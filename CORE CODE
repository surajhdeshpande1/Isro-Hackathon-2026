      stepsContainer.innerHTML = '';
      const scanBar = document.getElementById('scanBar');
      const scanPct = document.getElementById('scanPct');

      const stepsData = [
        { name: 'Diurnal LST acquisition', detail: 'INSAT-3D thermal passes' },
        { name: 'High-res land cover scan', detail: 'Resourcesat-2 LISS-IV' },
        { name: 'Building footprint extraction', detail: 'Cartosat-2 shadow maps' },
