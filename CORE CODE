          { id: `area_${i}_com`, name: `${z.name} - Commercial` },
          { id: `area_${i}_rd`, name: `${z.name} - Roads/Transit` }
        ];
        return computed;
      });
      zones.sort((a, b) => b.uhsi - a.uhsi);
      zones.forEach((z, i) => { z.rank = i + 1; });
      return zones;
