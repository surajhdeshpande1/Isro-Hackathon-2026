    /* ================= FORECAST & ADOPTION ================= */
    function adoptionFrac(year, complexity) {
      const params = { Low: [1.0, 0.95], Medium: [3.0, 0.55], High: [6.5, 0.32] }[complexity] || [3, 0.5];
      return 1 / (1 + Math.exp(-params[1] * (year - params[0])));
    }
    function zoneDTatYear(zone, year) {
      const sols = SOLUTIONS[zone.typology];
      let total = 0;
      sols.forEach(s => { total += (s.ambientDT || -1.5) * adoptionFrac(year, complexityKey(s.complexity)) * 0.5; });
      return total;
    }
    function computeForecastSeries(zones, meta) {
      const years = [0, 1, 2, 3, 4, 5, 7, 10, 15, 20];
      const totalPop = zones.reduce((s, z) => s + z.pop, 0) || 1;
      const avgLST = zones.reduce((s, z) => s + z.lstPeak * z.pop, 0) / totalPop;
      const series = years.map(y => {
        let weightedDT = 0, cost = 0;
        zones.forEach(z => {
          const dt = zoneDTatYear(z, y);
          weightedDT += dt * (z.pop / totalPop);
          SOLUTIONS[z.typology].forEach(s => {
            cost += s.costCr * (z.areaKm2 / 2.5) * adoptionFrac(y, complexityKey(s.complexity));
          });
        });
        const bauLST = avgLST + 0.07 * y;
        return { y: y, bauLST: bauLST, withLST: bauLST + weightedDT, dT: weightedDT, cost: cost, annualBenefit: Math.abs(weightedDT) * totalPop * 0.000180 };
      });
      let cumBenefit = 0;
      series.forEach((pt, i) => {
        if (i > 0) cumBenefit += (pt.annualBenefit + series[i - 1].annualBenefit) / 2 * (pt.y - series[i - 1].y);
        pt.cumBenefit = cumBenefit;
      });
      let breakevenYear = null;
      for (let i = 0; i < series.length; i++) { if (series[i].cumBenefit >= series[i].cost) { breakevenYear = series[i].y; break; } }
      return { series: series, breakevenYear: breakevenYear };
    }

    /* ================= CHART & GAUGE ================= */
    function svgLineChart(seriesArr, opts) {
      opts = opts || {};
      const W = opts.width || 400, H = opts.height || 200;
      const padL = 50, padR = 16, padT = 18, padB = 30;
      const xs = seriesArr[0].points.map(p => p.x);
      let allY = [];
      seriesArr.forEach(s => s.points.forEach(p => allY.push(p.y)));
      let minY = Math.min(...allY), maxY = Math.max(...allY);
      if (minY === maxY) { minY -= 1; maxY += 1; }
      const padY = (maxY - minY) * 0.1; minY -= padY; maxY += padY;
      const minX = Math.min(...xs), maxX = Math.max(...xs);
      const xScale = x => padL + (x - minX) / ((maxX - minX) || 1) * (W - padL - padR);
      const yScale = y => H - padB - (y - minY) / ((maxY - minY) || 1) * (H - padT - padB);
      let svg = `<svg viewBox="0 0 ${W} ${H}" class="chart-svg" xmlns="http://www.w3.org/2000/svg">`;
      const yTicks = 4;
      for (let i = 0; i <= yTicks; i++) {
        const val = minY + (maxY - minY) * i / yTicks;
        const yy = yScale(val);
        svg += `<line x1="${padL}" y1="${yy}" x2="${W - padR}" y2="${yy}" stroke="rgba(0,0,0,0.06)" stroke-width="1"/>`;
        svg += `<text x="${padL - 8}" y="${yy + 4}" text-anchor="end" font-size="9" fill="var(--mut2)" font-family="var(--mono)">${opts.yFmt ? opts.yFmt(val) : val.toFixed(1)}</text>`;
      }
      xs.forEach(x => {
        const xx = xScale(x);
        svg += `<text x="${xx}" y="${H - padB + 18}" text-anchor="middle" font-size="9" fill="var(--mut2)" font-family="var(--mono)">${opts.xFmt ? opts.xFmt(x) : x}</text>`;
      });
      seriesArr.forEach(s => {
        const pts = s.points.map(p => xScale(p.x) + ',' + yScale(p.y)).join(' ');
        if (s.fill) {
          const areaPts = xScale(s.points[0].x) + ',' + yScale(minY) + ' ' + pts + ' ' + xScale(s.points[s.points.length - 1].x) + ',' + yScale(minY);
          svg += `<polygon points="${areaPts}" fill="${s.color}" opacity="0.12"/>`;
        }
        svg += `<polyline points="${pts}" fill="none" stroke="${s.color}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>`;
      });
      return svg + '</svg>';
    }
    function radialGauge(value, max, color, size) {
      const startA = -225, totalSweep = 270;
      const r = (size / 2) - 6, cx = size / 2, cy = size / 2;
      const frac = clamp(value / max, 0, 1);
      const endA = startA + totalSweep * frac;
      const toXY = a => [cx + r * Math.cos(a * Math.PI / 180), cy + r * Math.sin(a * Math.PI / 180)];
      const p1 = toXY(startA), p2 = toXY(endA), p3 = toXY(startA + totalSweep);
      let s = `<svg viewBox="0 0 ${size} ${size}" width="${size}" height="${size}" class="gauge-svg">`;
      s += `<path d="M ${p1[0]} ${p1[1]} A ${r} ${r} 0 1 1 ${p3[0]} ${p3[1]}" fill="none" stroke="rgba(0,0,0,.06)" stroke-width="4.5" stroke-linecap="round"/>`;
      if (frac > 0) s += `<path d="M ${p1[0]} ${p1[1]} A ${r} ${r} 0 ${(totalSweep * frac > 180) ? 1 : 0} 1 ${p2[0]} ${p2[1]}" fill="none" stroke="${color}" stroke-width="4.5" stroke-linecap="round"/>`;
      s += `<text x="${cx}" y="${cy + 1}" text-anchor="middle" dominant-baseline="central" class="gauge-num" style="fill:${color}; font-size:12px;">${value}</text>`;
      return s + '</svg>';
    }

