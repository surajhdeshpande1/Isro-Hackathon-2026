            <button style="padding: 8px 16px; background: var(--teal); color: #fff; border: none; border-radius: 4px; cursor: pointer;" onclick="if(document.getElementById('intervention-area-select').value) { document.getElementById('intervention-step-2').style.display='none'; document.getElementById('intervention-step-3').style.display='block'; highlightAreaOnMap(); } else { alert('Please select an area'); }">Generate Solutions</button>
          </div>
        </div>

        <div id="intervention-step-3" style="display:none; padding: 10px; background: var(--surf); border: 1px solid var(--bord); border-radius: var(--r8); margin-bottom: 15px;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <h3 style="color: var(--gold); margin:0;">Recommended Scenarios</h3>
            <button style="padding: 4px 8px; background: transparent; color: var(--mut); border: 1px solid var(--bord); border-radius: 4px; cursor: pointer; font-size: 11px;" onclick="document.getElementById('intervention-step-3').style.display='none'; document.getElementById('intervention-step-1').style.display='block'; resetMapHighlights();">Start Over</button>
          </div>
          <p style="font-size: 13px; color: var(--mut); margin-bottom: 10px;">Physics-informed interventions tailored to your selected zone and area. Select one to view financial breakdown in the AI chat.</p>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <div style="padding: 12px; background: rgba(200, 154, 12, 0.1); border: 1px solid var(--gold); border-radius: var(--r8); cursor: pointer;" onclick="document.getElementById('aiChatInput').value='Explain the financials of Cool Pavements for my selected zone'; sendAIChat();">
              <strong>Cool Pavements & High-Albedo Surfaces</strong>
              <br><span style="font-size:11px; color:var(--mut);">Est. Temp Drop: 1.5°C | CapEx: ₹2.5 Cr | ROI: 4.5 Yrs</span>
            </div>
            <div style="padding: 12px; background: rgba(42, 136, 72, 0.1); border: 1px solid var(--green); border-radius: var(--r8); cursor: pointer;" onclick="document.getElementById('aiChatInput').value='How does Urban Forestry reduce LST in residential areas?'; sendAIChat();">
              <strong>Urban Forestry & Canopy Expansion</strong>
              <br><span style="font-size:11px; color:var(--mut);">Est. Temp Drop: 2.1°C | CapEx: ₹1.2 Cr | ROI: 6 Yrs</span>
            </div>
          </div>
        </div>
      `;
    }

    function populateAreas() {
      const zIdx = document.getElementById('intervention-zone-select').value;
      const areaSelect = document.getElementById('intervention-area-select');
      areaSelect.innerHTML = '<option value="">-- Choose an Area --</option>';
      if (zIdx !== '' && CURRENT.zones[zIdx]) {
        CURRENT.zones[zIdx].subAreas.forEach(a => {
          areaSelect.innerHTML += `<option value="${a.id}">${a.name}</option>`;
        });
      }
    }

    function zoomToZone() {
      const zIdx = document.getElementById('intervention-zone-select').value;
      if (zIdx !== '' && CURRENT.zones[zIdx] && mapLayers.prior) {
        const coords = CITY_COORDS[CURRENT.raw.toLowerCase()] || CURRENT.coords || [12.9716, 77.5946];
        const z = CURRENT.zones[zIdx];
        map.setView([coords[0] + z.latOffset, coords[1] + z.lngOffset], 13);
        
        mapLayers.prior.eachLayer(layer => {
          if (layer.feature && layer.feature.properties) {
            if (layer.feature.properties.zoneIdx == zIdx) {
              layer.setStyle({ opacity: 1, fillOpacity: 0.6 });
            } else {
              layer.setStyle({ opacity: 0.1, fillOpacity: 0.05 });
            }
          }
        });
      }
    }

    function highlightAreaOnMap() {
      const zIdx = document.getElementById('intervention-zone-select').value;
      const areaId = document.getElementById('intervention-area-select').value;
      if (zIdx !== '' && areaId !== '' && mapLayers.prior) {
        mapLayers.prior.eachLayer(layer => {
          if (layer.feature && layer.feature.properties) {
            if (layer.feature.properties.zoneIdx == zIdx && layer.feature.properties.subAreaId === areaId) {
              layer.setStyle({ opacity: 1, fillOpacity: 0.8, weight: 3, color: '#fff' });
              layer.bindTooltip("Selected Area", {sticky: true}).openTooltip();
            } else {
              layer.setStyle({ opacity: 0.1, fillOpacity: 0.05, weight: 1 });
            }
          }
        });
      }
    }

    function resetMapHighlights() {
      if (mapLayers.prior) {
        mapLayers.prior.eachLayer(layer => {
          if (layer.feature && layer.feature.properties) {
            layer.setStyle({ opacity: 0.90, fillOpacity: 0.50, weight: 1.5, color: layer.feature.properties.color });
            layer.unbindTooltip();
            layer.bindTooltip(
              `<b>Zone ${layer.feature.properties.zoneIdx + 1}</b><br>Heat Legend L${layer.feature.properties.priorityLevel}`,
              { sticky: true, className: 'heat-tip' }
            );
          }
        });
      }
    }

    function renderVerify() {
      const container = document.getElementById('verify-body');
      if (!container) return;
      container.innerHTML = `
        <div style="padding: 15px; text-align: center;">
          <div style="font-size: 40px; margin-bottom: 10px;">✅</div>
          <h2 style="color: var(--teal);">Validation Passed</h2>
          <p style="color: var(--mut); font-size: 14px; margin-top: 10px;">The scenario-based cooling interventions have been verified against established physical laws (Stefan-Boltzmann, Energy Balance Equations). No constraints violated.</p>
        </div>
      `;
    }

    function renderISRO() {
      const container = document.getElementById('isro-body');
      if (!container) return;
      container.innerHTML = `
        <div style="padding: 15px;">
          <h3 style="color: var(--blue); margin-bottom: 10px;">SURYAA Engine Architecture</h3>
          <ul style="color: var(--txt2); font-size: 13px; line-height: 1.6; padding-left: 20px;">
            <li><strong>Satellites:</strong> INSAT-3D, EOS-06, Landsat 8/9, Sentinel-2</li>
            <li><strong>Thermal Physics:</strong> Split-Window Algorithm for LST derivation</li>
            <li><strong>ML Engine:</strong> U-Net Spatial Downscaling from 1km to 10m resolution</li>
            <li><strong>Decision Logic:</strong> Scenario Knowledge Graph + Physics-Informed RAG LLM</li>
          </ul>
        </div>
      `;
    }

    function sendAIChat() {
      const input = document.getElementById('aiChatInput');
      const chatWin = document.getElementById('aiChatWindow');
      if (!input || !chatWin || !input.value.trim()) return;
      
      const msg = input.value.trim();
      input.value = '';
      
      const userDiv = document.createElement('div');
      userDiv.style.cssText = 'margin: 5px 10px; text-align: right;';
      userDiv.innerHTML = `<span style="background: var(--blue); color: #fff; padding: 6px 12px; border-radius: 12px 12px 0 12px; display: inline-block; font-size: 13px;">${msg}</span>`;
      chatWin.appendChild(userDiv);
      
      setTimeout(() => {
        const aiDiv = document.createElement('div');
        aiDiv.style.cssText = 'margin: 5px 10px; text-align: left;';
        aiDiv.innerHTML = `<span style="background: var(--bg2); border: 1px solid var(--bord); color: var(--txt); padding: 6px 12px; border-radius: 12px 12px 12px 0; display: inline-block; font-size: 13px; max-width: 90%;">Analyzing empirical data... Based on ISRO thermal scans and physics models, this intervention is highly effective for the selected zone morphology.</span>`;
        chatWin.appendChild(aiDiv);
        chatWin.scrollTop = chatWin.scrollHeight;
      }, 800);
    }
  </script>
</body>

</html>
