    function updateSimulatedLST() {
      const sc = SCENARIOS[activeScenarioIdx];
      const rawCooling = (sc.cooling[0] + sc.cooling[1]) / 2;
      const z = CURRENT.zones[ACTIVE_ZONE_IDX];
      const dt = -rawCooling * adoptionFrac(currentForecastYear, sc.risk.includes('Low') ? 'Low' : 'Medium');
      const simulatedLst = z.lstPeak + dt;
      const lstVals = document.querySelectorAll('.kpi-val');
      if (lstVals.length >= 2) lstVals[1].textContent = `${simulatedLst.toFixed(1)}C`;

      if (mapLayers.heatCells && CURRENT) {
        mapLayers.heatCells.eachLayer(layer => {
          const idx = layer.feature.properties.zoneIdx;
          const zone = CURRENT.zones[idx];
          const zdt = -rawCooling * adoptionFrac(currentForecastYear, sc.risk.includes('Low') ? 'Low' : 'Medium');
          const zSimLst = layer.feature.properties.lst + zdt;
          const simUhsi = clamp(Math.round(38 + (zSimLst - CURRENT.meta.baselineLST) * 3.5), 30, 99);
          const sev = severityInfo(simUhsi);
          layer.setStyle({ fillColor: sev.color, color: sev.color });
          layer.setTooltipContent(`#${idx + 1}: ${escapeHtml(zone.name)}<br>Simulated LST: <b>${zSimLst.toFixed(1)}°C</b>`);
        });
      }
    }

