      const typ = TYPOLOGIES[zoneDef.typology];
      const rng = rngFor(cityKey + '::' + zoneDef.typology + '::' + zoneDef.name);
      const amp = typ.ampRange[0] + rng() * (typ.ampRange[1] - typ.ampRange[0]);
      const lstPeak = meta.baselineLST + amp + (rng() - 0.5) * 1.2;
      const uhsi = clamp(Math.round(38 + (lstPeak - meta.baselineLST) * 3.5 + rng() * 5), 38, 99);
      const areaKm2 = round1(0.9 + rng() * 3.0);
      const pop = Math.round(areaKm2 * (zoneDef.typology === 'SCHI' ? 22000 : 9000) * (0.7 + rng() * 0.5));
      const imperviousPct = clamp(Math.round(40 + rng() * 45), 20, 96);
      return {
        typology: zoneDef.typology, name: zoneDef.name, lstPeak: round1(lstPeak), uhsi: uhsi,
        areaKm2: areaKm2, pop: pop, imperviousPct: imperviousPct,
        latOffset: Math.sin(rng() * Math.PI * 2) * (0.007 + rng() * 0.012),
