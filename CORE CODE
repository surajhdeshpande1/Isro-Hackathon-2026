    function updateMapMiniStat(latlng) {
      if (!CURRENT) return;
      const dist = Math.sqrt(Math.pow(latlng.lat - CURRENT.coords[0], 2) + Math.pow(latlng.lng - CURRENT.coords[1], 2));
      const factor = Math.max(0, 1 - dist / 0.025);
      const simulatedLST = CURRENT.meta.baselineLST + factor * 6.0;
      updateHoverReadout(
        `Coordinates [${latlng.lat.toFixed(4)}, ${latlng.lng.toFixed(4)}]`,
        simulatedLST,
        Math.round(40 + factor * 48),
        factor > 0.5 ? 'Urban Core' : 'Sprawl Edge',
        Math.round(20 - factor * 14),
        Math.round(40 + factor * 45)
      );
    }

    /* ================= OSM LIVE OVERPASS GATEWAY ================= */
    async function loadLiveOSMData(centerCoords) {
      const range = 0.008;
      const bbox = [centerCoords[0] - range, centerCoords[1] - range, centerCoords[0] + range, centerCoords[1] + range];
      const overpassUrl = `https://overpass-api.de/api/interpreter?data=[out:json][timeout:15];(way["highway"](${bbox.join(',')});way["building"](${bbox.join(',')});way["natural"="water"](${bbox.join(',')});way["leisure"="park"](${bbox.join(',')});node["amenity"~"hospital|school|university"](${bbox.join(',')}););out body;>;out skel qt;`;
      try {
        const res = await fetch(overpassUrl);
        const data = await res.json();
        if (data && data.elements) processOverpassData(data);
      } catch (err) {
        console.warn("Overpass API offline. Retaining synthetic layers.");
      }
    }

    function processOverpassData(osmData) {
      const nodes = {};
      osmData.elements.forEach(el => { if (el.type === 'node') nodes[el.id] = [el.lon, el.lat]; });
      const buildings = []; const highways = []; const waterBodies = []; const parks = []; const amenities = [];
      const rng = rngFor(CURRENT.key + '::osm');

      osmData.elements.forEach(el => {
        const tags = el.tags || {};
        if (el.type === 'way' && el.nodes) {
          const coords = el.nodes.map(nId => nodes[nId]).filter(c => c !== undefined);
          if (coords.length < 2) return;
          if (tags.building) {
            if (coords[0][0] !== coords[coords.length - 1][0] || coords[0][1] !== coords[coords.length - 1][1]) coords.push(coords[0]);
            const bTypes = ['Industrial', 'Commercial', 'Residential', 'Institutional', 'Transit', 'Utility'];
            const bt = tags.amenity === 'hospital' ? 'Institutional' : (tags.industrial ? 'Industrial' : bTypes[Math.floor(rng() * bTypes.length)]);
            buildings.push(turf.polygon([coords], { name: tags.name || `${bt} footprint: ${el.id}`, lst: CURRENT.meta.baselineLST + rng() * 5.5 + 1.5, uhsi: Math.round(55 + rng() * 35), bType: bt }));
          } else if (tags.highway) {
            highways.push(turf.lineString(coords, { name: tags.name || `Highway ref ${tags.ref || el.id}`, lst: CURRENT.meta.baselineLST + 5.2, uhsi: 78 }));
          } else if (tags.natural === 'water' || tags.water || tags.landuse === 'reservoir' || tags.basin) {
            if (coords[0][0] !== coords[coords.length - 1][0] || coords[0][1] !== coords[coords.length - 1][1]) coords.push(coords[0]);
            waterBodies.push(turf.polygon([coords], { name: tags.name || `Water body: ${el.id}`, lst: CURRENT.meta.baselineLST - 3.8, uhsi: 35, type: 'water' }));
          } else if (tags.leisure === 'park' || tags.landuse === 'grass' || tags.leisure === 'garden' || tags.landuse === 'forest') {
            if (coords[0][0] !== coords[coords.length - 1][0] || coords[0][1] !== coords[coords.length - 1][1]) coords.push(coords[0]);
            parks.push(turf.polygon([coords], { name: tags.name || `Green park: ${el.id}`, lst: CURRENT.meta.baselineLST - 2.5, uhsi: 40, type: 'park' }));
          }
        } else if (el.type === 'node' && tags.amenity) {
          if (['hospital', 'school', 'university', 'clinic', 'college'].includes(tags.amenity)) {
            amenities.push({
              type: 'Feature',
              geometry: { type: 'Point', coordinates: [el.lon, el.lat] },
              properties: {
                name: tags.name || `${titleCase(tags.amenity)}: ${el.id}`,
                lst: CURRENT.meta.baselineLST + (tags.amenity === 'hospital' ? -1.0 : 1.2),
                uhsi: tags.amenity === 'hospital' ? 48 : 64,
                type: 'amenity',
                amenityType: tags.amenity
              }
            });
          }
        }
      });

      if (buildings.length > 0 && mapLayers.buildings) {
        map.removeLayer(mapLayers.buildings);
        mapLayers.buildings = L.geoJSON(buildings, {
          style: function (f) {
            let c = 'var(--mut2)';
            const t = f.properties.bType;
            if (t === 'Industrial') c = '#C03010';
            else if (t === 'Commercial') c = '#C89A0C';
            else if (t === 'Residential') c = '#D97B20';
            else if (t === 'Institutional') c = '#2860A8';
            else if (t === 'Transit') c = '#6840A8';
            else if (t === 'Utility') c = '#1A9A88';
            return { color: 'rgba(0,0,0,0.15)', fillColor: c, fillOpacity: 0.5, weight: 1 };
          },
          onEachFeature: (f, l) => {
            const p = f.properties;
            l.bindPopup(`<h4>${escapeHtml(p.name)}</h4><p style="font-size:11px;">LST: <b>${p.lst.toFixed(1)}°C</b></p>`);
            l.on('mouseover', () => { updateHoverReadout(p.name, p.lst, p.uhsi, p.bType.toUpperCase(), 12, 85); });
          }
        }).addTo(map);
      }
      if (highways.length > 0 && mapLayers.roads) {
        map.removeLayer(mapLayers.roads);
        mapLayers.roads = L.geoJSON(highways, {
          style: { color: 'var(--amber)', weight: 2.2 },
          onEachFeature: (f, l) => {
            const p = f.properties;
            l.bindPopup(`<h4>${escapeHtml(p.name)}</h4>`);
            l.on('mouseover', () => { updateHoverReadout(p.name, p.lst, p.uhsi, 'LIVE HIGHWAY', 8, 92); });
          }
        }).addTo(map);
      }
      if (waterBodies.length > 0 && mapLayers.rivers) {
        map.removeLayer(mapLayers.rivers);
        mapLayers.rivers = L.geoJSON(waterBodies, {
          style: { color: '#1A9A88', fillColor: '#1A9A88', fillOpacity: 0.6, weight: 1 },
          onEachFeature: (f, l) => {
            const p = f.properties;
            l.bindPopup(`<h4>${escapeHtml(p.name)}</h4><p style="font-size:11px;">LST: <b>${p.lst.toFixed(1)}°C</b></p>`);
            l.on('mouseover', () => { updateHoverReadout(p.name, p.lst, p.uhsi, 'LIVE WATER BODY', 35, 5); });
          }
        }).addTo(map);
      }
      if (parks.length > 0 && mapLayers.parks) {
        map.removeLayer(mapLayers.parks);
        mapLayers.parks = L.geoJSON(parks, {
          style: { color: '#2A8848', fillColor: '#2A8848', fillOpacity: 0.5, weight: 1 },
          onEachFeature: (f, l) => {
            const p = f.properties;
            l.bindPopup(`<h4>${escapeHtml(p.name)}</h4><p style="font-size:11px;">LST: <b>${p.lst.toFixed(1)}°C</b></p>`);
            l.on('mouseover', () => { updateHoverReadout(p.name, p.lst, p.uhsi, 'LIVE GREEN PARK', 75, 12); });
          }
        }).addTo(map);
      }
      if (amenities.length > 0) {
        if (mapLayers.amenities) map.removeLayer(mapLayers.amenities);
        mapLayers.amenities = L.geoJSON(amenities, {
          pointToLayer: function (f, latlng) {
            const color = f.properties.amenityType === 'hospital' ? 'var(--red)' : 'var(--blue)';
            return L.circleMarker(latlng, { radius: 6, fillColor: color, color: color, weight: 2.2, fillOpacity: 0.25 });
          },
          onEachFeature: (f, l) => {
            const p = f.properties;
            l.bindPopup(`<h4>${escapeHtml(p.name)}</h4><p style="font-size:11px;">LST: <b>${p.lst.toFixed(1)}°C</b></p>`);
            l.on('mouseover', () => { updateHoverReadout(p.name, p.lst, p.uhsi, p.amenityType.toUpperCase(), 25, 45); });
          }
        }).addTo(map);
      }
    }

