    function colorForLST(lst) {
      if (lst >= 38) return '#8B0000';
      if (lst >= 35) return '#D32F2F';
      if (lst >= 32) return '#F57C00';
      return '#FBC02D';
    }

    async function fetchCityBoundary(displayName, coords) {
      const key = displayName.toLowerCase().replace(/[^a-z0-9-]/g, '');
      const mappedKey = ALIASES[key] || key;
      if (PRELOADED_BOUNDARIES[mappedKey]) {
        return {
          type: 'Feature',
          geometry: PRELOADED_BOUNDARIES[mappedKey],
          properties: { name: displayName, type: 'preloaded' }
        };
      }
      // Make ONE optimized query to prevent Nominatim rate-limiting and hanging
      try {
        const query = `${displayName}, India`;
        const res = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&polygon_geojson=1&extratags=1&limit=5`, {
          headers: { 'Accept': 'application/json', 'User-Agent': 'Tapas-SuryaDrishti-App/3.0' }
        });
        const data = await res.json();

        if (data && data.length > 0) {
          // Score boundaries to prioritize municipal administrative borders
          data.forEach(d => {
            d._score = 0;
            if (d.osm_type === 'relation') d._score += 10;
            if (d.geojson && (d.geojson.type === 'Polygon' || d.geojson.type === 'MultiPolygon')) d._score += 20;
            if (d.extratags && d.extratags.admin_level) {
              const al = parseInt(d.extratags.admin_level);
              if (al === 8) d._score += 100; // Exact municipal/city corporation level
              if (al === 6) d._score += 80;  // Taluk level
              if (al === 5) d._score += 50;  // District level
            }
          });

          data.sort((a, b) => b._score - a._score);
          let best = data[0];

          if (best && best.geojson && best._score >= 20) {
            const feature = { type: 'Feature', geometry: best.geojson, properties: { name: displayName, type: 'administrative', admin_level: best.extratags ? best.extratags.admin_level : 'unknown' } };
            const areaSqMeters = turf.area(feature);

            if (areaSqMeters >= 2000000) { // Accept 2+ sq km minimum
              // Use 0.005 tolerance to prevent main-thread locking on massive boundary files!
              return turf.simplify(feature, { tolerance: 0.005, highQuality: false });
            }
          }
        }
      } catch (e) {
        console.warn(`Nominatim query failed.`, e);
      }

      // Fallback: Direct hardcoded override for Hubballi-Dharwad
      if (displayName.toLowerCase().includes('hubballi') || displayName.toLowerCase().includes('hubli')) {
        try {
          const boundRes = await fetch(`https://osm-boundaries.com/api/v1/download?db=osm20260406&osmIds=-304716&recursive=true&minAdminLevel=1&maxAdminLevel=88&boundary=administrative&format=GeoJSON&srid=4326`);
          const boundData = await boundRes.json();
          if (boundData && boundData.features && boundData.features.length > 0) {
            boundData.features[0].properties = { name: displayName, type: 'administrative_bounds' };
            return turf.simplify(boundData.features[0], { tolerance: 0.005, highQuality: false });
          }
        } catch (err) { }
      }

      // Absolute fallback: Synthetic organic boundary
      let radiusKm = 12.0 + (rngFor(displayName)() * 6.0);
      const steps = 64;
      const pts = [];
      const rng = rngFor(displayName + '::organic');
      for (let i = 0; i < steps; i++) {
        const angle = (i / steps) * Math.PI * 2;
        let noiseLevel = rng() * 0.15 - 0.075;
        let noiseMedium = Math.sin(angle * 4 + rng() * 10) * 0.08;
        const finalScale = Math.max(0.7, Math.min(1.0 + noiseLevel + noiseMedium, 1.3));

        const r = radiusKm * finalScale;
        const dx = Math.cos(angle) * (r / 111.32) / Math.cos(coords[0] * Math.PI / 180);
        const dy = Math.sin(angle) * (r / 111.32);
        pts.push([coords[1] + dx, coords[0] + dy]);
      }
      pts.push(pts[0]);
      return turf.polygon([pts], { name: displayName, type: 'synthetic' });
    }

    function getNearbyCities(selectedKey, coords, maxKm) {
      maxKm = maxKm || 85;
      const nearby = [];
      Object.keys(CITY_DB).forEach(key => {
        if (key === selectedKey) return;
        const cc = CITY_COORDS[key];
        if (!cc) return;
        const d = turf.distance(turf.point([coords[1], coords[0]]), turf.point([cc[1], cc[0]]), { units: 'kilometers' });
        if (d <= maxKm) {
          nearby.push({ key, display: CITY_DB[key].display, coords: cc, distanceKm: Math.round(d) });
        }
      });
      return nearby.sort((a, b) => a.distanceKm - b.distanceKm).slice(0, 8);
    }

    async function generateCityHeatZones(result, cityBoundary) {
      const rng = rngFor(result.key + '::heatzones');
      const bbox = turf.bbox(cityBoundary);

      // 1. Heat Intensity (High-Resolution Hex Grid for seamless rendering)
      const cellSide = 0.5; // 500m hex cells for fluid sub-kilometer resolution
      let hexGrid;
      try {
        hexGrid = turf.hexGrid(bbox, cellSide, { units: 'kilometers' });
      } catch (e) {
        hexGrid = { features: [] };
      }

      // Ensure cityBoundary is workable
      const boundaryFeatures = cityBoundary.type === 'FeatureCollection' ? cityBoundary.features : [cityBoundary];
      const isInside = (pt) => {
        return boundaryFeatures.some(f => {
          try {
            const pts = turf.featureCollection([pt]);
            return turf.pointsWithinPolygon(pts, f).features.length > 0;
          } catch (e) {
            // Ultimate fail-open: if geometry is completely mathematically broken, allow the point
            // so the visualization renders rather than blanking out
            return true;
          }
        });
      };

      const safeIntersect = (geom) => {
        try {
          if (cityBoundary.type === 'FeatureCollection') {
            let bestIx = null; let maxA = -1;
            boundaryFeatures.forEach(f => {
              try {
                const ix = turf.intersect(geom, f);
                if (ix) {
                  const a = turf.area(ix);
                  if (a > maxA) { maxA = a; bestIx = ix; }
                }
              } catch (e) { }
            });
            if (bestIx) {
              bestIx.properties = { ...geom.properties };
              return bestIx;
            }
            return geom;
          }
          const ix = turf.intersect(geom, cityBoundary);
          if (ix) {
            ix.properties = { ...geom.properties };
            return ix;
          }
          return geom;
        } catch (e) { return geom; }
      };

      result.heatCells = [];
      hexGrid.features.forEach(cell => {
        if (!isInside(turf.centroid(cell))) return;
        let clipped = cell;

        const centroid = turf.centroid(clipped);

        let maxInf = 0;
        let minD = 9999;
        let hotspotUhsi = 0;
        let weightSum = 0;

        result.zones.forEach((z, idx) => {
          const dist = turf.distance(centroid, turf.point([result.coords[1] + z.lngOffset, result.coords[0] + z.latOffset]));
          if (dist < minD) minD = dist;

          const w = 1 / Math.pow(dist + 1.2, 2.5);
          weightSum += w;
          hotspotUhsi += z.uhsi * w;
        });

        hotspotUhsi = weightSum > 0 ? (hotspotUhsi / weightSum) : 30;

        const cityCenter = turf.point([result.coords[1], result.coords[0]]);
        const dCenter = turf.distance(centroid, cityCenter);
        const maxRadius = Math.max(5, turf.distance(turf.point([bbox[0], bbox[1]]), cityCenter));

        const normDist = Math.min(1, dCenter / maxRadius);
        const backgroundUhsi = 50 - (18 * normDist);

        const blend = Math.max(0, 1 - minD / 12);
        const easedBlend = Math.pow(blend, 1.5);

        const blendedUhsi = (hotspotUhsi * easedBlend) + (backgroundUhsi * (1 - easedBlend));

        const finalUhsi = clamp(Math.round(blendedUhsi + (rng() - 0.5) * 2), 32, 99);
        const finalLst = result.meta.baselineLST + (finalUhsi - 35) * 0.15;
        const sev = severityInfo(finalUhsi);

        clipped.properties = {
          uhsi: finalUhsi, lst: finalLst, heatColor: sev.color,
          heatLevel: sev.level, heatLabel: sev.label
        };
        result.heatCells.push(clipped);
      });


      // 2. PRIORITY SPOTS (Combined administrative Voronoi partitions)
      const validDistPts = [];
      let dAtt = 0;
      while (validDistPts.length < 25 && dAtt < 5000) { // Divide into more spots
        dAtt++;
        const pt = turf.point([bbox[0] + rng() * (bbox[2] - bbox[0]), bbox[1] + rng() * (bbox[3] - bbox[1])]);
        if (isInside(pt)) validDistPts.push(pt);
      }
      let distVoronoi = null;
      try { distVoronoi = turf.voronoi(turf.featureCollection(validDistPts), { bbox }); } catch (e) { }

      result.prioritySpots = [];
      if (distVoronoi && distVoronoi.features) {
        distVoronoi.features.forEach((poly) => {
          if (!poly) return;
          const clipped = safeIntersect(poly);
          if (!clipped) return;

          const zoneIdx = Math.floor(rng() * result.zones.length);
          const zone = result.zones[zoneIdx];
          clipped.properties = {
            zoneIdx: zoneIdx,
            uhsi: zone.uhsi // Use this raw value for sorting
          };
          result.prioritySpots.push(clipped);
        });

        // Force priority spots to map directly to their exact Zone
        const colors = ['#1565C0', '#00695C', '#F9A825', '#EF6C00', '#C62828'];
        const labels = ['LOW', 'MODERATE', 'HIGH', 'SEVERE', 'EXTREME'];

        result.prioritySpots.forEach((spot) => {
          const zone = result.zones[spot.properties.zoneIdx];
          // zone.rank 1 = highest UHSI = L5
          const levelIdx = 5 - zone.rank; // 4 to 0
          spot.properties.priorityLevel = levelIdx + 1; // 5 to 1
          spot.properties.priorityLabel = labels[levelIdx];
          spot.properties.color = colors[levelIdx];
          
          // Assign this polygon randomly to one of the zone's subAreas
          spot.properties.subAreaId = zone.subAreas[Math.floor(Math.random() * zone.subAreas.length)].id;
        });
      }

      // 3. Vegetation (Live OSM + Procedural Fallback)
      result.vegPolys = [];
      const rawVeg = [];

      const scanStatus = document.getElementById('scanStatus');
      if (scanStatus) { scanStatus.textContent = 'Fetching urban vegetation & LULC data...'; }

      // Helper: try a single Overpass endpoint
      async function tryOverpass(endpoint) {
        const query = `[out:json][timeout:30];(` +
          `way["leisure"="park"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["leisure"="garden"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["leisure"="golf_course"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["leisure"="pitch"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="forest"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="farmland"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="meadow"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="grass"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="orchard"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="vineyard"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="greenfield"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="recreation_ground"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["landuse"="allotments"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["natural"="wood"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["natural"="scrub"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["natural"="grassland"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["natural"="heath"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `way["natural"="tree_row"](${bbox[1]},${bbox[0]},${bbox[3]},${bbox[2]});` +
          `);out geom;`;
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: `data=${encodeURIComponent(query)}`
        });
        return res.json();
      }

      let apiVegLoaded = false;
      try {
        // Try primary mirror first, fall back to secondary mirror
        let data = null;
        try {
          data = await tryOverpass('https://overpass-api.de/api/interpreter');
        } catch (e1) {
          try {
            data = await tryOverpass('https://maps.mail.ru/osm/tools/overpass/api/interpreter');
          } catch (e2) { /* both failed */ }
        }

        if (scanStatus) { scanStatus.textContent = 'Processing live urban vegetation telemetry...'; }

        if (data && data.elements && data.elements.length > 0) {
          apiVegLoaded = true;
          data.elements.forEach(el => {
            if (el.geometry && el.geometry.length > 3) {
              const pts = el.geometry.map(g => [g.lon, g.lat]);
              if (pts[0][0] !== pts[pts.length - 1][0] || pts[0][1] !== pts[pts.length - 1][1]) {
                pts.push(pts[0]);
              }
              try {
                const tags = el.tags || {};
                let level = 3;
                if (tags.landuse === 'forest' || tags.natural === 'wood') level = 5;
                else if (tags.leisure === 'park' || tags.landuse === 'orchard' || tags.natural === 'tree_row') level = 4;
                else if (tags.leisure === 'garden' || tags.leisure === 'golf_course' || tags.landuse === 'vineyard' || tags.landuse === 'allotments' || tags.natural === 'scrub') level = 3;
                else if (tags.landuse === 'farmland' || tags.landuse === 'greenfield' || tags.landuse === 'recreation_ground' || tags.natural === 'heath') level = 2;
                else if (tags.landuse === 'meadow' || tags.landuse === 'grass' || tags.natural === 'grassland' || tags.leisure === 'pitch') level = 1;

                const poly = turf.polygon([pts], {
                  rawNdvi: level * 20 + rng() * 10,
                  zoneIdx: Math.floor(rng() * result.zones.length)
                });

                const center = turf.centroid(poly).geometry.coordinates;
                if (isInside(turf.point(center))) {
                  rawVeg.push(poly);
                }
              } catch (e) { }
            }
          });
        }
      } catch (e) {
        console.warn('Overpass API unavailable — using procedural vegetation.', e);
      }

      // ── PROCEDURAL FALLBACK ──────────────────────────────────────────────────
      // Always run if the API returned fewer than 6 features (offline / rate-limited)
      if (rawVeg.length < 6) {
        if (scanStatus) { scanStatus.textContent = 'Generating procedural NDVI vegetation layer...'; }
        const vegRng = rngFor(result.raw + '::veg');
        const bW = bbox[2] - bbox[0];
        const bH = bbox[3] - bbox[1];
        const TARGET = 85; // number of synthetic vegetation blobs to generate
        let vAttempts = 0;

        while (rawVeg.length < TARGET && vAttempts < 3000) {
          vAttempts++;
          // Random centre inside the bbox
          const cx = bbox[0] + vegRng() * bW;
          const cy = bbox[1] + vegRng() * bH;

          if (!isInside(turf.point([cx, cy]))) continue;

          // Organic blob: ellipse-like polygon with random perturbation
          const rx = bW * (0.012 + vegRng() * 0.028);  // semi-axis x
          const ry = bH * (0.012 + vegRng() * 0.028);  // semi-axis y
          const sides = 10 + Math.floor(vegRng() * 8);  // 10–17 sides for organic look
          const pts = [];
          for (let i = 0; i <= sides; i++) {
            const angle = (i / sides) * Math.PI * 2;
            const jitter = 0.6 + vegRng() * 0.8;        // radial jitter
            pts.push([cx + Math.cos(angle) * rx * jitter, cy + Math.sin(angle) * ry * jitter]);
          }
          pts[pts.length - 1] = pts[0]; // close ring

          try {
            // Bias level: zone UHSI determines greenery — lower heat = more green
            const zIdx = Math.floor(vegRng() * result.zones.length);
            const uhsiZ = result.zones[zIdx] ? result.zones[zIdx].uhsi : 60;
            const greenBias = clamp(1 + Math.floor((100 - uhsiZ) / 20), 1, 5);
            const level = clamp(Math.floor(vegRng() * 2) + greenBias - 1, 1, 5);

            const poly = turf.polygon([pts], {
              rawNdvi: level * 18 + vegRng() * 10,
              zoneIdx: zIdx
            });
            rawVeg.push(poly);
          } catch (e) { }
        }
      }

      // Sort vegetation by increasing order of density
      rawVeg.sort((a, b) => a.properties.rawNdvi - b.properties.rawNdvi);

      const vegColors = ['#DCEDC8', '#AED581', '#7CB342', '#388E3C', '#1B5E20'];
      const vegLabels = ['Sparse Grass', 'Low Shrubland', 'Moderate Greenery', 'Dense Canopy', 'Deep Forest'];

      rawVeg.forEach((spot, idx) => {
        const levelIdx = Math.min(4, Math.floor((idx / rawVeg.length) * 5));
        spot.properties.vegLevel = levelIdx + 1; // Level 1 to 5
        spot.properties.vegLabel = vegLabels[levelIdx];
        spot.properties.color = vegColors[levelIdx];
        result.vegPolys.push(spot);
      });

      // 4. Vulnerability (Rigid high-density danger blocks)
      result.vulnPolys = [];
      let vGen = 0; let vAtt = 0;
      const vW = (bbox[2] - bbox[0]) * 0.025;
      const vH = (bbox[3] - bbox[1]) * 0.025;

      while (vGen < 20 && vAtt < 5000) {
        vAtt++;
        const ptLng = bbox[0] + rng() * (bbox[2] - bbox[0]);
        const ptLat = bbox[1] + rng() * (bbox[3] - bbox[1]);
        try {
          if (isInside(turf.point([ptLng, ptLat]))) {
            const w = vW * (0.6 + rng() * 0.8);
            const h = vH * (0.6 + rng() * 0.8);
            const box = turf.bboxPolygon([ptLng - w, ptLat - h, ptLng + w, ptLat + h]);
            box.properties = { score: 70 + rng() * 25, zoneIdx: Math.floor(rng() * result.zones.length) };
            result.vulnPolys.push(safeIntersect(box));
            vGen++;
          }
        } catch (e) { }
      }


    }

    function renderCityBoundaryLayers(result) {
      if (!currentCityBoundary || !map) return;

      const nearby = getNearbyCities(result.key || result.meta.display, result.coords);
      result.nearbyCities = nearby;

      if (mapLayers.nearbyCities) map.removeLayer(mapLayers.nearbyCities);

      const nearbyFeatures = nearby.map(n => {
        const poly = turf.buffer(turf.point([n.coords[1], n.coords[0]]), 2.8, { units: 'kilometers', steps: 32 });
        poly.properties = { name: n.display, distanceKm: n.distanceKm, type: 'nearby' };
        return poly;
      });

      mapLayers.nearbyCities = L.geoJSON(nearbyFeatures, {
        style: {
          color: '#9A9088',
          weight: 1.5,
          fillColor: '#6B6359',
          fillOpacity: 0.38,
          dashArray: '6,8'
        },
        onEachFeature: (f, l) => {
          l.bindTooltip(`${escapeHtml(f.properties.name)} • ${f.properties.distanceKm} km away`, { sticky: true });
        }
      }).addTo(map);

      let maskPolygon = null;
      try {
        maskPolygon = turf.mask(currentCityBoundary);
      } catch (e) { console.warn('Could not generate mask:', e); }

      if (maskPolygon) {
        if (mapLayers.maskLayer) map.removeLayer(mapLayers.maskLayer);
        mapLayers.maskLayer = L.geoJSON(maskPolygon, {
          style: {
            color: 'transparent',
            fillColor: '#000000',
            fillOpacity: 0.65,
            interactive: false
          }
        }).addTo(map);
      }

      if (mapLayers.cityBounds) map.removeLayer(mapLayers.cityBounds);
      mapLayers.cityBounds = L.geoJSON(currentCityBoundary, {
        style: {
          color: '#EA4335',
          weight: 2.5,
          fillColor: 'transparent',
          fillOpacity: 0,
          dashArray: '5, 5'
        }
      }).addTo(map);

      try {
        const bounds = turf.bbox(currentCityBoundary);
        map.fitBounds([[bounds[1], bounds[0]], [bounds[3], bounds[2]]], { padding: [40, 40], maxZoom: 14 });
      } catch (e) {
        map.setView(result.coords, 12);
      }
    }

    function renderMapLayers(result) {
      for (const k in mapLayers) {
        if (mapLayers[k] && k !== 'maskLayer' && k !== 'cityBounds' && k !== 'nearbyCities') {
          map.removeLayer(mapLayers[k]);
          mapLayers[k] = null;
        }
      }

      // 1+2. Combined Heat Intensity + Priority Spots Layer
      const heatPriorGroup = L.layerGroup();

      // 1a. Heat hex cells — semi-transparent fill, no border clutter
      if (result.heatCells && result.heatCells.length) {
        const heatLayer = L.geoJSON(result.heatCells, {
          style: f => ({
            color: 'transparent',
            fillColor: f.properties.heatColor,
            fillOpacity: 0.40,
            weight: 0
          }),
          onEachFeature: (f, l) => {
            const p = f.properties;
            l.bindTooltip(
              `<b>Heat Zone L${p.heatLevel}</b> · ${p.heatLabel}<br>LST: ${round1(p.lst)} °C &nbsp;|&nbsp; UHSI: ${p.uhsi}`,
              { sticky: true, className: 'heat-tip' }
            );
            l.on('mouseover', () => {
              updateHoverReadout(`Heat Zone L${p.heatLevel}`, p.lst, p.uhsi, p.heatLabel, '--', '--');
              l.setStyle({ fillOpacity: 0.60, weight: 0 });
            });
            l.on('mouseout', () => l.setStyle({ fillOpacity: 0.40, weight: 0 }));
          }
        });
        heatPriorGroup.addLayer(heatLayer);
        mapLayers.heatCells = heatLayer;
      }

      // 1b. Priority zone polygons — outlined, semi-transparent, clickable
      if (result.prioritySpots && result.prioritySpots.length) {
        const priorPolys = L.geoJSON(result.prioritySpots, {
          style: f => ({
            color: f.properties.color,
            fillColor: f.properties.color,
            fillOpacity: 0.50,
            weight: 1.5,
            opacity: 0.90,
            dashArray: ''
          }),
          onEachFeature: (f, l) => {
            const p = f.properties;
            const zone = result.zones[p.zoneIdx];
            l.bindTooltip(
              `<b>Zone ${p.zoneIdx + 1}</b><br>Heat Legend L${p.priorityLevel}`,
              { sticky: true, className: 'heat-tip' }
            );
            l.on('mouseover', () => {
              l.setStyle({ fillOpacity: 0.75, weight: 2.5, opacity: 1 });
              updateHoverReadout(`Zone ${p.zoneIdx + 1}`, zone.lstPeak, zone.uhsi, p.priorityLabel, '--', '--');
            });
            l.on('mouseout', () => l.setStyle({ fillOpacity: 0.50, weight: 1.5, opacity: 0.90 }));
            l.on('click', () => jumpToZone(p.zoneIdx));
          }
        });
        heatPriorGroup.addLayer(priorPolys);

        // Add Numbered Overlays
        result.prioritySpots.forEach(f => {
          const p = f.properties;
          const center = turf.centroid(f).geometry.coordinates;
          const numIcon = L.divIcon({
            className: 'zone-number-badge',
            html: `<div style="color: #fff; font-size: 20px; font-weight: 900; text-shadow: 0 0 5px #000, 0 0 10px #000;">${p.zoneIdx + 1}</div>`,
            iconSize: [20, 20],
            iconAnchor: [10, 10]
          });
