        { name: 'UHI Causal DNA profiling', detail: 'PINN thermodynamics' },
        { name: '10 Portfolio simulations', detail: 'NSGA-II optimization' }
      ];

      for (let i = 0; i < stepsData.length; i++) {
        const step = stepsData[i];
        const el = document.createElement('div');
        el.className = 'scan-step active';
        el.innerHTML = `
      <div class="scan-step-icon">${i + 1}</div>
      <div class="scan-step-text">${step.name}</div>
      <div class="scan-step-sub">${step.detail}</div>
    `;
        stepsContainer.appendChild(el);
        stepsContainer.scrollTop = stepsContainer.scrollHeight;

        const pct = Math.round(((i + 0.5) / stepsData.length) * 100);
        scanBar.style.width = `${pct}%`;
        scanPct.textContent = `${pct}%`;

        await sleep(250 + Math.random() * 150);
        el.className = 'scan-step done';
      }

      scanBar.style.width = '100%';
      scanPct.textContent = '100%';
      await sleep(300);

      const result = buildCityResult(cityRaw);
      result.key = resolveCity(cityRaw).key;

      let coords = CITY_COORDS[result.key] || null;
      try {
        const res = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(result.meta.display)},India&format=json&limit=1&featureType=city`);
        const data = await res.json();
        if (data && data.length > 0) coords = [parseFloat(data[0].lat), parseFloat(data[0].lon)];
      } catch (err) {
        console.warn('Nominatim fetch failed:', err);
      }

      if (!coords) {
        const rng = rngFor(result.key);
        coords = [12.9716 + (rng() - 0.5) * 6, 77.5946 + (rng() - 0.5) * 6];
      }

      result.coords = coords;

      const scanStatus = document.getElementById('scanStatus');
      if (scanStatus) { scanStatus.classList.add('act'); scanStatus.textContent = 'Acquiring live meteorological telemetry...'; }

      // 1. Fetch live telemetry using the provided OpenWeatherMap API Key
      const OWM_API_KEY = '8b9b9699764f3660551e53c75415bed6';
      try {
        const weatherRes = await fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${coords[0]}&lon=${coords[1]}&appid=${OWM_API_KEY}&units=metric`);
        const weatherData = await weatherRes.json();
        if (weatherData && weatherData.main && weatherData.main.temp) {
          // Land Surface Temp is generally 2-4 degrees higher than ambient air temp
          result.meta.baselineLST = Math.round((weatherData.main.temp + 2.5) * 10) / 10;
          if (weatherData.weather && weatherData.weather[0]) {
            result.meta.climateNote = `Live Telemetry: ${weatherData.weather[0].description}, ${weatherData.main.humidity}% humidity.`;
          }
          console.log(`Live telemetry acquired: Ambient ${weatherData.main.temp}°C, Est. Baseline LST ${result.meta.baselineLST}°C`);
        }
      } catch (err) {
        console.warn('Live telemetry offline or API key inactive. Using static baseline.');
      }

      document.getElementById('scan').style.display = 'none';
      document.getElementById('workspace').style.display = 'flex';

      if (scanStatus) { scanStatus.classList.add('act'); scanStatus.textContent = 'Acquiring city boundary…'; }

      initMap(result.coords);
      currentCityBoundary = await fetchCityBoundary(result.meta.display, result.coords);

      // Instantly highlight the precise boundary and dim surroundings
      renderCityBoundaryLayers(result);

      if (scanStatus) { scanStatus.textContent = 'Tessellating 5 heat levels…'; }

      // Pause to admire the precise geographic limits
      await sleep(1800);

      await generateCityHeatZones(result, currentCityBoundary);

      if (scanStatus) scanStatus.classList.remove('act');

      // Reset buttons so only Heat Intensity is active initially
      activeLayers = { heat: true, dist: false, vuln: false, ndvi: false };
