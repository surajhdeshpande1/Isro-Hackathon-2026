<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>TAPAS-UHI · SURYA DRISHTI · Urban Heat Intelligence</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Manrope:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@turf/turf@6/turf.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    :root {
      --bg: #FAF9F6;
      --bg2: #F3F1EB;
      --bg3: #EBE8E0;
      --surf: #FFFFFF;
      --surf2: #FDFCFA;
      --bord: #E5E1D6;
      --bord2: #D8D3C8;
      --gold: #C89A0C;
      --gold2: #E8B820;
      --amber: #D97B20;
      --amber2: #F09030;
      --hot: #D95A18;
      --hot2: #F06830;
      --red: #C03010;
      --orange: #E07028;
      --bronze: #A06828;
      --teal: #1A9A88;
      --teal2: #22B8A0;
      --green: #2A8848;
      --blue: #2860A8;
      --purple: #6840A8;
      --txt: #1A1612;
      --txt2: #3A342E;
      --mut: #6B6359;
      --mut2: #9A9088;
      --mut3: #C0B8B0;
      --shadow: 0 2px 12px rgba(60, 40, 20, 0.08);
      --shadow2: 0 8px 32px rgba(60, 40, 20, 0.12);
      --shadow3: 0 24px 64px rgba(60, 40, 20, 0.18);
      --glass: rgba(255, 252, 248, 0.88);
      --glass2: rgba(255, 252, 248, 0.96);
      --r4: 4px;
      --r8: 8px;
      --r12: 12px;
      --r16: 16px;
      --r24: 24px;
      --mono: 'JetBrains Mono', monospace;
    }

    /* Removed dark mode to enforce the Light Theme inspired by nature */
    html,
    body {
      height: 100%;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--txt);
      overflow: hidden
    }

    button {
      font-family: inherit;
      cursor: pointer
    }

    input {
      font-family: inherit
    }

    /* ── LANDING ── */
    #landing {
      position: fixed;
      inset: 0;
      z-index: 9000;
      background: linear-gradient(150deg, #FAF8F2 0%, #F5F0E4 40%, #EDE5D0 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 20px;
    }

    .land-bg-sun {
      position: absolute;
      top: -25%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 900px;
      border-radius: 50%;
      pointer-events: none;
      background: radial-gradient(circle, rgba(232, 184, 32, 0.20) 0%, rgba(232, 160, 40, 0.10) 35%, rgba(232, 140, 40, 0.04) 65%, transparent 80%);
      animation: sunPulse 8s ease-in-out infinite;
    }

    @keyframes sunPulse {

      0%,
      100% {
        transform: translateX(-50%) scale(1);
        opacity: .7
      }

      50% {
        transform: translateX(-50%) scale(1.08);
        opacity: 1
      }
    }

    .land-particles {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden
    }

    .land-p {
      position: absolute;
      border-radius: 50%;
      background: var(--gold);
      opacity: 0;
      animation: particleFloat 12s infinite
    }

    @keyframes particleFloat {
      0% {
        opacity: 0;
        transform: translateY(100vh) scale(0)
      }

      20% {
        opacity: .3
      }

      80% {
        opacity: .15
      }

      100% {
        opacity: 0;
        transform: translateY(-20vh) scale(1.5)
      }
    }

    .land-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(200, 154, 12, .12);
      border: 1px solid rgba(200, 154, 12, .3);
      padding: 6px 18px;
      border-radius: 100px;
      font-family: 'Manrope', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 28px;
    }

    .land-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      animation: blink 2s infinite
    }

    @keyframes blink {

      0%,
      100% {
        opacity: 1
      }

      50% {
        opacity: .3
      }
    }

    .land-headline {
      font-family: 'Manrope', sans-serif;
      font-size: clamp(32px, 5vw, 66px);
      font-weight: 800;
      line-height: 1.08;
      text-align: center;
      color: var(--txt);
      letter-spacing: -2px;
      margin-bottom: 18px;
      max-width: 820px;
    }

    .land-headline span {
      background: linear-gradient(135deg, var(--gold), var(--amber));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text
    }

    .land-sub {
      font-size: 17px;
      color: var(--mut);
      text-align: center;
      max-width: 520px;
      line-height: 1.65;
      margin-bottom: 40px;
      font-weight: 400
    }

    .land-search-wrap {
      position: relative;
      width: min(600px, 90vw);
      margin-bottom: 18px
    }

    .land-search {
      width: 100%;
      padding: 18px 68px 18px 24px;
      border: 2px solid var(--bord2);
      border-radius: 100px;
      background: var(--surf);
      font-size: 17px;
      color: var(--txt);
      box-shadow: var(--shadow2);
      transition: all .3s;
      outline: none;
    }

    .land-search:focus {
      border-color: var(--gold);
      box-shadow: var(--shadow2), 0 0 0 4px rgba(200, 154, 12, .15)
    }

    .land-search::placeholder {
      color: var(--mut2)
    }

    .land-search-btn {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      background: linear-gradient(135deg, var(--gold), var(--amber));
      color: #fff;
      border: none;
      width: 46px;
      height: 46px;
      border-radius: 100px;
      font-size: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .2s;
      box-shadow: 0 4px 16px rgba(200, 154, 12, .4);
    }

    .land-search-btn:hover {
      transform: translateY(-50%) scale(1.08);
      box-shadow: 0 6px 24px rgba(200, 154, 12, .5)
    }

    .land-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin-bottom: 48px
    }

    .land-chip {
      padding: 8px 16px;
      border-radius: 100px;
      border: 1px solid var(--bord2);
      background: var(--surf);
      font-size: 13px;
      font-weight: 500;
      color: var(--txt2);
      cursor: pointer;
      transition: all .2s;
    }

    .land-chip:hover {
      background: var(--gold);
      color: #fff;
      border-color: var(--gold);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(200, 154, 12, .35)
    }

    .land-metrics {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      justify-content: center
    }

    .land-metric {
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r16);
      padding: 18px 26px;
      text-align: center;
      min-width: 130px;
      box-shadow: var(--shadow);
    }

    .land-metric-num {
      font-family: 'Manrope', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: var(--amber);
      line-height: 1
    }

    .land-metric-lbl {
      font-size: 11px;
      font-weight: 600;
      color: var(--mut);
      letter-spacing: .5px;
      margin-top: 5px
    }

    .land-isro {
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 10px;
      color: var(--mut2);
      letter-spacing: 1.5px;
      font-weight: 700;
      text-transform: uppercase;
      white-space: nowrap
    }

    /* ── SCAN ── */
    #scan {
      position: fixed;
      inset: 0;
      z-index: 8000;
      background: var(--bg);
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .scan-prog-wrap {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--bord)
    }

    .scan-prog-bar {
      height: 3px;
      width: 0;
      background: linear-gradient(90deg, var(--gold), var(--amber));
      transition: width .4s ease
    }

    .scan-badge {
      font-family: 'Manrope', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px
    }

    .scan-city {
      font-family: 'Manrope', sans-serif;
      font-size: clamp(28px, 5vw, 60px);
      font-weight: 800;
      color: var(--txt);
      letter-spacing: -2px;
      margin-bottom: 6px;
      text-align: center
    }

    .scan-state {
      font-size: 14px;
      color: var(--mut);
      font-weight: 500;
      margin-bottom: 44px;
      letter-spacing: 1px
    }

    .scan-ring-wrap {
      position: relative;
      width: 120px;
      height: 120px;
      margin-bottom: 44px
    }

    .scan-ring {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 2px solid var(--bord2);
      border-top-color: var(--gold);
      border-right-color: var(--amber);
      animation: spin 1.2s linear infinite
    }

    @keyframes spin {
      to {
        transform: rotate(360deg)
      }
    }

    .scan-ring-inner {
      position: absolute;
      top: 18px;
      left: 18px;
      right: 18px;
      bottom: 18px;
      border-radius: 50%;
      border: 1px solid var(--bord);
      border-top-color: var(--amber);
      animation: spin 2s linear infinite reverse
    }

    .scan-ring-center {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 11px;
      font-weight: 700;
      color: var(--mut);
      font-family: 'JetBrains Mono', monospace
    }

    .scan-steps {
      width: min(460px, 90vw);
      display: flex;
      flex-direction: column;
      gap: 5px;
      max-height: 400px;
      overflow-y: auto
    }

    .scan-step {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 9px 14px;
      border-radius: var(--r8);
      border: 1px solid var(--bord);
      background: var(--surf);
      opacity: .35;
      transition: all .4s
    }

    .scan-step.active {
      opacity: 1;
      border-color: var(--gold);
      background: rgba(200, 154, 12, .05)
    }

    .scan-step.done {
      opacity: .65;
      background: rgba(42, 136, 72, .05);
      border-color: rgba(42, 136, 72, .3)
    }

    .scan-step-icon {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--bord2);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--mut)
    }

    .scan-step.active .scan-step-icon {
      background: var(--gold);
      color: #fff;
      animation: pulse 1s infinite
    }

    .scan-step.done .scan-step-icon {
      background: var(--green);
      color: #fff
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(200, 154, 12, .4)
      }

      50% {
        box-shadow: 0 0 0 8px rgba(200, 154, 12, 0)
      }
    }

    .scan-step-text {
      font-size: 12px;
      font-weight: 600;
      color: var(--txt)
    }

    .scan-step-sub {
      font-size: 10px;
      color: var(--mut);
      margin-left: auto;
      font-family: 'JetBrains Mono', monospace;
      white-space: nowrap
    }

    /* ── WORKSPACE ── */
    #workspace {
      position: fixed;
      inset: 0;
      display: none;
      flex-direction: row;
      background: var(--bg2);
      z-index: 100;
    }

    #workspace-right {
      display: flex;
      flex-direction: column;
      flex: 1;
      height: 100%;
      overflow: hidden;
    }

    /* Topbar */
    #topbar {
      position: relative;
      z-index: 500;
      height: 52px;
      background: var(--glass2);
      border-bottom: 1px solid var(--bord);
      display: flex;
      align-items: center;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-shrink: 0;
    }

    .tb-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 18px;
      border-right: 1px solid var(--bord);
      height: 100%;
      cursor: pointer;
      flex-shrink: 0
    }

    .tb-logo-mark {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--gold), var(--amber));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      color: #fff;
      font-weight: 700;
      flex-shrink: 0
    }

    .tb-logo-text {
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 800;
      color: var(--txt);
      letter-spacing: -.3px;
      white-space: nowrap
    }

    .tb-logo-sub {
      font-size: 10px;
      color: var(--mut);
      font-weight: 500;
      letter-spacing: .5px
    }

    .tb-city-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 13px;
      margin-left: 14px;
      background: rgba(200, 154, 12, .1);
      border: 1px solid rgba(200, 154, 12, .25);
      border-radius: 100px;
      cursor: pointer;
      flex-shrink: 0
    }

    .tb-city-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
      animation: blink 2s infinite;
      flex-shrink: 0
    }

    .tb-city-name {
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--txt)
    }

    .tb-city-state {
      font-size: 11px;
      color: var(--mut);
      margin-left: 2px
    }

    .tb-spacer {
      flex: 1
    }

    .tb-score-pill {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 6px 13px;
      border: 1px solid var(--bord2);
      border-radius: 100px;
      background: var(--surf);
      flex-shrink: 0
    }

    .tb-score-label {
      font-size: 10px;
      color: var(--mut);
      font-weight: 700;
      letter-spacing: .5px;
      white-space: nowrap
    }

    .tb-score-val {
      font-family: 'Manrope', sans-serif;
      font-size: 16px;
      font-weight: 800
    }

    .tb-btns {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 0 10px;
      flex-shrink: 0
    }

    .tb-btn {
      padding: 6px 12px;
      border-radius: 100px;
      border: 1px solid var(--bord2);
      background: var(--surf);
      font-size: 12px;
      font-weight: 600;
      color: var(--txt2);
      cursor: pointer;
      transition: all .2s;
      display: flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap
    }

    .tb-btn:hover {
      background: var(--bg3)
    }

    .tb-btn-gold {
      background: linear-gradient(135deg, var(--gold), var(--amber));
      color: #fff;
      border-color: transparent;
      box-shadow: 0 2px 12px rgba(200, 154, 12, .4)
    }

    .tb-btn-gold:hover {
      box-shadow: 0 4px 20px rgba(200, 154, 12, .5);
      transform: translateY(-1px)
    }

    /* Layout */
    #main-layout {
      display: flex;
      flex: 1;
      overflow: hidden;
      position: relative;
    }

    /* Vertical Tab Nav */
    #tab-nav {
      width: 180px;
      flex-shrink: 0;
      background: var(--glass2);
      border-right: 1px solid var(--bord);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 16px 0;
      gap: 4px;
      overflow-y: auto;
      overflow-x: hidden;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      z-index: 400;
    }

    #tab-nav::-webkit-scrollbar {
      display: none
    }

    .tn-btn {
      width: calc(100% - 16px);
      margin: 2px 8px;
      padding: 10px 12px;
      height: auto;
      border-radius: var(--r8);
      border: none;
      background: transparent;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 12px;
      cursor: pointer;
      transition: all .2s;
      position: relative;
      color: var(--mut);
      flex-shrink: 0;
    }

    .tn-btn:hover {
      background: var(--bg3);
      color: var(--txt)
    }

    .tn-btn.active {
      background: rgba(40, 96, 168, 0.15) !important;
      color: var(--blue) !important;
    }

    .tn-btn.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 4px;
      height: 18px;
      background: var(--blue);
      border-radius: 0 4px 4px 0
    }

    .tn-icon {
      font-size: 16px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .tn-label {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .2px;
      text-transform: none;
      line-height: 1
    }

    .tn-div {
      width: calc(100% - 32px);
      height: 1px;
      background: var(--bord);
      margin: 6px 0;
      flex-shrink: 0
    }

    /* Map */
    #map-wrap {
      flex: 1;
      position: relative;
      overflow: hidden
    }

    #map {
      position: absolute;
      inset: 0;
      z-index: 1
    }

    .leaflet-container {
      background: #E8E4DC
    }

    .map-layer-bar {
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 100;
      display: flex;
      flex-direction: column;
      gap: 4px
    }

    .map-layer-btn {
      background: rgba(10, 16, 28, 0.72);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 7px 13px;
      border-radius: var(--r8);
      font-size: 11px;
      font-weight: 600;
      color: rgba(200, 218, 255, 0.75);
      cursor: pointer;
      transition: all .2s;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      box-shadow: 0 2px 8px rgba(0,0,0,0.35);
    }

    .map-layer-btn:hover {
      background: rgba(20, 30, 55, 0.85);
      color: #fff;
      border-color: rgba(255,255,255,0.2);
    }

    .map-layer-btn.on {
      background: rgba(64, 144, 255, 0.18);
      border-color: rgba(64, 144, 255, 0.45);
      color: #7bc8ff;
      box-shadow: 0 0 12px rgba(64, 144, 255, 0.2);
    }

    /* Unified Heat+Priority pill marker */
    .hp-pill {
      background: rgba(10, 16, 28, 0.80);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 3px 9px 3px 6px;
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 10px;
      font-weight: 600;
      color: #fff;
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 2px 8px rgba(0,0,0,0.5);
      white-space: nowrap;
      pointer-events: none;
      cursor: default;
    }
    .hp-pill-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .hp-pill-level {
      font-size: 8px;
      font-weight: 800;
      opacity: 0.65;
      letter-spacing: 0.3px;
    }
    .hp-pill-temp {
      font-family: var(--mono);
      font-size: 10px;
      font-weight: 700;
      color: #ffd060;
    }

    .map-style-panel {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 100;
      background: var(--glass2);
      border: 1px solid var(--bord);
      border-radius: var(--r12);
      padding: 10px 12px;
      backdrop-filter: blur(14px);
      width: min(240px, calc(100% - 24px));
      box-shadow: var(--shadow2);
    }

    .map-style-title {
      font-size: 9px;
      font-weight: 800;
      color: var(--mut);
      letter-spacing: 1.2px;
      text-transform: uppercase;
      margin-bottom: 8px
    }

    .map-style-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px
    }

    .map-style-btn {
      background: var(--surf);
      border: 1.5px solid var(--bord);
      border-radius: var(--r8);
      padding: 8px 6px;
      cursor: pointer;
      text-align: left;
      transition: all .2s;
    }

    .map-style-btn:hover {
      border-color: var(--gold2);
      background: var(--bg2)
    }

    .map-style-btn.on {
      border-color: var(--gold);
      background: rgba(200, 154, 12, .1);
      box-shadow: 0 0 0 1px rgba(200, 154, 12, .15)
    }

    .map-style-icon {
      font-size: 16px;
      line-height: 1;
      margin-bottom: 4px
    }

    .map-style-name {
      display: block;
      font-size: 11px;
      font-weight: 800;
      color: var(--txt);
      line-height: 1.2
    }

    .map-style-src {
      display: block;
      font-size: 8.5px;
      color: var(--mut2);
      margin-top: 2px;
      line-height: 1.2
    }

    .heat-legend {
      position: absolute;
      bottom: 12px;
      right: 12px;
      z-index: 100;
      background: var(--glass2);
      border: 1px solid var(--bord);
      border-radius: var(--r8);
      padding: 8px 10px;
      backdrop-filter: blur(12px);
      min-width: 130px;
    }

    .heat-legend-title {
      font-size: 8px;
      font-weight: 800;
      color: var(--mut);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 6px
    }

    .heat-legend-row {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 3px;
      font-size: 9px;
      font-weight: 600;
      color: var(--txt2)
    }

    .heat-legend-swatch {
      width: 14px;
      height: 10px;
      border-radius: 2px;
      flex-shrink: 0;
      border: 1px solid rgba(0, 0, 0, .08)
    }

    .scan-status {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 200;
      background: var(--glass2);
      border: 1px solid var(--gold);
      border-radius: var(--r12);
      padding: 14px 22px;
      font-size: 12px;
      font-weight: 700;
      color: var(--gold);
      backdrop-filter: blur(12px);
      display: none;
      pointer-events: none;
    }

    .scan-status.act {
      display: block
    }

    .map-ministat {
      position: absolute;
      bottom: 12px;
      left: 12px;
      z-index: 100;
      background: var(--glass2);
      border: 1px solid var(--bord);
      border-radius: var(--r8);
      padding: 8px 12px;
      backdrop-filter: blur(12px);
      min-width: 280px;
    }

    .map-ministat-row {
      display: flex;
      gap: 14px;
      justify-content: space-between
    }

    .mms-item {
      text-align: center
    }

    .mms-val {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      color: var(--amber);
      line-height: 1
    }

    .mms-lbl {
      font-size: 9px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .5px;
      margin-top: 2px;
      text-transform: uppercase
    }

    /* Panel */
    #panel-wrap {
      width: 440px;
      flex-shrink: 0;
      background: var(--surf2);
      border-left: 1px solid var(--bord);
      overflow-y: auto;
      overflow-x: hidden;
      display: flex;
      flex-direction: column
    }

    #panel-wrap::-webkit-scrollbar {
      width: 4px
    }

    #panel-wrap::-webkit-scrollbar-track {
      background: transparent
    }

    #panel-wrap::-webkit-scrollbar-thumb {
      background: var(--bord2);
      border-radius: 4px
    }

    .panel-section {
      display: none;
      flex-direction: column;
      min-height: 100%
    }

    .panel-section.active {
      display: flex
    }

    .panel-head {
      padding: 18px 18px 14px;
      border-bottom: 1px solid var(--bord);
      background: var(--surf);
      flex-shrink: 0;
      position: sticky;
      top: 0;
      z-index: 10
    }

    .panel-title {
      font-family: 'Manrope', sans-serif;
      font-size: 15px;
      font-weight: 800;
      color: var(--txt);
      letter-spacing: -.4px
    }

    .panel-sub {
      font-size: 11px;
      color: var(--mut);
      margin-top: 3px
    }

    .panel-body {
      padding: 14px;
      flex: 1
    }

    .panel-body::-webkit-scrollbar {
      width: 3px
    }

    .panel-body::-webkit-scrollbar-thumb {
      background: var(--bord2);
      border-radius: 3px
    }

    /* Cards */
    .card {
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r12);
      padding: 14px;
      margin-bottom: 10px;
      box-shadow: var(--shadow);
      transition: all .2s
    }

    .card:hover {
      box-shadow: var(--shadow2)
    }

    .card-title {
      font-size: 10px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .8px;
      text-transform: uppercase;
      margin-bottom: 10px
    }

    /* KPI */
    .kpi-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 7px;
      margin-bottom: 10px
    }

    .kpi {
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r8);
      padding: 11px;
      display: flex;
      flex-direction: column;
      gap: 2px
    }

    .kpi-label {
      font-size: 9px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .8px;
      text-transform: uppercase
    }

    .kpi-val {
      font-family: 'Manrope', sans-serif;
      font-size: 17px;
      font-weight: 800;
      color: var(--txt);
      line-height: 1
    }

    .kpi-sub {
      font-size: 10px;
      color: var(--mut2)
    }

    /* Score ring */
    .score-wrap {
      display: flex;
      align-items: center;
      gap: 18px;
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r16);
      padding: 18px;
      margin-bottom: 10px;
      box-shadow: var(--shadow)
    }

    .score-ring {
      position: relative;
      width: 84px;
      height: 84px;
      flex-shrink: 0
    }

    .score-ring svg {
      transform: rotate(-90deg)
    }

    .score-ring-val {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: 'Manrope', sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: var(--txt);
      line-height: 1;
      text-align: center
    }

    .score-ring-label {
      font-size: 9px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .5px;
      display: block;
      margin-top: 2px;
      text-align: center
    }

    .score-details {
      flex: 1
    }

    .score-name {
      font-family: 'Manrope', sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: var(--txt);
      line-height: 1.15
    }

    .score-grade {
      display: inline-block;
      padding: 3px 9px;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .5px;
      margin-top: 6px
    }

    .score-desc {
      font-size: 11px;
      color: var(--mut);
      margin-top: 7px;
      line-height: 1.55
    }

    /* Progress */
    .prog-item {
      margin-bottom: 9px
    }

    .prog-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 4px
    }

    .prog-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--txt2)
    }

    .prog-val {
      font-size: 11px;
      font-weight: 700;
      font-family: 'JetBrains Mono', monospace
    }

    .prog-bar {
      height: 5px;
      border-radius: 3px;
      background: var(--bg3);
      overflow: hidden
    }

    .prog-fill {
      height: 100%;
      border-radius: 3px;
      transition: width 1.2s cubic-bezier(.4, 0, .2, 1)
    }

    /* Severity */
    .sev {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .4px
    }

    .sev-ext {
      background: rgba(192, 48, 16, .12);
      color: var(--red)
    }

    .sev-high {
      background: rgba(217, 90, 24, .12);
      color: var(--hot)
    }

    .sev-mod {
      background: rgba(217, 123, 32, .12);
      color: var(--amber)
    }

    .sev-low {
      background: rgba(42, 136, 72, .12);
      color: var(--green)
    }

    /* Overview Hotspots List */
    .narrative {
      font-size: 12px;
      color: var(--txt2);
      line-height: 1.6;
      margin-bottom: 14px
    }

    .hot-list {
      display: flex;
      flex-direction: column;
      gap: 8px
    }

    .hot-card {
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r12);
      padding: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: all .2s;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .hot-card:hover {
      border-color: var(--tc);
      box-shadow: var(--shadow2);
      transform: translateY(-2px);
    }

    .hot-rank {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 800;
      color: var(--mut2);
      min-width: 24px;
      text-align: center;
    }

    .hot-icon {
      width: 32px;
      height: 32px;
      border-radius: var(--r8);
      background: var(--bg2);
      font-size: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border: 1px solid var(--bord);
    }

    .hot-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 3px;
      min-width: 0
    }

    .hot-name {
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 800;
      color: var(--txt);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .hot-typ {
      font-size: 10px;
      font-weight: 600;
      color: var(--mut);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .hot-bar-wrap {
      height: 4px;
      background: var(--bg3);
      border-radius: 2px;
      overflow: hidden;
      margin-top: 2px
    }

    .hot-bar {
      height: 100%;
      border-radius: 2px
    }

    .hot-metrics {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      min-width: 54px;
      text-align: center;
    }

    .overview-hint {
      font-size: 10px;
      color: var(--mut2);
      text-align: center;
      margin-top: 14px;
      padding: 10px 0 0;
      border-top: 1px solid var(--bord);
      font-style: italic;
    }

    /* Section header */
    .sec-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 14px 0 7px
    }

    .sec-title {
      font-size: 10px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .8px;
      text-transform: uppercase
    }

    /* Zone tabs */
    .zone-tabs {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      padding: 10px 14px;
      background: var(--bg);
      border-bottom: 1px solid var(--bord);
      flex-shrink: 0
    }

    .zone-tab {
      padding: 5px 10px;
      border-radius: 100px;
      border: 1px solid var(--bord2);
      background: var(--surf);
      font-size: 11px;
      font-weight: 600;
      color: var(--mut);
      cursor: pointer;
      transition: all .2s
    }

    .zone-tab:hover {
      background: var(--bg2);
      color: var(--txt2)
    }

    .zone-tab.active {
      background: var(--gold);
      color: #fff;
      border-color: var(--gold)
    }

    /* Scenario cards */
    .sc-card {
      border: 1px solid var(--bord);
      border-radius: var(--r12);
      padding: 14px;
      margin-bottom: 9px;
      cursor: pointer;
      transition: all .25s;
      background: var(--surf)
    }

    .sc-card:hover {
      border-color: var(--gold);
      box-shadow: 0 4px 20px rgba(200, 154, 12, .14);
      transform: translateY(-2px)
    }

    .sc-card.selected {
      border-color: var(--gold);
      background: rgba(200, 154, 12, .04);
      box-shadow: 0 0 0 2px rgba(200, 154, 12, .2)
    }

    .sc-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 8px
    }

    .sc-letter {
      width: 26px;
      height: 26px;
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 900;
      color: #fff;
      flex-shrink: 0
    }

    .sc-name {
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 800;
      color: var(--txt);
      margin-bottom: 6px
    }

    .sc-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5px
    }

    .sc-metric {
      background: var(--bg2);
      border-radius: var(--r4);
      padding: 7px 5px;
      text-align: center
    }

    .sc-metric-val {
      font-family: 'Manrope', sans-serif;
      font-size: 14px;
      font-weight: 800;
      color: var(--amber);
      line-height: 1
    }

    .sc-metric-lbl {
      font-size: 9px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .3px;
      margin-top: 2px;
      text-transform: uppercase
    }

    /* Verification */
    .phase-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px solid var(--bord)
    }

    .phase-item:last-child {
      border-bottom: none
    }

    .phase-num {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--bg2);
      border: 2px solid var(--bord2);
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      font-weight: 700;
      color: var(--mut);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px
    }

    .phase-num.pass {
      background: rgba(42, 136, 72, .1);
      border-color: var(--green);
      color: var(--green)
    }

    .phase-num.warn {
      background: rgba(217, 123, 32, .1);
      border-color: var(--amber);
      color: var(--amber)
    }

    .phase-content {
      flex: 1
    }

    .phase-name {
      font-size: 12px;
      font-weight: 700;
      color: var(--txt)
    }

    .phase-desc {
      font-size: 11px;
      color: var(--mut);
      margin-top: 2px;
      line-height: 1.5
    }

    .phase-score {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      font-weight: 700;
      color: var(--green);
      margin-left: auto;
      padding-left: 6px
    }

    /* Timeline */
    .timeline-item {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      position: relative
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: 19px;
      top: 38px;
      bottom: -16px;
      width: 1px;
      background: var(--bord)
    }

    .timeline-item:last-child::before {
      display: none
    }

    .timeline-dot {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      border: 2px solid
    }

    .timeline-content {
      flex: 1
    }

    .timeline-phase {
      font-size: 10px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .8px;
      text-transform: uppercase;
      margin-bottom: 2px
    }

    .timeline-title {
      font-family: 'Manrope', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--txt);
      margin-bottom: 4px
    }

    .timeline-desc {
      font-size: 12px;
      color: var(--mut);
      line-height: 1.5
    }

    .timeline-meta {
      display: flex;
      gap: 6px;
      margin-top: 6px;
      flex-wrap: wrap
    }

    .timeline-tag {
      padding: 3px 8px;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 600;
      background: var(--bg2);
      color: var(--mut)
    }

    /* Forecast table */
    .forecast-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px
    }

    .forecast-table th {
      text-align: left;
      padding: 7px 5px;
      border-bottom: 2px solid var(--bord);
      font-size: 10px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .5px;
      text-transform: uppercase
    }

    .forecast-table td {
      padding: 7px 5px;
      border-bottom: 1px solid var(--bord);
      color: var(--txt2)
    }

    .forecast-table tr:hover td {
      background: var(--bg2)
    }

    .forecast-yr {
      font-family: 'Manrope', sans-serif;
      font-weight: 700;
      color: var(--txt)
    }

    .forecast-good {
      color: var(--green);
      font-weight: 700
    }

    .forecast-bad {
      color: var(--red);
      font-weight: 700
    }

    /* Executive */
    .exec-rec {
      background: linear-gradient(135deg, rgba(200, 154, 12, .08), rgba(232, 135, 42, .05));
      border: 2px solid var(--gold);
      border-radius: var(--r16);
      padding: 18px;
      margin-bottom: 14px
    }

    .exec-rec-badge {
      font-size: 10px;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 7px
    }

    .exec-rec-name {
      font-family: 'Manrope', sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: var(--txt);
      line-height: 1.1;
      margin-bottom: 4px
    }

    .exec-rec-why {
      font-size: 12px;
      color: var(--mut);
      line-height: 1.55
    }

    .exec-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 7px;
      margin-bottom: 10px
    }

    .exec-cell {
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r8);
      padding: 11px;
      display: flex;
      flex-direction: column;
      gap: 2px
    }

    .exec-cell-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--mut);
      letter-spacing: .5px;
      text-transform: uppercase
    }

    .exec-cell-val {
      font-family: 'Manrope', sans-serif;
      font-size: 17px;
      font-weight: 800;
      color: var(--txt)
    }

    .exec-cell-sub {
      font-size: 10px;
      color: var(--mut2)
    }

    .exec-brief {
      background: var(--bg2);
      border-radius: var(--r8);
      padding: 14px;
      font-size: 12px;
      color: var(--txt2);
      line-height: 1.7;
      margin-bottom: 10px
    }

    /* Alerts */
    .alert-card {
      display: flex;
      gap: 10px;
      padding: 11px;
      background: var(--surf);
      border: 1px solid var(--bord);
      border-radius: var(--r8);
      margin-bottom: 7px;
      align-items: flex-start
    }

    .alert-icon {
      width: 30px;
      height: 30px;
      border-radius: var(--r8);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      flex-shrink: 0
    }

    .alert-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--txt)
    }

    .alert-desc {
      font-size: 11px;
      color: var(--mut);
      margin-top: 2px;
      line-height: 1.5
    }

    .alert-time {
      font-size: 10px;
      color: var(--mut2);
      font-family: 'JetBrains Mono', monospace;
      margin-top: 3px
    }

    /* Copilot */
    .copilot-flex {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0
    }

    .copilot-suggest {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 10px 14px;
      border-bottom: 1px solid var(--bord);
      flex-shrink: 0
    }

    .copilot-suggest-btn {
      padding: 5px 10px;
      border: 1px solid var(--bord2);
      border-radius: 100px;
      font-size: 11px;
      font-weight: 500;
      color: var(--txt2);
      background: var(--surf);
      cursor: pointer;
      transition: all .2s
    }

    .copilot-suggest-btn:hover {
      background: rgba(200, 154, 12, .08);
      border-color: var(--gold);
      color: var(--gold)
    }

    .copilot-chat {
      flex: 1;
      overflow-y: auto;
      padding: 14px;
      display: flex;
      flex-direction: column;
      gap: 9px;
      min-height: 240px;
      max-height: 360px
    }

    .chat-msg {
      max-width: 88%;
      padding: 10px 13px;
      border-radius: 12px;
      font-size: 13px;
      line-height: 1.6
    }

    .chat-msg.ai {
      background: var(--surf);
      border: 1px solid var(--bord);
      color: var(--txt);
      align-self: flex-start;
      border-radius: 4px 12px 12px 12px
    }

    .chat-msg.user {
      background: linear-gradient(135deg, var(--gold), var(--amber));
      color: #fff;
      align-self: flex-end;
