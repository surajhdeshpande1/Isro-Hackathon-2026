function renderMasterRoadmap(zones,meta){
  const rows=zones.map(function(z){
    const typ=TYPOLOGIES[z.typology];
    const sols=zoneSolutions(z);
    const phases=buildZoneRoadmap(z,sols);
    const cells=phases.map(function(p){
      const names=p.items.map(function(s){return s.name.split('(')[0].trim();}).join(', ');
      return `<div class="gantt-cell" style="--tc:${typ.color}">${names||(p.synth?'Saturation & verify':'—')}</div>`;
    }).join('');
    return `<div class="gantt-row">
      <div class="gantt-label" style="--tc:${typ.color}"><span>#${z.rank}</span> ${typ.icon} ${escapeHtml(z.name)}</div>
      <div class="gantt-cells">${cells}</div>
    </div>`;
  }).join('');

  const checklistItems=buildMasterChecklist(zones);
  const checklistHtml=checklistItems.map(function(it,i){
    return `<div class="chk"><input type="checkbox" id="mchk${i}" onchange="updateMasterProgress()"><label for="mchk${i}">${it}</label></div>`;
  }).join('');

  document.getElementById('panel-roadmap').innerHTML=`
    <div class="zd-h">Phased City-Wide Rollout — ${escapeHtml(meta.display)}</div>
    <div class="gantt-wrap">
      <div class="gantt-row gantt-header">
        <div class="gantt-label"></div>
        <div class="gantt-cells">
          <div class="gantt-cell head">Phase 1 · 0-6mo</div>
          <div class="gantt-cell head">Phase 2 · 6-18mo</div>
          <div class="gantt-cell head">Phase 3 · 18-36mo</div>
          <div class="gantt-cell head">Phase 4 · Yr 3-10</div>
        </div>
      </div>
      ${rows}
    </div>
    <div class="g2">
      <div class="card"><div class="zd-h">Recommended Governance</div><p>A Heat Action Task Force for ${escapeHtml(meta.display)}, chaired by the Municipal Corporation Commissioner's office, with the State Pollution Control Board, the regional ISRO/NRSC remote-sensing centre as data-and-verification partner, and a local engineering-college research cell as embedded analysis support. The Task Force meets monthly during Phases 1-2 and quarterly thereafter, reviewing satellite-verified ΔT against the modelled targets for every zone.</p></div>
      <div class="card"><div class="zd-h">Funding Mechanisms</div><p>Layer funding across four sources: convergence with AMRUT 2.0 and Smart Cities Mission allocations for Phase 3 infrastructure; CSR contributions from zone-adjacent industry, highest-leverage in the Industrial and Transit zones; the Albedo Banking Incentive System as a self-funding, revenue-neutral mechanism for Phase 1-2 cool-surface adoption; and Satellite-Verified Outcome Bonds, a municipal bond whose coupon is indexed to independently re-measured ΔT, so investor capital is repaid against verified results rather than promised ones.</p></div>
    </div>
    <div class="card card-s">
      <div class="zd-h">Master Implementation Checklist</div>
      <div class="prog-row"><div class="prog-track"><div class="prog-fill" id="mProgFill"></div></div><span id="mProgTxt">0 / ${checklistItems.length} actions confirmed</span></div>
      ${checklistHtml}
    </div>`;
}
function updateMasterProgress(){
  const boxes=document.querySelectorAll('#panel-roadmap .chk input[type=checkbox]');
  const done=Array.prototype.filter.call(boxes,function(b){return b.checked;}).length;
  const fill=document.getElementById('mProgFill');
  const txt=document.getElementById('mProgTxt');
  if(fill) fill.style.width=(done/boxes.length*100)+'%';
  if(txt) txt.textContent=done+' / '+boxes.length+' actions confirmed';
}
function renderForecast(zones,meta){
  const fc=computeForecastSeries(zones,meta);
  const series=fc.series,breakevenYear=fc.breakevenYear;
  const chart1=svgLineChart([
    {label:'Business as usual',color:'var(--mut2)',points:series.map(function(p){return {x:p.y,y:p.bauLST};}),fill:false},
    {label:'With SURYA DRISHTI interventions',color:'var(--red)',points:series.map(function(p){return {x:p.y,y:p.withLST};}),fill:true}
  ],{xFmt:function(v){return 'Y'+v;},yFmt:function(v){return v.toFixed(0)+'°';}});

  const chart2=svgLineChart([
    {label:'Cumulative investment',color:'var(--amber)',points:series.map(function(p){return {x:p.y,y:p.cost};}),fill:false},
    {label:'Cumulative benefit',color:'var(--teal)',points:series.map(function(p){return {x:p.y,y:p.cumBenefit};}),fill:false}
  ],{xFmt:function(v){return 'Y'+v;},yFmt:function(v){return '₹'+Math.round(v);}});

  function findY(y){ return series.filter(function(p){return p.y===y;})[0]; }
  const m1=findY(1),m5=findY(5),m10=findY(10),m20=findY(20),m0=series[0];
  const milestoneRows=[m1,m5,m10,m20].map(function(p){
    const net=p.cumBenefit-p.cost;
    return `<tr><td>Year ${p.y}</td><td>${round1(p.withLST-m0.withLST)}°C vs today</td><td>₹${round1(p.cost)} Cr</td><td>₹${round1(p.cumBenefit)} Cr</td><td style="color:${net>=0?'var(--teal)':'var(--red)'}">${net>=0?'+':''}₹${round1(net)} Cr</td></tr>`;
  }).join('');

  document.getElementById('panel-forecast').innerHTML=`
    <div class="zd-h">20-Year ΔT Trajectory — ${escapeHtml(meta.display)}</div>
    <div class="chart-card">
      ${chart1}
      <div class="legend"><span><i style="background:var(--mut2)"></i>Business as usual</span><span><i style="background:var(--red)"></i>With interventions</span></div>
    </div>
    <div class="zd-h">Cumulative Investment vs. Monetised Benefit</div>
    <div class="chart-card">
      ${chart2}
      <div class="legend"><span><i style="background:var(--amber)"></i>Cumulative cost</span><span><i style="background:var(--teal)"></i>Cumulative benefit</span></div>
    </div>
    <p class="forecast-note">${breakevenYear!=null?`Modelled breakeven: <b>Year ${breakevenYear}</b> — cumulative monetised benefit overtakes cumulative investment around this point.`:`Within this 20-year model, cumulative investment does not fully recover under the conservative monetisation assumptions used here — typical for capital-heavy zones such as lake restoration or district cooling, whose payback is partly non-monetary (health, equity, resilience).`}</p>
    <table class="t milestone-t"><thead><tr><th>Milestone</th><th>ΔT vs Today</th><th>Cumulative Cost</th><th>Cumulative Benefit</th><th>Net Position</th></tr></thead><tbody>${milestoneRows}</tbody></table>
    <p class="disclaim-sm">Illustrative model: cooling adoption follows complexity-based logistic curves; monetisation assumes roughly ₹180 per person per °C of cooling per year, combining avoided cooling-energy cost, heat-productivity-loss avoidance and a conservative property-value fraction. Treat every figure here as directional, not audited.</p>`;
}
