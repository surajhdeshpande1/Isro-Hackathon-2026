{name:'Blue Acupuncture: Tank Cascade Revival (BATCR)',
 mech:`Many Indian cities' tanks and lakes were historically linked by channels into a thermodynamic cascade, with water, and coolness, flowing from upper tanks down to lower ones. Restoring the cascade as a network, rather than fixing isolated lakes one at a time, turns the whole chain into a city-scale evaporative cooling system. Historical survey maps plus a current elevation model identify the cheapest sequence of restorations for the largest cooling return.`,
 dTLabel:'-3.8°C (400m lake radius); -1.2°C (1.5km cascade corridor)',ambientDT:-1.2,cost:'₹8-25 Cr per lake restored (typically NPV-positive within ~12 years via property-tax uplift)',costCr:12.0,complexity:'High',stars:5,
 cobenefit:'Groundwater recharge, flood attenuation, biodiversity gain, occasionally Ramsar-site potential',
 source:'Historical tank-cascade hydrology and urban-lake restoration research',
 isro:'Cartosat-2 elevation data plus historical survey maps reconstruct the cascade network; INSAT-3D validates the lake thermal-signature recovery as restoration proceeds',
 pilotFn:function(z){return `wherever ${z}'s restoration is already furthest along — start the cascade there and work outward`;}},
{name:'Aquifer Thermal Energy Storage (ATES)',
 mech:`Two borewell clusters work as an underground thermal battery: in summer, constant ~18°C aquifer water is pumped up to building cooling systems; in monsoon, warmed surface water is injected back down to recharge the thermal gradient for next year. The result runs at a coefficient of performance roughly five times that of a conventional chiller.`,
 dTLabel:'Indoor: -10°C; Zone outdoor (reduced AC exhaust): -0.7°C ambient',ambientDT:-0.7,cost:'₹35-60L per building cluster (typically breaks even in ~6 years on AC savings alone)',costCr:4.0,complexity:'High',stars:5,
 cobenefit:'Built-in groundwater monitoring, a productive use for monsoon recharge, roughly 60% energy-cost savings',
 source:'Aquifer thermal energy storage engineering research',
 isro:'EOS-04 SAR interferometry detects ground deformation from extraction, used to monitor the system safely over time',
 pilotFn:function(z){return `${z} — wherever the local groundwater board already has good aquifer characterisation data`;}},
{name:'Thermocline Stratification Enhancement (TSE)',
 mech:`Restored lakes naturally settle into layers, cold water at depth and warm at the surface, but most restoration projects let wind mix this away. TSE actively protects the layering with windbreaks, floating macrophytes that shade the surface, and carefully positioned solar aerators that add oxygen without breaking the stratification. The protected cold bottom layer can then be pumped out specifically for riparian irrigation, maximising the radius of cooling it delivers.`,
 dTLabel:'-1.8°C additional, vs. an unstratified restored lake',ambientDT:-1.8,cost:'₹8-12L per hectare, additional lake-management cost',costCr:0.8,complexity:'Medium',stars:5,
 cobenefit:'Cold deep water naturally suppresses surface algal blooms, improves fish habitat and water clarity',
 source:'Lake thermal-stratification limnology research, applied here to an urban restoration context',
 isro:'INSAT-3D thermal-IR distinguishes a stratified lake cooler surface signature from an unstratified one even at coarse resolution',
 pilotFn:function(z){return `${z} — fold stratification design into whatever restoration plan is already underway`;}},
{name:'Monsoon Cistern Cooling Network (MCCN)',
 mech:`Rooftop rainwater is collected into large underground ferro-cement cisterns, one per city block. Each cistern feeds a neighbourhood misting network and cools pavement through irrigation, entirely gravity-fed with no pump and no electricity. A single large cistern alone provides 3-4 weeks of full misting capacity for a 200m street segment, and the cistern's own thermal mass helps stabilise the block's micro-climate too.`,
 dTLabel:'-3.1°C (misted corridor); -0.8°C (block ambient)',ambientDT:-0.8,cost:'₹4-8L per cistern plus ₹2L for the distribution network',costCr:0.6,complexity:'Medium',stars:4,
 cobenefit:'Flood-risk reduction, groundwater recharge, year-round water security for the block',
 source:'Rainwater-harvesting and urban-cooling integration research',
 isro:'Sentinel-2 NDWI plus Cartosat-2 elevation data identify the best cistern catchment zones across the periphery',
 pilotFn:function(z){return `${z}'s highest-impervious, flattest sub-block — biggest catchment, easiest gravity flow`;}},
{name:'Lake-Fed Cold Water Street Irrigation Loop (LCWSIL)',
 mech:`Once a lake is restored and stratified, its cold hypolimnion water is gravity- or low-energy-pumped through a small engineered channel network to irrigate and lightly mist streets within roughly 500m of the shoreline, extending the lake's own cooling radius outward into the surrounding blocks instead of letting it stop at the water's edge.`,
 dTLabel:'-1.6°C (street segments inside the loop)',ambientDT:-1.6,cost:'₹10-16L per km of loop (gravity-fed, very low running energy)',costCr:1.0,complexity:'Medium',stars:4,
 cobenefit:'Stacks directly on top of the cascade and stratification work rather than competing for budget with them; extends their benefit further into the neighbourhood',
 source:'Extension of district-cooling and aquifer-thermal-storage principles to surface lake water. Using restored-lake hypolimnion water this way is an original proposal, pending a hydraulic feasibility study.',
 isro:'INSAT-3D thermal-IR combined with Sentinel-2 NDWI jointly confirms cold-water availability in the hypolimnion before each irrigation cycle',
 pilotFn:function(z){return `the 500m ring immediately around ${z}, once stratification is confirmed`;}}
],
PSHI:[
{name:'Biotic Pump Urban Forest Patches (BPUFP)',
 mech:`Dense forest patches create a persistent local low-pressure zone through sheer evapotranspiration volume, physically drawing in moist air from outside the patch, the same mechanism large forests use to pull in rain from the coast. At urban scale, strategic 2-5 hectare patches placed in the sprawl zone create self-sustaining moisture recycling, modelled to lift local precipitation frequency by 12-18% within roughly 5km of each patch.`,
 dTLabel:'-2.6°C (patch vicinity); -0.8°C (5km radius)',ambientDT:-0.8,cost:'₹25-40L per hectare to establish (native species, intensive early-years care)',costCr:1.0,complexity:'Medium',stars:5,
 cobenefit:'Carbon sequestration, a biodiversity hotspot, watershed recharge, genuine recreational and educational value',
 source:'Biotic-pump atmospheric-moisture-transport theory, applied here as an original urban-scale extension',
 isro:'Resourcesat-2 LISS-IV NDVI tracks canopy development; ERA5 precipitation data helps validate the biotic-pump effect over time',
 pilotFn:function(z){return `any abandoned quarry or fallow land already inside ${z}`;}},
{name:'Vernacular Thermal Architecture Revival (VTAR)',
 mech:`Pre-modern houses in this climate typically used central courtyards for stack-effect cooling, thick load-bearing walls for a 6-8 hour thermal-mass delay, deep overhanging eaves for solar exclusion, and wind-catching openings. VTAR quantifies exactly how much each feature is worth using building-physics simulation, then writes the numbers straight into a buildable code applied to every new approval in the sprawl zone.`,
 dTLabel:'Indoor: -6°C vs. standard construction; -0.4°C ambient',ambientDT:-0.4,cost:'₹0 additional — it is a code requirement, and thermal mass is cheaper than 20 years of AC anyway',costCr:0.05,complexity:'Low',stars:4,
 cobenefit:'60-70% AC energy savings, better occupant comfort, and a direct cultural-heritage payoff',
 source:'Vernacular passive-cooling building-physics research',
 isro:'Cartosat-2 building-shadow mapping validates eave-projection compliance across the zone at scale',
 pilotFn:function(z){return `every new development-authority layout approved in ${z} from this year onward`;}},
{name:'CFD-Optimised Wind Corridor Ordinance (CWCO)',
 mech:`Using a neural-network surrogate trained on full computational-fluid-dynamics simulations, so it runs instantly instead of needing hours of compute per check, the system tests every proposed building layout's orientation and street alignment against the locally prevailing wind direction before a permit is issued, and requires a 15m wind corridor at least every 200m, aligned with that prevailing wind.`,
 dTLabel:'-2.4°C (corridor zones); -0.9°C (block average)',ambientDT:-0.9,cost:'₹0 — a computational compliance check, negligible developer cost at design stage',costCr:0.05,complexity:'Low',stars:5,
 cobenefit:'Less indoor AC need, better air quality, and incidental cyclone resilience from the same corridor geometry',
 source:'Wind-corridor urban-planning precedent, notably Singapore, applied here through an automated CFD-surrogate compliance check',
 isro:'EOS-04 SAR detects as-built layout patterns so the CFD surrogate can validate real compliance, not just the approved drawing',
 pilotFn:function(z){return `${z}'s next development-authority sector that's still in the planning stage`;}},
{name:'Albedo Banking Incentive System (ABIS)',
 mech:`A simple market mechanism: any property that installs a high-albedo roof earns tradeable albedo credits proportional to area times the albedo gain achieved. Industrial owners with dark roofs can buy credits from residential cool-roof adopters instead of retrofitting immediately themselves; credits convert to a property-tax rebate. Every credit is verified against the same satellite albedo product the rest of the system already uses.`,
 dTLabel:'-2.1°C (zone average, from market-driven adoption)',ambientDT:-2.1,cost:'₹0 public capital cost; roughly ₹2L/year to administer; revenue-neutral against tax receipts',costCr:0.05,complexity:'Medium',stars:5,
 cobenefit:'Market-efficient voluntary adoption, plus a built-in data-collection mechanism for satellite validation',
 source:'Original policy design, analogous in structure to existing carbon-credit markets',
 isro:'MODIS daily albedo product is the verification oracle for the entire credit system — no separate audit needed',
 pilotFn:function(z){return `${z}'s commercial corridor — companies with ESG targets are natural early credit buyers`;}},
{name:'Agrivoltaic Greenbelt Containment Rings (AGCR)',
 mech:`A ring of solar panels elevated over shade-tolerant crops is placed as a deliberate buffer between the sprawl edge and adjacent farmland. It generates revenue for the farmer so there is an economic reason not to sell the land to a developer, keeps the land productively green rather than fallow-and-paved, and physically caps how far the built-up footprint can expand in that direction.`,
 dTLabel:'-1.1°C (immediate ring), plus a larger, harder-to-quantify long-run value from sprawl actually being contained',ambientDT:-0.7,cost:'₹15-22L per hectare for combined solar-plus-cropping setup (partially self-funding through power-purchase revenue)',costCr:1.6,complexity:'Medium',stars:5,
 cobenefit:'Direct farmer income, clean power generation, and a genuine structural brake on further sprawl-driven heat-island formation',
 source:'Builds on established agrivoltaic research. Using it specifically as an anti-sprawl economic containment ring is an original policy proposal here.',
 isro:'Resourcesat-2 LISS-IV land-cover change-detection flags any encroachment into the ring early enough to act on',
 pilotFn:function(z){return `the most threatened farmland edge directly adjoining ${z}`;}}
]
};

