const GENERIC_TEMPLATES={
  IHI:['{C} Industrial Estate / Outer Industrial Belt','{C} GIDC-MIDC-KIADB-Type Industrial Area'],
  SCHI:['{C} Old City / Main Bazaar Canyon','{C} Central Market Street Canyon'],
  DRHI:['{C} Dense Residential Core','{C} Inner-City Residential Wards'],
  TCHI:['{C} Railway Station & Bus Stand Corridor','{C} Central Transit Hub Belt'],
  LDHI:['{C} Local Tank/River Degraded Fringe','{C} Seasonal Water-Body Periphery'],
  PSHI:['{C} Outer Ring Road Peripheral Corridor','{C} Highway-Adjacent Peripheral Sprawl']
};
function genericZoneName(t,city,rng){
  const arr=GENERIC_TEMPLATES[t];
  const tpl=arr[Math.floor(rng()*arr.length)%arr.length];
  return tpl.replace('{C}',city);
}
function buildGenericMeta(displayRaw){
  const rng=rngFor(displayRaw.toLowerCase());
  const disp=titleCase(displayRaw);
  const zones=TYPO_ORDER.map(function(t){return Z(t,genericZoneName(t,disp,rng));});
  return {display:disp,state:null,tier:2,baselineLST:32.5+rng()*3.5,
    climateNote:'Composite Indian urban-heat baseline — city-specific climate calibration is not yet curated for this city.',
    confidence:'projected',zones:zones};
}

const BASE_DENSITY={IHI:3200,SCHI:24000,DRHI:17500,TCHI:11000,LDHI:8500,PSHI:4200};
function popDensityFor(typology,tier){
  const base=BASE_DENSITY[typology];
  const tierMul=tier===1?1.3:(tier===2?1.0:0.8);
  return base*tierMul;
