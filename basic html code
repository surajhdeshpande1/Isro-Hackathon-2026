}

/* ---- forecast math ---- */
function adoptionFrac(year,complexity){
  const params={Low:[1.1,0.95],Medium:[3.0,0.55],High:[6.5,0.32]}[complexity]||[3,0.5];
  const x0=params[0],k=params[1];
  return 1/(1+Math.exp(-k*(year-x0)));
}
function zoneDTatYear(zone,year){
  const sols=SOLUTIONS[zone.typology];
  const top=sols.slice().sort(function(a,b){return Math.abs(b.ambientDT)-Math.abs(a.ambientDT);}).slice(0,3);
  let total=0;
  top.forEach(function(s){ total+=s.ambientDT*adoptionFrac(year,complexityKey(s.complexity))*0.6; });
  return total;
}
function computeForecastSeries(zones,meta){
  const years=[0,1,2,3,4,5,7,10,15,20];
  const totalPop=zones.reduce(function(s,z){return s+z.pop;},0)||1;
  const avgCurrentLST=zones.reduce(function(s,z){return s+z.lstPeak*z.pop;},0)/totalPop;
  const bauDrift=0.07;
  const series=years.map(function(y){
    let weightedDT=0,cost=0;
    zones.forEach(function(z){
      const dt=zoneDTatYear(z,y);
      weightedDT+=dt*(z.pop/totalPop);
      SOLUTIONS[z.typology].forEach(function(s){
        const c=complexityKey(s.complexity);
        const frac=adoptionFrac(y,c);
        cost+=s.costCr*(z.areaKm2/2.5)*frac;
      });
    });
    const bauLST=avgCurrentLST+bauDrift*y;
    const withLST=bauLST+weightedDT;
    const annualBenefit=Math.abs(weightedDT)*totalPop*0.000180;
    return {y:y,bauLST:bauLST,withLST:withLST,dT:weightedDT,cost:cost,annualBenefit:annualBenefit};
  });
  let cumBenefit=0,prevY=0,prevAB=0;
  series.forEach(function(pt,i){
    if(i>0){ cumBenefit += (pt.annualBenefit+prevAB)/2*(pt.y-prevY); }
    prevY=pt.y; prevAB=pt.annualBenefit;
    pt.cumBenefit=cumBenefit;
  });
  let breakevenYear=null;
  for(let i=0;i<series.length;i++){ if(series[i].cumBenefit>=series[i].cost){breakevenYear=series[i].y;break;} }
  return {series:series,breakevenYear:breakevenYear};
}

/* ================= CHART BUILDER ================= */
function svgLineChart(seriesArr,opts){
  opts=opts||{};
  const W=opts.width||640,H=opts.height||260;
  const padL=58,padR=16,padT=18,padB=30;
  const xs=seriesArr[0].points.map(function(p){return p.x;});
  let allY=[];
  seriesArr.forEach(function(s){ s.points.forEach(function(p){ allY.push(p.y); }); });
  let minY=Math.min.apply(null,allY),maxY=Math.max.apply(null,allY);
  if(minY===maxY){minY-=1;maxY+=1;}
  const padY=(maxY-minY)*0.10; minY-=padY; maxY+=padY;
  const minX=Math.min.apply(null,xs),maxX=Math.max.apply(null,xs);
  function xScale(x){ return padL+(x-minX)/((maxX-minX)||1)*(W-padL-padR); }
  function yScale(y){ return H-padB-(y-minY)/((maxY-minY)||1)*(H-padT-padB); }
  let svg=`<svg viewBox="0 0 ${W} ${H}" class="chart-svg" xmlns="http://www.w3.org/2000/svg">`;
  const yTicks=5;
  for(let i=0;i<=yTicks;i++){
    const val=minY+(maxY-minY)*i/yTicks;
    const yy=yScale(val);
    svg+=`<line x1="${padL}" y1="${yy}" x2="${W-padR}" y2="${yy}" stroke="rgba(255,194,61,0.09)" stroke-width="1"/>`;
    svg+=`<text x="${padL-8}" y="${yy+4}" text-anchor="end" font-size="10" fill="var(--mut2)" font-family="var(--mono)">${opts.yFmt?opts.yFmt(val):val.toFixed(1)}</text>`;
  }
  xs.forEach(function(x){
    const xx=xScale(x);
    svg+=`<text x="${xx}" y="${H-padB+18}" text-anchor="middle" font-size="10" fill="var(--mut2)" font-family="var(--mono)">${opts.xFmt?opts.xFmt(x):x}</text>`;
  });
  seriesArr.forEach(function(s){
    const pts=s.points.map(function(p){ return xScale(p.x)+','+yScale(p.y); }).join(' ');
    if(s.fill){
      const first=s.points[0],last=s.points[s.points.length-1];
      const areaPts=xScale(first.x)+','+yScale(minY)+' '+pts+' '+xScale(last.x)+','+yScale(minY);
      svg+=`<polygon points="${areaPts}" fill="${s.color}" opacity="0.13"/>`;
    }
    svg+=`<polyline points="${pts}" fill="none" stroke="${s.color}" stroke-width="2.6" stroke-linejoin="round" stroke-linecap="round"/>`;
    s.points.forEach(function(p){
      svg+=`<circle cx="${xScale(p.x)}" cy="${yScale(p.y)}" r="3" fill="${s.color}"/>`;
    });
  });
  svg+='</svg>';
  return svg;
}
function radialGauge(value,max,color,size){
  const startA=-225,totalSweep=270;
  const r=(size/2)-7,cx=size/2,cy=size/2;
  const frac=clamp(value/max,0,1);
  const endA=startA+totalSweep*frac;
  function toXY(a){ const r2=a*Math.PI/180; return [cx+r*Math.cos(r2),cy+r*Math.sin(r2)]; }
  const p1=toXY(startA),p2=toXY(endA),p3=toXY(startA+totalSweep);
  const bigFill=(totalSweep*frac>180)?1:0;
  let s=`<svg viewBox="0 0 ${size} ${size}" width="${size}" height="${size}" class="gauge-svg">`;
  s+=`<path d="M ${p1[0]} ${p1[1]} A ${r} ${r} 0 1 1 ${p3[0]} ${p3[1]}" fill="none" stroke="rgba(255,255,255,.10)" stroke-width="7" stroke-linecap="round"/>`;
  if(frac>0){ s+=`<path d="M ${p1[0]} ${p1[1]} A ${r} ${r} 0 ${bigFill} 1 ${p2[0]} ${p2[1]}" fill="none" stroke="${color}" stroke-width="7" stroke-linecap="round"/>`; }
  s+=`<text x="${cx}" y="${cy+1}" text-anchor="middle" dominant-baseline="central" class="gauge-num" style="fill:${color}">${value}</text>`;
  s+='</svg>';
  return s;
}

