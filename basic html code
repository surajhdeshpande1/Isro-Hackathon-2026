<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>SURYA DRISHTI · TAPAS-UHI — Pan-India Urban Heat Engine</title>
<style>
:root{
  --bg:#0A0703;--bg2:#140B05;--card:#1B0F08;--card2:#241408;--bord:#3D2515;--bord2:#54311C;
  --txt:#F3E6D2;--mut:#CBA47D;--mut2:#8C7256;
  --gold:#FFC23D;--amber:#F2C879;--bronze:#D9A04B;--orange:#FF7A1F;--red:#FF4B2E;--teal:#2FD0C7;
  --mono:ui-monospace,"SF Mono","Cascadia Code","Roboto Mono",Consolas,monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--txt);font-family:system-ui,-apple-system,"Segoe UI",sans-serif;font-size:14.5px;line-height:1.65;min-height:100vh;position:relative;overflow-x:hidden;}
body::before{content:'';position:fixed;top:-25%;left:50%;transform:translateX(-50%);width:140vw;height:140vw;max-width:1500px;max-height:1500px;background:radial-gradient(circle,rgba(255,122,31,.10) 0%,rgba(255,75,46,.045) 38%,transparent 66%);pointer-events:none;z-index:0;}
a{color:var(--gold);text-decoration:none;}
.mono{font-family:var(--mono);}
.hidden{display:none!important;}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);}
::selection{background:var(--red);color:#fff;}

/* ---------- topbar ---------- */
.topbar{position:sticky;top:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:14px 22px;border-bottom:1px solid var(--bord);background:rgba(10,7,3,.92);backdrop-filter:blur(10px);}
.brand{display:flex;align-items:center;gap:9px;font-size:13.5px;letter-spacing:.3px;}
.brand-mark{font-size:17px;filter:drop-shadow(0 0 6px rgba(255,194,61,.7));}
.brand b{font-weight:800;}
.topbar-actions{display:flex;gap:8px;}
.btn{font-family:inherit;font-size:12.5px;font-weight:600;border-radius:8px;padding:8px 14px;cursor:pointer;border:1px solid var(--bord2);background:var(--card);color:var(--txt);transition:border-color .15s,transform .1s;}
.btn:hover{border-color:var(--gold);}
.btn:active{transform:scale(.97);}
.btn.primary{background:linear-gradient(135deg,var(--gold),var(--orange));color:#1A0D04;border:none;font-weight:800;letter-spacing:.2px;}
.btn.ghost{background:transparent;}

/* ---------- hero ---------- */
.hero{max-width:760px;margin:0 auto;padding:54px 24px 70px;text-align:center;position:relative;z-index:1;}
.dial-wrap{position:relative;width:204px;height:204px;margin:0 auto 18px;}
.dial-rays{position:absolute;inset:0;border-radius:50%;background:repeating-conic-gradient(from 0deg,rgba(255,194,61,.30) 0deg 3deg,transparent 3deg 15deg);animation:spin 22s linear infinite;filter:blur(.5px);}
.dial-ring{position:absolute;inset:14px;border-radius:50%;border:1px dashed rgba(255,194,61,.35);}
.dial-ring::before,.dial-ring::after{content:'';position:absolute;width:6px;height:6px;border-radius:50%;background:var(--teal);box-shadow:0 0 8px var(--teal);}
.dial-ring::before{top:-3px;left:50%;margin-left:-3px;}
.dial-ring::after{top:50%;right:-3px;margin-top:-3px;background:var(--gold);box-shadow:0 0 8px var(--gold);}
.dial-orbit{position:absolute;inset:14px;border-radius:50%;animation:spin 14s linear infinite reverse;}
.dial-core{position:absolute;inset:46px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#FFF6DE 0%,var(--gold) 32%,var(--orange) 62%,var(--red) 100%);box-shadow:0 0 56px 16px rgba(255,122,31,.5),0 0 110px 36px rgba(255,75,46,.22);animation:pulse 4.2s ease-in-out infinite;}
.dial-ticks{position:absolute;inset:0;}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.05);}}
.hero-tag{font-family:var(--mono);font-size:12px;letter-spacing:2px;color:var(--mut);margin-bottom:6px;}
.hero-title{font-size:clamp(34px,7vw,54px);font-weight:900;letter-spacing:1px;line-height:1;background:linear-gradient(120deg,var(--gold) 10%,var(--orange) 55%,var(--red) 95%);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:6px;}
.hero-sub{font-size:14.5px;color:var(--mut);font-weight:600;letter-spacing:.3px;margin-bottom:18px;}
.hero-copy{font-size:14.5px;color:var(--txt);max-width:560px;margin:0 auto 28px;opacity:.92;}
.scan-form{display:flex;gap:10px;max-width:520px;margin:0 auto 16px;flex-wrap:wrap;}
.scan-form input{flex:1;min-width:200px;background:var(--card);border:1px solid var(--bord2);border-radius:10px;padding:13px 16px;color:var(--txt);font-size:14.5px;font-family:inherit;}
.scan-form input:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(255,194,61,.15);}
.scan-form input.shake{animation:shake .4s;border-color:var(--red);}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}
.scan-form button{white-space:nowrap;}
.chip-row{display:flex;gap:7px;justify-content:center;flex-wrap:wrap;margin-bottom:24px;}
.chip-label{font-size:12px;color:var(--mut2);align-self:center;margin-right:2px;}
.chip{font-family:inherit;font-size:12px;font-weight:600;background:var(--card);border:1px solid var(--bord);color:var(--mut);border-radius:99px;padding:6px 13px;cursor:pointer;transition:border-color .15s,color .15s;}
.chip:hover{border-color:var(--teal);color:var(--txt);}
.badges-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
.badge{font-size:11px;font-weight:600;color:var(--mut);background:var(--card);border:1px solid var(--bord);border-radius:7px;padding:5px 10px;font-family:var(--mono);}

/* ---------- scan overlay ---------- */
.scan-overlay{position:fixed;inset:0;z-index:500;background:radial-gradient(circle at 50% 38%,#180D05 0%,#0A0703 70%);display:none;flex-direction:column;align-items:center;justify-content:center;padding:24px;}
.scan-overlay.act{display:flex;}
.scan-sun{position:relative;width:150px;height:150px;margin-bottom:24px;}
.scan-sun .dial-rays{animation-duration:5s;}
.scan-sun .dial-core{inset:30px;animation-duration:1.4s;}
.scan-beam{position:absolute;left:-30px;right:-30px;top:0;height:3px;background:linear-gradient(90deg,transparent,var(--teal),transparent);animation:beam 1.6s linear infinite;}
@keyframes beam{0%{top:-10%;opacity:0;}10%{opacity:1;}90%{opacity:1;}100%{top:110%;opacity:0;}}
.scan-title{font-family:var(--mono);font-size:13px;letter-spacing:1.5px;color:var(--gold);text-transform:uppercase;margin-bottom:18px;}
.scan-log{width:min(560px,90vw);height:170px;overflow-y:auto;font-family:var(--mono);font-size:12px;color:var(--mut);margin-bottom:16px;border-left:2px solid var(--bord2);padding-left:14px;}
.logline{padding:3px 0;opacity:0;animation:fadein .3s forwards;}
@keyframes fadein{to{opacity:1;}}
.scan-prog-track{width:min(420px,80vw);height:5px;background:var(--card2);border-radius:99px;overflow:hidden;margin-bottom:6px;}
.scan-prog-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--gold),var(--red));transition:width .3s;}
.scan-prog-pct{font-family:var(--mono);font-size:12px;color:var(--mut);margin-bottom:14px;}
.scan-hint{font-size:11.5px;color:var(--mut2);font-style:italic;}

/* ---------- results shell ---------- */
.results{display:none;max-width:1180px;margin:0 auto;padding:26px 22px 60px;position:relative;z-index:1;}
.results.act{display:block;}
.stat-strip{margin-bottom:18px;}
.city-head{display:flex;justify-content:space-between;align-items:flex-end;gap:14px;flex-wrap:wrap;margin-bottom:14px;}
.city-name{font-size:26px;font-weight:900;letter-spacing:.3px;}
.city-sub{font-size:12.5px;color:var(--mut);margin-top:2px;}
.conf-badge{font-family:var(--mono);font-size:11px;font-weight:700;padding:6px 12px;border-radius:7px;border:1px solid var(--c);color:var(--c);white-space:nowrap;}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;}
.stat-tile{background:var(--card);border:1px solid var(--bord);border-radius:10px;padding:13px 14px;}
.stat-n{display:block;font-family:var(--mono);font-size:21px;font-weight:800;}
.stat-l{font-size:11px;color:var(--mut2);}

.tabs{display:flex;gap:4px;overflow-x:auto;border-bottom:1px solid var(--bord);margin-bottom:20px;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{font-family:inherit;padding:10px 15px;border-radius:8px 8px 0 0;cursor:pointer;font-size:12.5px;font-weight:600;white-space:nowrap;background:transparent;color:var(--mut2);border:1px solid transparent;border-bottom:none;margin-bottom:-1px;}
.tab:hover{color:var(--txt);}
.tab.act{background:var(--card);border-color:var(--bord);color:var(--gold);}
.tabpanel{display:none;}
.tabpanel.act{display:block;}

.zd-h{font-size:15px;font-weight:800;margin-bottom:10px;letter-spacing:.2px;}
.card{background:var(--card);border:1px solid var(--bord);border-radius:12px;padding:18px 20px;margin-bottom:14px;}
.card-i{background:linear-gradient(135deg,rgba(47,208,199,.06),var(--card));border-color:rgba(47,208,199,.22);}
.card-s{background:linear-gradient(135deg,rgba(255,194,61,.06),var(--card));border-color:rgba(255,194,61,.22);}
.g2{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;}

/* ---------- overview ---------- */
.narrative{font-size:14.5px;color:var(--txt);background:var(--card);border:1px solid var(--bord);border-radius:12px;padding:16px 18px;margin-bottom:18px;}
.narrative b{color:var(--gold);}
.hot-list{display:flex;flex-direction:column;gap:9px;}
.hot-card{display:flex;align-items:center;gap:14px;background:var(--card);border:1px solid var(--bord);border-left:4px solid var(--tc);border-radius:10px;padding:12px 16px;cursor:pointer;transition:transform .12s,border-color .12s;}
.hot-card:hover{transform:translateX(3px);border-color:var(--tc);}
.hot-rank{font-family:var(--mono);font-size:12px;color:var(--mut2);width:26px;flex-shrink:0;}
.hot-icon{font-size:20px;flex-shrink:0;}
.hot-body{flex:1;min-width:0;}
.hot-name{font-size:13.5px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.hot-typ{font-size:11px;color:var(--mut2);margin-bottom:5px;font-family:var(--mono);}
.hot-bar-wrap{height:5px;background:var(--card2);border-radius:99px;overflow:hidden;}
.hot-bar{height:100%;border-radius:99px;}
.hot-metrics{display:flex;flex-direction:column;align-items:center;gap:0;flex-shrink:0;}
.overview-hint{font-size:12px;color:var(--mut2);margin-top:14px;font-style:italic;}

/* ---------- gauges ---------- */
.gauge-svg{display:block;}
.gauge-num{font-family:var(--mono);font-weight:800;font-size:19px;}

/* ---------- deep dive ---------- */
.deepdive-layout{display:flex;gap:18px;align-items:flex-start;}
.zone-rail{width:270px;flex-shrink:0;display:flex;flex-direction:column;gap:7px;}
.zone-chip{display:flex;align-items:center;gap:9px;width:100%;text-align:left;font-family:inherit;background:var(--card);border:1px solid var(--bord);border-left:3px solid var(--tc);border-radius:9px;padding:9px 12px;cursor:pointer;color:var(--txt);}
.zone-chip.act{background:var(--card2);border-color:var(--tc);}
.zc-rank{font-family:var(--mono);font-size:11px;color:var(--mut2);}
.zc-icon{font-size:15px;}
.zc-name{flex:1;font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.zc-uhsi{font-family:var(--mono);font-size:12px;font-weight:800;}
.zone-detail{flex:1;min-width:0;}
.zd-header{border:1px solid var(--bord);border-top:3px solid var(--tc);border-radius:12px;padding:18px 20px;margin-bottom:16px;background:var(--card);}
.zd-rank{font-family:var(--mono);font-size:11px;letter-spacing:1.5px;color:var(--mut2);margin-bottom:6px;}
.zd-title{font-size:21px;font-weight:800;display:flex;align-items:center;gap:9px;margin-bottom:4px;}
.zd-typ{font-size:12.5px;color:var(--mut);margin-bottom:14px;}
.zd-channel{font-family:var(--mono);color:var(--mut2);}
.zd-metrics{display:flex;gap:18px;flex-wrap:wrap;align-items:center;}
.zd-m{font-size:12.5px;color:var(--mut);}
.zd-m b{font-family:var(--mono);}
.zd-section{margin-bottom:18px;}
.insuff-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--bord);font-size:12.5px;}
.insuff-row:last-child{border-bottom:none;}
.badge.dim{background:var(--card2);color:var(--mut);border:1px solid var(--bord);font-size:11px;padding:3px 9px;border-radius:6px;font-weight:600;flex-shrink:0;}
.insuff-d{font-family:var(--mono);color:var(--mut2);flex-shrink:0;}
.insuff-note{color:var(--mut2);}

.sol-grid{display:flex;flex-direction:column;gap:11px;}
.sol-card{background:var(--card2);border:1px solid var(--bord);border-left:3px solid var(--tc);border-radius:10px;padding:15px 17px;}
.sol-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:7px;}
.sol-name{font-size:13.5px;font-weight:700;}
.sol-stars{color:var(--gold);font-size:12px;letter-spacing:1px;flex-shrink:0;}
.sol-mech{font-size:12.5px;color:var(--txt);opacity:.92;margin-bottom:9px;}
.sol-meta{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:7px;margin-bottom:9px;}
.meta-pill{background:var(--card);border:1px solid var(--bord);border-radius:7px;padding:6px 9px;}
.meta-l{display:block;font-size:9.5px;text-transform:uppercase;letter-spacing:.5px;color:var(--mut2);margin-bottom:1px;}
.meta-v{font-size:12px;font-weight:700;font-family:var(--mono);}
.sol-cobenefit,.sol-source,.sol-isro,.sol-pilot{font-size:11.5px;color:var(--mut);margin-top:4px;}
.sol-isro{color:var(--teal);}
.sol-pilot{color:var(--gold);}

.phase-mini-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;}
.phase-mini{background:var(--card2);border:1px solid var(--bord);border-radius:10px;padding:12px 14px;}
.phase-mini-head{display:flex;justify-content:space-between;font-size:11.5px;font-weight:700;margin-bottom:8px;}
.phase-window{font-family:var(--mono);color:var(--mut2);font-weight:600;}
.phase-item{font-size:11.5px;color:var(--mut);padding:4px 0;border-top:1px solid var(--bord);}
.phase-item:first-child{border-top:none;}
.phase-item.dim{color:var(--mut2);font-style:italic;}
.phase-item.synth{color:var(--teal);}
.mini-forecast{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.mf-tile{background:var(--card2);border:1px solid var(--bord);border-radius:9px;padding:10px;text-align:center;}
.mf-y{display:block;font-size:10.5px;color:var(--mut2);margin-bottom:3px;}
.mf-v{font-family:var(--mono);font-size:15px;font-weight:800;color:var(--teal);}

/* ---------- roadmap ---------- */
.gantt-wrap{margin-bottom:18px;}
.gantt-row{display:grid;grid-template-columns:230px 1fr;gap:9px;margin-bottom:7px;align-items:stretch;}
.gantt-label{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:700;border-left:3px solid var(--tc);padding:0 0 0 10px;}
.gantt-label span{font-family:var(--mono);color:var(--mut2);font-weight:600;}
.gantt-cells{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;}
.gantt-cell{background:var(--card);border:1px solid var(--bord);border-radius:7px;padding:8px 9px;font-size:10.5px;color:var(--mut);min-height:34px;display:flex;align-items:center;}
.gantt-cell.head{background:transparent;border:none;font-family:var(--mono);color:var(--mut2);font-weight:700;text-transform:uppercase;letter-spacing:.4px;font-size:9.5px;}
.gantt-header .gantt-label{border-left:none;}
.prog-row{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.prog-track{flex:1;height:7px;background:var(--card2);border-radius:99px;overflow:hidden;}
.prog-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--teal),var(--gold));transition:width .3s;}
#mProgTxt{font-size:12px;color:var(--mut);font-family:var(--mono);white-space:nowrap;}
.chk{display:flex;align-items:flex-start;gap:9px;padding:7px 0;border-bottom:1px solid var(--bord);}
.chk:last-child{border-bottom:none;}
.chk input{margin-top:3px;accent-color:var(--teal);flex-shrink:0;}
.chk label{font-size:12.5px;cursor:pointer;}

/* ---------- forecast ---------- */
.chart-card{background:var(--card);border:1px solid var(--bord);border-radius:12px;padding:16px 18px 8px;margin-bottom:10px;}
.chart-svg{width:100%;height:auto;}
.legend{display:flex;gap:16px;justify-content:center;margin-top:4px;padding-bottom:8px;}
.legend span{display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--mut);}
.legend i{width:10px;height:10px;border-radius:3px;display:inline-block;}
.forecast-note{font-size:13px;color:var(--mut);margin:10px 0 16px;}
.forecast-note b{color:var(--gold);}
.disclaim-sm{font-size:11px;color:var(--mut2);margin-top:10px;font-style:italic;}
table.t{width:100%;border-collapse:collapse;font-size:12.5px;}
table.t th{text-align:left;padding:8px 10px;background:var(--card2);color:var(--mut2);font-size:10.5px;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--bord);}
table.t td{padding:8px 10px;border-bottom:1px solid var(--bord);font-family:var(--mono);font-size:12px;}
table.t td.gold{color:var(--gold);}

/* ---------- methodology ---------- */
.fw-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:12px;margin-bottom:16px;}
.fw-card{background:var(--card);border:1px solid var(--bord);border-left:3px solid var(--tc);border-radius:10px;padding:14px 16px;}
.fw-name{font-size:13px;font-weight:700;margin-bottom:6px;}
.fw-desc{font-size:12px;color:var(--mut);}
.conf-legend{display:flex;flex-direction:column;gap:8px;margin:14px 0;}
.conf-row{font-size:12.5px;color:var(--mut);display:flex;align-items:center;gap:9px;}
.conf-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}

/* ---------- footer ---------- */
.foot{max-width:1180px;margin:0 auto;padding:24px 22px 50px;position:relative;z-index:1;}
.foot-disclaim{font-size:11.5px;color:var(--mut2);border-top:1px solid var(--bord);padding-top:16px;}

@media (max-width:760px){
  .deepdive-layout{flex-direction:column;}
  .zone-rail{width:100%;flex-direction:row;overflow-x:auto;}
  .zone-chip{flex-shrink:0;min-width:200px;}
  .gantt-row{grid-template-columns:1fr;}
  .gantt-cells{grid-template-columns:repeat(2,1fr);}
  .mini-forecast{grid-template-columns:repeat(2,1fr);}
  .hot-metrics{flex-direction:row;}
}
@media print{
  .topbar,.tabs,#hero,#scanOverlay,.chip-row{display:none!important;}
  .tabpanel{display:block!important;margin-bottom:30px;}
  body::before{display:none;}
}
</style>
</head>
<body>

<header class="topbar">
  <div class="brand"><span class="brand-mark">☉</span><span><b>TAPAS-UHI</b> · SURYA DRISHTI</span></div>
  <div class="topbar-actions" id="topActions" style="display:none">
    <button class="btn ghost" onclick="window.print()">🖨 Print Report</button>
    <button class="btn ghost" id="resetBtn">↺ Scan Another City</button>
  </div>
</header>

<section class="hero" id="hero">
  <div class="dial-wrap">
    <div class="dial-rays"></div>
    <div class="dial-ring"></div>
    <div class="dial-orbit"></div>
    <div class="dial-core"></div>
  </div>
  <div class="hero-tag">तपस्-UHI // ORBITAL HEAT TELEMETRY</div>
  <h1 class="hero-title">SURYA DRISHTI</h1>
  <p class="hero-sub">Pan-India Urban Heat Intelligence Engine</p>
  <p class="hero-copy">Type any city in India. SURYA DRISHTI scans it from orbit, ranks every heat island by severity, and hands you a physics-grounded, costed, scenario-specific cooling plan for each one — with a phased roadmap and a 20-year forecast.</p>
  <form id="scanForm" class="scan-form">
    <label for="cityInput" class="sr-only">City name</label>
    <input id="cityInput" type="text" list="cityList" placeholder="e.g. Mumbai, Bagalkot, Lucknow, Surat…" autocomplete="off">
    <datalist id="cityList"></datalist>
    <button type="submit" class="btn primary">🛰️ Scan From Orbit</button>
  </form>
  <div class="chip-row">
    <span class="chip-label">Try:</span>
    <button type="button" class="chip" data-city="Bengaluru">Bengaluru</button>
    <button type="button" class="chip" data-city="Mumbai">Mumbai</button>
    <button type="button" class="chip" data-city="Delhi">Delhi</button>
    <button type="button" class="chip" data-city="Bagalkot">Bagalkot</button>
    <button type="button" class="chip" id="chipSurprise">🎲 Surprise Me</button>
  </div>
  <div class="badges-row">
