function renderResults(result){
  CURRENT=result;
  ACTIVE_ZONE_IDX=0;
  document.getElementById('results').classList.add('act');
  document.getElementById('topActions').style.display='flex';
  renderStatStrip(result.zones,result.meta);
  renderOverview(result.zones,result.meta);
  renderZoneRail(result.zones);
  renderZoneDetail(result.zones[0]);
  renderMasterRoadmap(result.zones,result.meta);
  renderForecast(result.zones,result.meta);
  renderMethodology(result.zones,result.meta);
  switchTab('overview');
  window.scrollTo({top:0,behavior:'smooth'});
}
function switchTab(id){
  const tabs=document.querySelectorAll('.tab');
  for(let i=0;i<tabs.length;i++){ tabs[i].classList.toggle('act',tabs[i].dataset.tab===id); }
  const panels=document.querySelectorAll('.tabpanel');
  for(let i=0;i<panels.length;i++){ panels[i].classList.toggle('act',panels[i].id==='panel-'+id); }
}

/* ================= SCAN FLOW ================= */
function buildCityResult(cityRaw){
  const resolved=resolveCity(cityRaw);
  const zones=computeCityZones(resolved);
  return {raw:cityRaw,meta:resolved.meta,zones:zones};
}
function showOverlay(){
  document.getElementById('hero').classList.add('hidden');
  document.getElementById('scanOverlay').classList.add('act');
}
function hideOverlay(){
  document.getElementById('scanOverlay').classList.remove('act');
}
async function runScan(cityRaw){
  showOverlay();
  const logEl=document.getElementById('scanLog');
  logEl.innerHTML='';
  const total=SCAN_LOG.length;
  for(let i=0;i<total;i++){
    const line=SCAN_LOG[i].replace('{CITY}',cityRaw);
    const div=document.createElement('div');
    div.className='logline';
    div.textContent=line;
    logEl.appendChild(div);
    logEl.scrollTop=logEl.scrollHeight;
    document.getElementById('scanProgFill').style.width=((i+1)/total*100)+'%';
    document.getElementById('scanProgPct').textContent=Math.round((i+1)/total*100)+'%';
    await sleep(420+Math.random()*260);
  }
  await sleep(500);
  const result=buildCityResult(cityRaw);
  hideOverlay();
  renderResults(result);
}
function resetScan(){
  document.getElementById('results').classList.remove('act');
  document.getElementById('hero').classList.remove('hidden');
  document.getElementById('topActions').style.display='none';
  document.getElementById('cityInput').value='';
  window.scrollTo({top:0,behavior:'smooth'});
}
function shakeInput(){
  const el=document.getElementById('cityInput');
  el.classList.add('shake');
  setTimeout(function(){el.classList.remove('shake');},420);
}

/* ================= INIT ================= */
function initDatalist(){
  const dl=document.getElementById('cityList');
  const names=Object.keys(CITY_DB).map(function(k){return CITY_DB[k].display;}).sort();
  dl.innerHTML=names.map(function(n){return `<option value="${escapeHtml(n)}"></option>`;}).join('');
}
initDatalist();
document.getElementById('scanForm').addEventListener('submit',function(e){
  e.preventDefault();
  const v=document.getElementById('cityInput').value;
  if(!v||!v.trim()){ shakeInput(); return; }
  runScan(v.trim());
});
const chipButtons=document.querySelectorAll('.chip[data-city]');
for(let i=0;i<chipButtons.length;i++){
  chipButtons[i].addEventListener('click',function(){
    document.getElementById('cityInput').value=this.dataset.city;
    runScan(this.dataset.city);
  });
}
document.getElementById('chipSurprise').addEventListener('click',function(){
  const keys=Object.keys(CITY_DB);
  const k=keys[Math.floor(Math.random()*keys.length)];
  document.getElementById('cityInput').value=CITY_DB[k].display;
  runScan(CITY_DB[k].display);
});
const tabButtons=document.querySelectorAll('.tab');
for(let i=0;i<tabButtons.length;i++){
  tabButtons[i].addEventListener('click',function(){ switchTab(this.dataset.tab); });
}
document.getElementById('resetBtn').addEventListener('click',resetScan);
</script>
