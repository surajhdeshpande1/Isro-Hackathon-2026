/* ================= CORE COMPUTE ================= */
function resolveCity(raw){
  const trimmed=raw.trim();
  const norm=trimmed.toLowerCase().replace(/\s+/g,' ');
  let key=ALIASES[norm]||norm;
  key=key.replace(/[^a-z\-\u0020]/g,'').trim();
  if(CITY_DB[key]) return {key:key,meta:CITY_DB[key]};
  return {key:'generic::'+key,meta:buildGenericMeta(trimmed)};
}
function computeZoneMetrics(cityKey,meta,zoneDef){
  const typ=TYPOLOGIES[zoneDef.typology];
  const rng=rngFor(cityKey+'::'+zoneDef.typology+'::'+zoneDef.name);
  const amp=typ.ampRange[0]+rng()*(typ.ampRange[1]-typ.ampRange[0]);
  const jitter=(rng()-0.5)*1.4;
  const lstPeak=meta.baselineLST+amp+jitter;
  const lstLow=lstPeak-(2.2+rng()*2.2);
  const uhsi=clamp(Math.round(38+(lstPeak-meta.baselineLST)*3.6+rng()*6),38,99);
  const areaKm2=round1(0.9+rng()*4.0);
  const density=popDensityFor(zoneDef.typology,meta.tier);
  const pop=Math.round(areaKm2*density*(0.65+rng()*0.55));
  const imperviousPct=clamp(Math.round(35+(typ.ampRange[0]+typ.ampRange[1])/2*3+(rng()-0.5)*10),20,96);
  const out={typology:zoneDef.typology,name:zoneDef.name,lstPeak:round1(lstPeak),lstLow:round1(lstLow),uhsi:uhsi,areaKm2:areaKm2,pop:pop,imperviousPct:imperviousPct};
  return out;
}
function computeCityZones(resolved){
  const meta=resolved.meta;
  const zones=meta.zones.map(function(z){return computeZoneMetrics(resolved.key,meta,z);});
  zones.sort(function(a,b){return (b.uhsi-a.uhsi)||(b.lstPeak-a.lstPeak);});
  zones.forEach(function(z,i){z.rank=i+1;});
  return zones;
}
function zoneSolutions(zone){
  return SOLUTIONS[zone.typology].map(function(s){
    const copy={};
    for(const k in s){copy[k]=s[k];}
    copy.pilot=s.pilotFn(zone.name);
    return copy;
  });
}
function complexityKey(c){return c.indexOf('Low')===0?'Low':(c.indexOf('Medium')===0?'Medium':'High');}
function severityInfo(u){
  if(u>=88) return {label:'CRITICAL',color:'var(--red)'};
  if(u>=76) return {label:'SEVERE',color:'var(--orange)'};
  if(u>=64) return {label:'HIGH',color:'var(--gold)'};
  if(u>=52) return {label:'MODERATE',color:'var(--bronze)'};
  return {label:'EMERGING',color:'var(--teal)'};
}
function buildZoneRoadmap(zone,sols){
  const buckets={Low:[],Medium:[],High:[]};
  sols.forEach(function(s){buckets[complexityKey(s.complexity)].push(s);});
  const totalDT=sols.reduce(function(a,s){return a+s.ambientDT;},0);
  return [
    {label:'Phase 1 · Immediate Wins',window:'Month 0-6',items:buckets.Low},
    {label:'Phase 2 · Pilot & Scale',window:'Month 6-18',items:buckets.Medium},
    {label:'Phase 3 · Infrastructure Build-Out',window:'Month 18-36',items:buckets.High},
    {label:'Phase 4 · Maturation & Replication',window:'Year 3-10',items:[],
     synth:`Full-zone saturation of all interventions. A ${TYPOLOGIES[zone.typology].channel} satellite re-scan verifies achieved cooling against the modelled ${round1(totalDT)}°C combined potential, and the results feed forward into the next-ranked zone's plan.`}
  ];
}
function buildNarrative(zones,meta){
  const top=zones[0];
  const typ=TYPOLOGIES[top.typology];
  const totalPop=zones.reduce(function(s,z){return s+z.pop;},0);
  const typAvg={};
  TYPO_ORDER.forEach(function(t){
    const zz=zones.filter(function(z){return z.typology===t;})[0];
    typAvg[t]=zz?zz.uhsi:0;
  });
  let calmest=TYPO_ORDER[0];
  TYPO_ORDER.forEach(function(t){ if(typAvg[t]<typAvg[calmest]) calmest=t; });
  return `${escapeHtml(meta.display)}'s most severe diagnosed heat island is <b>${escapeHtml(top.name)}</b> — a ${typ.label.toLowerCase()} running ${top.lstPeak}°C at peak, ${round1(top.lstPeak-meta.baselineLST)}°C above the metro's rural baseline of ${meta.baselineLST}°C. Of the six thermal typologies scanned, <b>${TYPOLOGIES[calmest].label.toLowerCase()}</b> zones came out comparatively contained, while ${typ.label.toLowerCase()} zones ran hottest here. An estimated <b>${fmtPop(totalPop)}</b> residents and workers live or work inside the six heat-risk zones identified citywide.`;
}
function buildMasterChecklist(zones){
