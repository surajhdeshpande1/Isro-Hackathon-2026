function buildZoneRoadmap(zone,sols){
  const buckets={Low:[],Medium:[],High:[]};
  sols.forEach(s=>buckets[complexityKey(s.complexity)].push(s));
  const totalDT=sols.reduce((a,s)=>a+s.ambientDT,0);
  return [
    {label:'Immediate Wins',window:'Month 0-6',items:buckets.Low},
    {label:'Pilot & Scale',window:'Month 6-18',items:buckets.Medium},
    {label:'Infrastructure Build-Out',window:'Month 18-36',items:buckets.High},
    {label:'Maturation & Replication',window:'Year 3-10',items:[],
     synth:`Full-zone saturation of all interventions. ${TYPOLOGIES[zone.typology].channel} re-scan verifies achieved cooling against modelled ${r1(totalDT)}°C combined potential.`}
  ];
}

