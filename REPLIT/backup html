function initMap(resolved,zones){
  const meta=resolved.meta;
  if(cityMap){cityMap.remove();cityMap=null;}
  heatLayerGroup=null;hotspotsLayerGroup=null;waterLayerGroup=null;parksLayerGroup=null;buildingsLayerGroup=null;poiLayerGroup=null;
  const mapEl=document.getElementById('cityMap');
  if(!mapEl) return;
  const defaultCenter=meta.coords||[20.5937,78.9629];
  const zoom=meta.coords?13:5;
  cityMap=L.map('cityMap',{zoomControl:true,attributionControl:false}).setView(defaultCenter,zoom);
  L.control.attribution({position:'bottomright',prefix:false}).addTo(cityMap);
  osmLayer=L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{
    attribution:'© OSM © CARTO',subdomains:'abcd',maxZoom:20}).addTo(cityMap);
  satLayer=L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{
    attribution:'Tiles © Esri',maxZoom:19});
  cityMap._hybridLabels=L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png',{
    attribution:'© OSM © CARTO',subdomains:'abcd',maxZoom:20,opacity:.85});
  waterLayerGroup=L.layerGroup().addTo(cityMap);
  parksLayerGroup=L.layerGroup().addTo(cityMap);
  buildingsLayerGroup=L.layerGroup();
  heatLayerGroup=L.layerGroup().addTo(cityMap);
  hotspotsLayerGroup=L.layerGroup().addTo(cityMap);
  poiLayerGroup=L.layerGroup();
  const center=meta.coords||defaultCenter;
  if(!meta.coords){
    geocodeCity(meta.display).then(coords=>{
      if(coords&&cityMap){
        cityMap.setView(coords,13);
        renderHeatAndMarkers(zones,coords);
        fetchAndRenderOSMLayers(coords);
      }
    });
  } else {
    renderHeatAndMarkers(zones,center);
    fetchAndRenderOSMLayers(center);
  }
  cityMap.on('mousemove',e=>showVision(e.latlng,zones,center));
  cityMap.on('mouseout',()=>{const vp=document.getElementById('visionPanel');if(vp)vp.style.display='none';});
}

function renderHeatAndMarkers(zones,center){
  if(!cityMap||!heatLayerGroup||!hotspotsLayerGroup) return;
  heatLayerGroup.clearLayers();
  hotspotsLayerGroup.clearLayers();
  zones.forEach(z=>{
    const typ=TYPOLOGIES[z.typology];
    const lat=center[0]+z.latOff;
    const lng=center[1]+z.lngOff;
    const radius=Math.sqrt(z.areaKm2)*430;
    L.circle([lat,lng],{radius,color:typ.color,fillColor:typ.color,fillOpacity:0.17,weight:1.5,opacity:0.72}).addTo(heatLayerGroup);
    L.circle([lat,lng],{radius:radius*1.5,color:typ.color,fillColor:typ.color,fillOpacity:0.05,weight:0.5,opacity:0.35,dashArray:'4,7'}).addTo(heatLayerGroup);
    const markerHtml=`<div class="surya-marker" style="--mc:${typ.color}">
      <div class="sm-pulse"></div><div class="sm-pulse2"></div>
      <div class="sm-dot"><div class="sm-rank">${z.rank}</div></div>
    </div>`;
    const divIcon=L.divIcon({className:'',html:markerHtml,iconSize:[22,22],iconAnchor:[11,11]});
    const marker=L.marker([lat,lng],{icon:divIcon,zIndexOffset:z.rank===1?1000:0}).addTo(hotspotsLayerGroup);
    marker.on('click',()=>openHotspotPanel(z));
    marker.on('mouseover',()=>{
      const vp=document.getElementById('visionPanel');
      if(vp) vp.style.display='block';
      showVisionForZone(z);
    });
  });
}

async function fetchAndRenderOSMLayers(center){
  /* --- Nature layers (water, parks, forests) --- */
  try{
    const r=0.09;
    const bbox=`${center[0]-r},${center[1]-r},${center[0]+r},${center[1]+r}`;
    const q1=`[out:json][timeout:22];(way["natural"="water"](${bbox});way["leisure"="park"](${bbox});way["landuse"~"^(park|forest|grass|recreation_ground)$"](${bbox});way["natural"~"^(wood|grassland)$"](${bbox}););out geom 600;`;
    const res1=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q1)});
    if(res1.ok){
      const d1=await res1.json();
      (d1.elements||[]).forEach(el=>{
        if(!el.geometry||el.geometry.length<3) return;
        const coords=el.geometry.map(pt=>[pt.lat,pt.lon]);
        const isWater=el.tags&&el.tags.natural==='water';
        const isForest=el.tags&&(el.tags.landuse==='forest'||el.tags.natural==='wood');
        const style=isWater
          ?{color:'rgba(47,208,199,.55)',fillColor:'rgba(47,208,199,.18)',weight:1,fillOpacity:1,interactive:false}
          :isForest
          ?{color:'rgba(74,222,128,.4)',fillColor:'rgba(74,222,128,.12)',weight:0.8,fillOpacity:1,interactive:false}
          :{color:'rgba(100,200,100,.4)',fillColor:'rgba(100,200,100,.1)',weight:0.8,fillOpacity:1,interactive:false};
        L.polygon(coords,style).addTo(isWater?waterLayerGroup:parksLayerGroup);
      });
    }
  }catch(e){}
  /* --- Buildings (major: commercial, industrial, civic) --- */
  try{
    const rb=0.07;
    const bboxB=`${center[0]-rb},${center[1]-rb},${center[0]+rb},${center[1]+rb}`;
    const q2=`[out:json][timeout:18];(way["building"~"^(commercial|industrial|hospital|school|university|government|civic|office|retail|warehouse|manufacture)$"](${bboxB}););out geom 150;`;
    const res2=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q2)});
    if(res2.ok){
      const d2=await res2.json();
      (d2.elements||[]).forEach(el=>{
        if(!el.geometry||el.geometry.length<3) return;
        const coords=el.geometry.map(pt=>[pt.lat,pt.lon]);
        const bType=el.tags&&el.tags.building;
        const isIndustrial=bType==='industrial'||bType==='warehouse'||bType==='manufacture';
        const isHealth=bType==='hospital';
        const col=isIndustrial?'rgba(255,122,31,.45)':isHealth?'rgba(255,75,46,.5)':'rgba(200,170,255,.35)';
        L.polygon(coords,{color:col,fillColor:col,fillOpacity:0.25,weight:0.7,interactive:false}).addTo(buildingsLayerGroup);
      });
    }
  }catch(e){}
  /* --- POIs (hospitals, schools, transit, markets) --- */
  try{
    const rp=0.08;
    const bboxP=`${center[0]-rp},${center[1]-rp},${center[0]+rp},${center[1]+rp}`;
    const q3=`[out:json][timeout:16];(node["amenity"~"^(hospital|school|university|college|bus_station|railway_station|police|fire_station|marketplace)$"](${bboxP});node["shop"="mall"](${bboxP}););out 80;`;
    const res3=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q3)});
    if(res3.ok){
      const d3=await res3.json();
      (d3.elements||[]).forEach(el=>{
        if(!el.lat||!el.lon) return;
        const amenity=el.tags&&(el.tags.amenity||el.tags.shop||'');
        const icon=amenity==='hospital'?'🏥':amenity==='school'||amenity==='university'||amenity==='college'?'🏫':amenity==='bus_station'?'🚌':amenity==='railway_station'?'🚉':amenity==='police'?'🚓':amenity==='marketplace'||amenity==='mall'?'🛒':'📍';
        const name=(el.tags&&el.tags.name)||amenity;
        const poiHtml=`<div style="font-size:13px;filter:drop-shadow(0 1px 4px rgba(0,0,0,.8));cursor:pointer" title="${esc(name)}">${icon}</div>`;
        L.marker([el.lat,el.lon],{icon:L.divIcon({className:'',html:poiHtml,iconSize:[16,16],iconAnchor:[8,8]}),zIndexOffset:-100})
