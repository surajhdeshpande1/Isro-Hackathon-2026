function openHotspotPanel(zone){
  activeHotspotZone=zone;
  const panel=document.getElementById('mapHstpPanel');
  if(!panel) return;
  panel.classList.add('open');
  const typ=TYPOLOGIES[zone.typology];
  const nameEl=document.getElementById('hstpZoneName');
  const typEl=document.getElementById('hstpZoneTyp');
  if(nameEl) nameEl.textContent=`${typ.icon} ${zone.name}`;
  if(typEl) typEl.textContent=`Rank #${zone.rank} · ${typ.label} · UHSI ${zone.uhsi}`;
  document.querySelectorAll('.hstp-tab').forEach((t,i)=>{t.classList.toggle('act',i===0);});
  mapHstpTab='overview';
  renderHstpBody();
  /* Highlight active zone in left rail */
  if(CURRENT_ZONES) CURRENT_ZONES.forEach((_,i)=>{
    const el=document.getElementById('mlpz-'+i);
    if(!el) return;
    const isActive=CURRENT_ZONES[i]===zone;
    el.dataset.act=isActive?'1':'0';
    el.style.background=isActive?'rgba(155,110,255,.12)':'';
    el.style.borderLeft=isActive?'2px solid var(--violet)':'';
  });
  setTimeout(()=>{if(cityMap)cityMap.invalidateSize();},340);
}

function closeHotspotPanel(){
  const panel=document.getElementById('mapHstpPanel');
  if(panel) panel.classList.remove('open');
  activeHotspotZone=null;
  /* Clear left rail highlights */
  if(CURRENT_ZONES) CURRENT_ZONES.forEach((_,i)=>{
    const el=document.getElementById('mlpz-'+i);
    if(el){el.dataset.act='0';el.style.background='';el.style.borderLeft='';}
  });
  setTimeout(()=>{if(cityMap)cityMap.invalidateSize();},340);
}

