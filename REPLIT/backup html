    <div style="font-size:11px;color:var(--mut2);margin-top:14px;font-style:italic">TAPAS SURYA DRISHTI v3.0 · Bhartiya Antariksha Hackathon 2026 · ISRO + Hack2skill. Deterministic demo engine using calibrated synthetic models based on real ISRO data products and published UHI literature. Not a live satellite feed. Field-calibrate before policy use.</div>`;
}

/* =========================================================
   CHART BUILDER
   ========================================================= */
function svgLineChart(seriesArr,opts={}){
  const W=opts.width||680,H=opts.height||240;
  const pL=54,pR=16,pT=16,pB=28;
  const xs=seriesArr[0].points.map(p=>p.x);
  let allY=[];
  seriesArr.forEach(s=>s.points.forEach(p=>allY.push(p.y)));
  let mn=Math.min(...allY),mx=Math.max(...allY);
  if(mn===mx){mn-=1;mx+=1;}
  const py=(mx-mn)*0.10;mn-=py;mx+=py;
  const mnX=Math.min(...xs),mxX=Math.max(...xs);
  const xS=x=>pL+(x-mnX)/((mxX-mnX)||1)*(W-pL-pR);
  const yS=y=>H-pB-(y-mn)/((mx-mn)||1)*(H-pT-pB);
  let svg=`<svg viewBox="0 0 ${W} ${H}" class="chart-svg" xmlns="http://www.w3.org/2000/svg">`;
  for(let i=0;i<=5;i++){
    const v=mn+(mx-mn)*i/5,yy=yS(v);
    svg+=`<line x1="${pL}" y1="${yy}" x2="${W-pR}" y2="${yy}" stroke="rgba(155,110,255,0.08)" stroke-width="1"/>`;
    svg+=`<text x="${pL-6}" y="${yy+4}" text-anchor="end" font-size="10" fill="var(--mut2)" font-family="var(--mono)">${opts.yFmt?opts.yFmt(v):v.toFixed(1)}</text>`;
  }
  xs.forEach(x=>{
    const xx=xS(x);
    svg+=`<text x="${xx}" y="${H-pB+16}" text-anchor="middle" font-size="10" fill="var(--mut2)" font-family="var(--mono)">${opts.xFmt?opts.xFmt(x):x}</text>`;
  });
  seriesArr.forEach(s=>{
    const pts=s.points.map(p=>xS(p.x)+','+yS(p.y)).join(' ');
    if(s.fill){
      const f=s.points[0],l=s.points[s.points.length-1];
      svg+=`<polygon points="${xS(f.x)},${yS(mn)} ${pts} ${xS(l.x)},${yS(mn)}" fill="${s.color}" opacity="0.10"/>`;
    }
    svg+=`<polyline points="${pts}" fill="none" stroke="${s.color}" stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round"/>`;
    s.points.forEach(p=>svg+=`<circle cx="${xS(p.x)}" cy="${yS(p.y)}" r="3" fill="${s.color}"/>`);
  });
  svg+='</svg>';
  return svg;
}

/* =========================================================
   TABS
   ========================================================= */
function setupTabs(){
  document.querySelectorAll('.tab').forEach(tab=>{
    tab.onclick=()=>{
      document.querySelectorAll('.tab').forEach(t=>t.classList.remove('act'));
      document.querySelectorAll('.tabpanel').forEach(p=>p.classList.remove('act'));
      tab.classList.add('act');
      const panel=document.getElementById('panel-'+tab.dataset.tab);
      if(panel) panel.classList.add('act');
      if(tab.dataset.tab==='map'&&cityMap) setTimeout(()=>cityMap.invalidateSize(),60);
    };
  });
}

/* =========================================================
   BOOTSTRAP
   ========================================================= */
const SURPRISES=['Bengaluru','Mumbai','Delhi','Chennai','Hyderabad','Pune','Ahmedabad','Jaipur','Bagalkot','Lucknow','Nagpur','Indore','Mysuru','Kochi','Coimbatore','Bhopal','Chandigarh','Guwahati'];

document.getElementById('scanForm').addEventListener('submit',e=>{
  e.preventDefault();
  const v=document.getElementById('cityInput').value.trim();
  if(!v){
    const inp=document.getElementById('cityInput');
    inp.classList.add('shake');
    setTimeout(()=>inp.classList.remove('shake'),500);
    return;
  }
  runScan(v);
});

document.querySelectorAll('.chip[data-city]').forEach(c=>{
  c.addEventListener('click',()=>{
    document.getElementById('cityInput').value=c.dataset.city;
    runScan(c.dataset.city);
  });
});

document.getElementById('chipSurprise').addEventListener('click',()=>{
  const city=SURPRISES[Math.floor(Math.random()*SURPRISES.length)];
  document.getElementById('cityInput').value=city;
  runScan(city);
});

document.getElementById('resetBtn').addEventListener('click',()=>{
  document.getElementById('hero').style.display='';
  document.getElementById('results').classList.remove('act');
  document.getElementById('topActions').style.display='none';
  document.getElementById('cityInput').value='';
  document.getElementById('suryaStatus').textContent='SURYA CORE · READY';
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('act',i===0));
  document.querySelectorAll('.tabpanel').forEach((p,i)=>p.classList.toggle('act',i===0));
  if(cityMap){cityMap.remove();cityMap=null;}
  CURRENT_RESOLVED=null;CURRENT_ZONES=null;CURRENT_FIN=null;CURRENT_FORECAST=null;
  selectedScenario='moderate';
});
</script>
