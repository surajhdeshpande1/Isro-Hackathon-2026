async function mapSearch(query){
  if(!query||!query.trim()||!cityMap) return;
  const inp=document.getElementById('mapSearchInp');
  if(inp){inp.style.borderColor='var(--violet)';inp.disabled=true;}
  try{
    const url=`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query+', India')}&format=json&limit=1&accept-language=en`;
    const res=await fetch(url,{headers:{'User-Agent':'TAPAS-UHI-SURYA-DRISHTI/3.0'}});
    const data=await res.json();
    if(data&&data[0]){
      cityMap.flyTo([parseFloat(data[0].lat),parseFloat(data[0].lon)],16,{duration:1.5});
      L.popup({closeButton:true}).setLatLng([parseFloat(data[0].lat),parseFloat(data[0].lon)])
        .setContent(`<div class="hp-pop-title">📍 ${esc(data[0].display_name.split(',')[0])}</div><div style="font-size:10.5px;color:var(--mut)">${esc(data[0].display_name.substring(0,80))}…</div>`)
        .openOn(cityMap);
    }
  }catch(e){}
  if(inp){inp.disabled=false;setTimeout(()=>{inp.style.borderColor='';},1500);}
}

