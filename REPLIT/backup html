    insuff:[{n:'Cool roofs',d:-1.7,note:'raises albedo but ignores anthropogenic source'},{n:'Street trees',d:-1.2,note:'space-constrained inside industrial plots'}]},
  SCHI:{label:'Street Canyon Heat Island',short:'Street Canyon',icon:'🏙️',color:'#FFC23D',
    ampRange:[7,12.5],channel:'AIA 171Å · Quiet Corona',
    mech:z=>`${z}'s canyon geometry bounces shortwave and longwave radiation between facing walls before it can escape skyward. With near-zero canopy and dense vehicle heat, this is a radiation trap that shade trees alone cannot drain.`,
    insuff:[{n:'Street trees',d:-2.1,note:'sidewalks cap canopy inside deep canyons'},{n:'Misting',d:-1.5,note:'water-intensive, short-lived effect'}]},
  DRHI:{label:'Dense Residential Heat Island',short:'Dense Residential',icon:'🏘️',color:'#D9A04B',
