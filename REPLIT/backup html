function resolveCity(raw){
  const trimmed=raw.trim();
  const norm=trimmed.toLowerCase().replace(/\s+/g,' ');
  let key=ALIASES[norm]||norm;
  key=key.replace(/[^a-z\-\u0020]/g,'').trim();
  if(CITY_DB[key]) return {key,meta:CITY_DB[key]};
  return {key:'generic::'+key,meta:buildGenericMeta(trimmed)};
}

function severityInfo(u){
  if(u>=88) return {label:'CRITICAL',color:'var(--red)'};
  if(u>=76) return {label:'SEVERE',color:'var(--orange)'};
  if(u>=64) return {label:'HIGH',color:'var(--gold)'};
  if(u>=52) return {label:'MODERATE',color:'var(--bronze)'};
  return {label:'EMERGING',color:'var(--teal)'};
}

function computeZoneMetrics(cityKey,meta,zoneDef){
  const typ=TYPOLOGIES[zoneDef.typology];
  const rng=rngFor(cityKey+'::'+zoneDef.typology+'::'+zoneDef.name);
  const amp=typ.ampRange[0]+rng()*(typ.ampRange[1]-typ.ampRange[0]);
  const lstPeak=r1(meta.baselineLST+amp+(rng()-0.5)*1.4);
  const lstLow=r1(lstPeak-(2.2+rng()*2.2));
  const uhsi=clamp(Math.round(38+(lstPeak-meta.baselineLST)*3.6+rng()*6),38,99);
  const areaKm2=r1(0.9+rng()*4.0);
  const baseD={IHI:3200,SCHI:24000,DRHI:17500,TCHI:11000,LDHI:8500,PSHI:4200};
  const density=baseD[zoneDef.typology]*(meta.tier===1?1.3:1.0);
  const pop=Math.round(areaKm2*density*(0.65+rng()*0.55));
  const imperviousPct=clamp(Math.round(35+(typ.ampRange[0]+typ.ampRange[1])/2*3+(rng()-0.5)*10),20,96);
  const ndvi=r2(clamp(0.45-imperviousPct*0.004+rng()*0.05,0.05,0.45));
  const ndbi=r2(clamp(imperviousPct*0.009+rng()*0.05,0.05,0.65));
  const albedo=r2(clamp(0.28-ndbi*0.15+rng()*0.04,0.10,0.35));
  const severity=clamp(Math.round(uhsi*0.95+rng()*5),38,99);
  const confidence=clamp(Math.round(72+rng()*22),60,94);
  const evidence=clamp(Math.round(65+rng()*25),50,92);
  const resilience=clamp(Math.round(100-uhsi+rng()*10),10,65);
  const vulnerability=clamp(Math.round(uhsi*0.8+rng()*15),30,96);
  const interventionScore=clamp(Math.round(60+rng()*30),50,95);
  const urgency=clamp(Math.round((uhsi-38)/61*100+rng()*8),20,99);
  const financialImpact=clamp(Math.round(55+rng()*35),40,98);
  const dR=rngFor(cityKey+'::dna::'+zoneDef.typology);
  const dRaw=[dR()*40+10,dR()*30+5,dR()*25+5,dR()*20+3,dR()*15+3,dR()*10+2];
  const dSum=dRaw.reduce((a,b)=>a+b,0);
  const dna=dRaw.map(v=>Math.round(v/dSum*100));
  dna[0]+=100-dna.reduce((a,b)=>a+b,0);
  const oR=rngFor(cityKey+'::offset::'+zoneDef.typology);
  const latOff=(oR()-0.5)*0.14;
  const lngOff=(oR()-0.5)*0.14;
  return {typology:zoneDef.typology,name:zoneDef.name,lstPeak,lstLow,uhsi,areaKm2,pop,
    imperviousPct,ndvi,ndbi,albedo,severity,confidence,evidence,resilience,vulnerability,
    interventionScore,urgency,financialImpact,sevInfo:severityInfo(uhsi),dna,latOff,lngOff};
}

function computeCityZones(resolved){
  const meta=resolved.meta;
  const zones=meta.zones.map(z=>computeZoneMetrics(resolved.key,meta,z));
  zones.sort((a,b)=>(b.uhsi-a.uhsi)||(b.lstPeak-a.lstPeak));
  zones.forEach((z,i)=>{z.rank=i+1;});
  return zones;
}

function zoneSolutions(zone){
  return SOLUTIONS[zone.typology].map(s=>{const c={...s};c.pilot=s.pilotFn(zone.name);return c;});
}
function complexityKey(c){return c.startsWith('Low')?'Low':c.startsWith('Medium')?'Medium':'High';}

/* ---- Financial Engine ---- */
function computeFinancials(zones,meta){
  const rng=rngFor(meta.display+'::fin');
  let capex=0,opexPerYear=0;
  zones.forEach(z=>{
    SOLUTIONS[z.typology].forEach(s=>{
      const ck=complexityKey(s.complexity);
      const fr=ck==='Low'?0.9:ck==='Medium'?0.7:0.5;
      capex+=s.costCr*z.areaKm2*fr;
      opexPerYear+=s.costCr*z.areaKm2*fr*0.04;
    });
  });
  capex=r1(capex*(0.85+rng()*0.3));
  opexPerYear=r1(opexPerYear);
  const totalPop=zones.reduce((s,z)=>s+z.pop,0);
  const energySav=r1(capex*0.12*(0.9+rng()*0.2));
  const healthSav=r1(totalPop*0.0000085*(0.9+rng()*0.2));
  const prodGain=r1(capex*0.08*(0.9+rng()*0.2));
  const carbonSav=r1(capex*0.06*(0.9+rng()*0.2));
  const propGain=r1(capex*0.22*(0.9+rng()*0.2));
  const totalBen=r1(energySav+healthSav+prodGain+carbonSav);
  const npv=r1(totalBen*8.5-capex);
  const irr=r1(14+rng()*12);
  const cbr=r2(totalBen*10/capex);
  const payback=r1(capex/totalBen);
  return {capex,opexPerYear,energySav,healthSav,prodGain,carbonSav,propGain,
    totalBen,npv,irr,cbr,payback,totalPop};
}

function adoptionFrac(year,ck){
  const p={Low:[1.1,0.95],Medium:[3.0,0.55],High:[6.5,0.32]}[ck]||[3,0.5];
  return 1/(1+Math.exp(-p[1]*(year-p[0])));
}

function computeForecastSeries(zones,meta){
  const years=[2025,2030,2035,2040,2045,2050];
  const totalPop=zones.reduce((s,z)=>s+z.pop,0)||1;
  const avgLST=zones.reduce((s,z)=>s+z.lstPeak*z.pop,0)/totalPop;
  return years.map(yr=>{
    const y=yr-2025;
    let wDT=0;
    zones.forEach(z=>{
      const top=SOLUTIONS[z.typology].slice().sort((a,b)=>Math.abs(b.ambientDT)-Math.abs(a.ambientDT)).slice(0,3);
      let dt=0;
      top.forEach(s=>{dt+=s.ambientDT*adoptionFrac(y,complexityKey(s.complexity))*0.6;});
      wDT+=dt*(z.pop/totalPop);
    });
    const bauLST=r1(avgLST+0.07*y);
    const withLST=r1(bauLST+wDT);
    const vegCov=r1(15+y*1.2+wDT*-3);
    const popExp=r1(totalPop*(1+y*0.018)/100000);
    const ecoLoss=r1(Math.max(0,totalPop*0.00045*(1+0.07*y)-totalPop*0.0003*Math.abs(wDT)));
    const infraStress=clamp(Math.round(55+y*2+wDT*-8),20,95);
    return {yr,bauLST,withLST,dT:r1(wDT),vegCov,popExp,ecoLoss,infraStress};
  });
}

/* =========================================================
   GEOCODING via Nominatim
   ========================================================= */
async function geocodeCity(cityName){
  try{
    const url=`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(cityName+', India')}&format=json&limit=1&accept-language=en`;
    const res=await fetch(url,{headers:{'User-Agent':'TAPAS-UHI-SURYA-DRISHTI/3.0'}});
    if(!res.ok) return null;
    const data=await res.json();
    if(data&&data[0]) return [parseFloat(data[0].lat),parseFloat(data[0].lon)];
  }catch(e){}
  return null;
}

