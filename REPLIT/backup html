async function runScan(cityInput){
  const overlay=document.getElementById('scanOverlay');
  const log=document.getElementById('scanLog');
  const fill=document.getElementById('scanProgFill');
  const pctEl=document.getElementById('scanProgPct');
  const titleEl=document.getElementById('scanTitle');
  const phaseEl=document.getElementById('scanPhase');
  overlay.classList.add('act');
  log.innerHTML='';
  fill.style.width='0%';
  document.getElementById('hero').style.display='none';
  const resolved=resolveCity(cityInput);
  CURRENT_RESOLVED=resolved;
  CURRENT_ZONES=computeCityZones(resolved);
  CURRENT_FIN=computeFinancials(CURRENT_ZONES,resolved.meta);
  CURRENT_FORECAST=computeForecastSeries(CURRENT_ZONES,resolved.meta);
  const cityDisp=resolved.meta.display;
  for(let pi=0;pi<SCAN_PHASES.length;pi++){
    const ph=SCAN_PHASES[pi];
    titleEl.textContent='SURYA CORE — '+ph.phase;
    phaseEl.textContent=ph.phase+' · ACTIVE';
    for(const line of ph.lines){
      await sleep(line.t||0);
      const div=document.createElement('div');
      div.className='logline'+(line.c?' '+line.c:'');
      div.textContent='['+new Date().toLocaleTimeString('en-IN',{hour12:false})+'] '+
        line.m.replace(/{CITY}/g,cityDisp).replace(/{N}/g,String(Math.floor(Math.random()*8+12)));
      log.appendChild(div);
      log.scrollTop=log.scrollHeight;
    }
    const pct=Math.round((pi+1)/SCAN_PHASES.length*100);
    fill.style.width=pct+'%';
    pctEl.textContent=pct+'%';
    await sleep(200);
  }
  await sleep(300);
  overlay.classList.remove('act');
  renderResults(resolved,CURRENT_ZONES,CURRENT_FIN,CURRENT_FORECAST);
}

