<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>SURYA DRISHTI · TAPAS-UHI — Urban Climate Intelligence OS</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{
  --bg:#08060A;--bg2:#120D16;--card:#16101C;--card2:#1E1526;--bord:#3A2650;--bord2:#5A3A7A;
  --txt:#EDE0F5;--mut:#B89FD0;--mut2:#7A6090;
  --gold:#FFC23D;--amber:#F2C879;--bronze:#D9A04B;--orange:#FF7A1F;--red:#FF4B2E;
  --teal:#2FD0C7;--violet:#9B6EFF;--pink:#FF6B9D;--green:#4ADE80;
  --mono:ui-monospace,"SF Mono","Cascadia Code","Roboto Mono",Consolas,monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--txt);font-family:system-ui,-apple-system,"Segoe UI",sans-serif;font-size:14.5px;line-height:1.65;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;top:-20%;left:50%;transform:translateX(-50%);width:130vw;height:130vw;max-width:1400px;max-height:1400px;background:radial-gradient(circle,rgba(155,110,255,.07) 0%,rgba(255,122,31,.04) 38%,transparent 66%);pointer-events:none;z-index:0;}
a{color:var(--gold);text-decoration:none;}
.mono{font-family:var(--mono);}
.hidden{display:none!important;}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);}
::selection{background:var(--violet);color:#fff;}

.topbar{position:sticky;top:0;z-index:400;display:flex;align-items:center;justify-content:space-between;padding:12px 20px;border-bottom:1px solid var(--bord);background:rgba(8,6,10,.95);backdrop-filter:blur(12px);}
.brand{display:flex;align-items:center;gap:9px;font-size:13px;letter-spacing:.3px;}
.brand-mark{font-size:16px;filter:drop-shadow(0 0 7px rgba(155,110,255,.8));}
.brand b{font-weight:800;}
.topbar-right{display:flex;align-items:center;gap:8px;}
.surya-status{font-family:var(--mono);font-size:10px;color:var(--teal);background:rgba(47,208,199,.1);border:1px solid rgba(47,208,199,.25);border-radius:5px;padding:3px 8px;display:flex;align-items:center;gap:5px;}
.surya-status::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--teal);animation:blink 1.4s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
.btn{font-family:inherit;font-size:12px;font-weight:600;border-radius:8px;padding:7px 13px;cursor:pointer;border:1px solid var(--bord2);background:var(--card);color:var(--txt);transition:all .15s;}
.btn:hover{border-color:var(--violet);}
.btn:active{transform:scale(.97);}
.btn.primary{background:linear-gradient(135deg,var(--violet),var(--orange));color:#fff;border:none;font-weight:800;}
.btn.ghost{background:transparent;}

.hero{max-width:780px;margin:0 auto;padding:50px 24px 68px;text-align:center;position:relative;z-index:1;}
.dial-wrap{position:relative;width:200px;height:200px;margin:0 auto 16px;}
.dial-rays{position:absolute;inset:0;border-radius:50%;background:repeating-conic-gradient(from 0deg,rgba(155,110,255,.25) 0deg 3deg,transparent 3deg 15deg);animation:spin 22s linear infinite;filter:blur(.5px);}
.dial-ring{position:absolute;inset:14px;border-radius:50%;border:1px dashed rgba(155,110,255,.35);}
.dial-ring::before,.dial-ring::after{content:'';position:absolute;width:6px;height:6px;border-radius:50%;background:var(--teal);box-shadow:0 0 8px var(--teal);}
.dial-ring::before{top:-3px;left:50%;margin-left:-3px;}
.dial-ring::after{top:50%;right:-3px;margin-top:-3px;background:var(--gold);box-shadow:0 0 8px var(--gold);}
.dial-orbit{position:absolute;inset:14px;border-radius:50%;animation:spin 14s linear infinite reverse;}
.dial-core{position:absolute;inset:46px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#F0E8FF 0%,var(--violet) 32%,var(--orange) 62%,var(--red) 100%);box-shadow:0 0 56px 16px rgba(155,110,255,.5),0 0 110px 36px rgba(255,122,31,.22);animation:pulse 4.2s ease-in-out infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.05);}}
.hero-tag{font-family:var(--mono);font-size:11px;letter-spacing:2.5px;color:var(--mut);margin-bottom:6px;}
.hero-title{font-size:clamp(32px,7vw,52px);font-weight:900;letter-spacing:1px;line-height:1;background:linear-gradient(120deg,var(--violet) 0%,var(--gold) 45%,var(--orange) 80%,var(--red) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:6px;}
.hero-sub{font-size:14px;color:var(--mut);font-weight:600;margin-bottom:16px;}
.hero-copy{font-size:14px;color:var(--txt);max-width:580px;margin:0 auto 26px;opacity:.9;}
.scan-form{display:flex;gap:10px;max-width:540px;margin:0 auto 14px;flex-wrap:wrap;}
.scan-form input{flex:1;min-width:200px;background:var(--card);border:1px solid var(--bord2);border-radius:10px;padding:13px 16px;color:var(--txt);font-size:14px;font-family:inherit;}
.scan-form input:focus{outline:none;border-color:var(--violet);box-shadow:0 0 0 3px rgba(155,110,255,.15);}
.scan-form input.shake{animation:shake .4s;border-color:var(--red);}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}
.chip-row{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:22px;}
.chip-label{font-size:12px;color:var(--mut2);align-self:center;}
.chip{font-family:inherit;font-size:11.5px;font-weight:600;background:var(--card);border:1px solid var(--bord);color:var(--mut);border-radius:99px;padding:5px 12px;cursor:pointer;transition:all .15s;}
.chip:hover{border-color:var(--violet);color:var(--txt);}
.badges-row{display:flex;gap:7px;justify-content:center;flex-wrap:wrap;}
.badge{font-size:10.5px;font-weight:600;color:var(--mut);background:var(--card);border:1px solid var(--bord);border-radius:6px;padding:4px 9px;font-family:var(--mono);}
.badge.violet{color:var(--violet);border-color:rgba(155,110,255,.3);}

.scan-overlay{position:fixed;inset:0;z-index:500;background:radial-gradient(circle at 50% 38%,#100820 0%,#08060A 70%);display:none;flex-direction:column;align-items:center;justify-content:center;padding:24px;}
.scan-overlay.act{display:flex;}
.scan-sun{position:relative;width:140px;height:140px;margin-bottom:22px;}
.scan-sun .dial-rays{animation-duration:5s;}
.scan-sun .dial-core{inset:28px;animation-duration:1.4s;}
.scan-beam{position:absolute;left:-30px;right:-30px;top:0;height:2px;background:linear-gradient(90deg,transparent,var(--teal),transparent);animation:beam 1.6s linear infinite;}
@keyframes beam{0%{top:-10%;opacity:0;}10%{opacity:1;}90%{opacity:1;}100%{top:110%;opacity:0;}}
.scan-title{font-family:var(--mono);font-size:12px;letter-spacing:2px;color:var(--violet);text-transform:uppercase;margin-bottom:6px;}
.scan-phase{font-family:var(--mono);font-size:10px;color:var(--teal);letter-spacing:1px;margin-bottom:12px;}
.scan-log{width:min(580px,90vw);height:180px;overflow-y:auto;font-family:var(--mono);font-size:11.5px;color:var(--mut);margin-bottom:14px;border-left:2px solid var(--bord2);padding-left:12px;}
.logline{padding:2px 0;opacity:0;animation:fadein .3s forwards;}
.logline.ok{color:var(--teal);}
.logline.warn{color:var(--gold);}
.logline.crit{color:var(--red);}
@keyframes fadein{to{opacity:1;}}
.scan-prog-track{width:min(440px,82vw);height:4px;background:var(--card2);border-radius:99px;overflow:hidden;margin-bottom:5px;}
.scan-prog-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--violet),var(--gold),var(--red));transition:width .3s;}
.scan-prog-pct{font-family:var(--mono);font-size:11px;color:var(--mut);margin-bottom:12px;}

.results{display:none;max-width:1280px;margin:0 auto;padding:22px 20px 60px;position:relative;z-index:1;}
.results.act{display:block;}
.city-head{display:flex;justify-content:space-between;align-items:flex-end;gap:12px;flex-wrap:wrap;margin-bottom:12px;}
.city-name{font-size:24px;font-weight:900;}
.city-sub{font-size:12px;color:var(--mut);margin-top:2px;}
.conf-badge{font-family:var(--mono);font-size:10.5px;font-weight:700;padding:5px 11px;border-radius:6px;border:1px solid var(--c,var(--gold));color:var(--c,var(--gold));}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:9px;margin-bottom:16px;}
.stat-tile{background:var(--card);border:1px solid var(--bord);border-radius:10px;padding:12px 14px;position:relative;overflow:hidden;}
.stat-tile::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--tc,var(--violet));}
.stat-n{display:block;font-family:var(--mono);font-size:20px;font-weight:800;}
.stat-l{font-size:10.5px;color:var(--mut2);}
.stat-delta{font-size:10px;color:var(--red);font-family:var(--mono);}

.tabs{display:flex;gap:3px;overflow-x:auto;border-bottom:1px solid var(--bord);margin-bottom:18px;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{font-family:inherit;padding:9px 14px;border-radius:8px 8px 0 0;cursor:pointer;font-size:12px;font-weight:600;white-space:nowrap;background:transparent;color:var(--mut2);border:1px solid transparent;border-bottom:none;margin-bottom:-1px;transition:all .15s;}
.tab:hover{color:var(--txt);}
.tab.act{background:var(--card);border-color:var(--bord);color:var(--violet);}
.tabpanel{display:none;}
.tabpanel.act{display:block;}

.card{background:var(--card);border:1px solid var(--bord);border-radius:12px;padding:16px 18px;margin-bottom:12px;}
.card-v{border-color:rgba(155,110,255,.25);background:linear-gradient(135deg,rgba(155,110,255,.06),var(--card));}
.card-t{border-color:rgba(47,208,199,.22);background:linear-gradient(135deg,rgba(47,208,199,.05),var(--card));}
.card-g{border-color:rgba(74,222,128,.2);background:linear-gradient(135deg,rgba(74,222,128,.05),var(--card));}
.card-r{border-color:rgba(255,75,46,.2);background:linear-gradient(135deg,rgba(255,75,46,.05),var(--card));}
.g2{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:12px;}
.g3{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;}
.sec-label{font-family:var(--mono);font-size:10px;letter-spacing:1.5px;color:var(--mut2);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:7px;}
.sec-label::after{content:'';flex:1;height:1px;background:var(--bord);}

.narrative{font-size:14px;background:var(--card);border:1px solid var(--bord);border-left:3px solid var(--violet);border-radius:12px;padding:16px 18px;margin-bottom:16px;line-height:1.75;}
.narrative b{color:var(--gold);}
.hot-list{display:flex;flex-direction:column;gap:8px;}
.hot-card{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--bord);border-left:4px solid var(--tc);border-radius:10px;padding:11px 15px;cursor:pointer;transition:all .12s;}
.hot-card:hover{transform:translateX(3px);background:var(--card2);}
.hot-rank{font-family:var(--mono);font-size:11px;color:var(--mut2);width:24px;flex-shrink:0;}
.hot-icon{font-size:19px;flex-shrink:0;}
.hot-body{flex:1;min-width:0;}
.hot-name{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.hot-typ{font-size:10.5px;color:var(--mut2);margin-bottom:4px;font-family:var(--mono);}
.hot-bar-wrap{height:4px;background:var(--card2);border-radius:99px;overflow:hidden;}
.hot-bar{height:100%;border-radius:99px;}
.hot-scores{display:flex;flex-direction:column;align-items:flex-end;gap:1px;flex-shrink:0;}
.score-badge{font-family:var(--mono);font-size:11px;font-weight:800;}

/* Map Mission Control Layout */
.map-mission-wrap{display:flex;height:calc(100vh - 210px);min-height:640px;border-radius:12px;overflow:hidden;border:1px solid var(--bord);margin-bottom:14px;position:relative;}
.map-left-panel{width:252px;flex-shrink:0;background:rgba(8,6,10,.97);border-right:1px solid var(--bord);overflow-y:auto;z-index:200;display:flex;flex-direction:column;scrollbar-width:thin;scrollbar-color:var(--bord) transparent;}
.map-left-panel::-webkit-scrollbar{width:3px;}
.map-left-panel::-webkit-scrollbar-thumb{background:var(--bord2);border-radius:2px;}
.mlp-hdr{padding:13px 13px 9px;border-bottom:1px solid var(--bord);flex-shrink:0;}
.mlp-city{font-size:13px;font-weight:800;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mlp-tag{font-family:var(--mono);font-size:8.5px;letter-spacing:2px;color:var(--violet);text-transform:uppercase;margin-top:2px;}
.mlp-sec{font-family:var(--mono);font-size:8.5px;letter-spacing:1.5px;color:var(--mut2);text-transform:uppercase;padding:9px 13px 5px;border-top:1px solid rgba(255,255,255,.05);flex-shrink:0;}
.mlp-stats{display:grid;grid-template-columns:1fr 1fr;gap:5px;padding:9px 11px;flex-shrink:0;}
.mlp-stat{background:var(--card2);border:1px solid var(--bord);border-radius:7px;padding:6px 8px;}
.mlp-stat-v{display:block;font-family:var(--mono);font-size:13px;font-weight:900;color:var(--gold);}
.mlp-stat-l{font-size:8.5px;color:var(--mut2);}
.mlp-base-group{display:flex;flex-direction:column;gap:3px;padding:5px 11px;flex-shrink:0;}
.mlp-base-btn{font-family:inherit;font-size:11px;font-weight:600;padding:6px 10px;border-radius:6px;border:1px solid var(--bord);background:transparent;color:var(--mut);cursor:pointer;text-align:left;transition:all .15s;}
.mlp-base-btn:hover{color:var(--txt);border-color:var(--bord2);}
.mlp-base-btn.act{background:rgba(155,110,255,.15);border-color:var(--violet);color:var(--violet);}
.mlp-intel-layers{display:flex;flex-direction:column;gap:0;padding:5px 11px 9px;flex-shrink:0;}
.mlp-layer-row{display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.mlp-layer-row:last-child{border:none;}
.mlp-layer-lbl{font-size:11px;color:var(--mut);display:flex;align-items:center;gap:6px;}
.mlp-layer-lbl span{font-size:12px;}
.toggle-sw{position:relative;width:30px;height:16px;flex-shrink:0;}
.toggle-sw input{opacity:0;width:0;height:0;position:absolute;}
.toggle-sw .slider{position:absolute;inset:0;background:var(--card2);border:1px solid var(--bord);border-radius:99px;cursor:pointer;transition:.2s;}
.toggle-sw .slider::before{content:'';position:absolute;height:10px;width:10px;left:2px;top:2px;background:var(--mut2);border-radius:50%;transition:.2s;}
.toggle-sw input:checked+.slider{background:rgba(155,110,255,.22);border-color:var(--violet);}
.toggle-sw input:checked+.slider::before{transform:translateX(14px);background:var(--violet);}
.map-hstp{width:0;flex-shrink:0;overflow:hidden;transition:width .32s cubic-bezier(.4,0,.2,1);background:rgba(6,4,10,.98);border-left:1px solid transparent;z-index:300;display:flex;flex-direction:column;}
.map-hstp.open{width:360px;border-left-color:var(--bord);}
.hstp-inner{width:360px;height:100%;display:flex;flex-direction:column;overflow:hidden;}
.hstp-head{padding:13px 14px;border-bottom:1px solid var(--bord);display:flex;align-items:flex-start;justify-content:space-between;flex-shrink:0;}
.hstp-close{background:none;border:none;color:var(--mut);font-size:18px;cursor:pointer;line-height:1;padding:0 2px;font-family:inherit;}
.hstp-close:hover{color:var(--txt);}
.hstp-tabs{display:flex;gap:2px;padding:6px 8px;border-bottom:1px solid var(--bord);overflow-x:auto;flex-shrink:0;scrollbar-width:none;}
.hstp-tabs::-webkit-scrollbar{display:none;}
.hstp-tab{font-size:9.5px;font-weight:700;font-family:var(--mono);padding:4px 7px;border-radius:5px;cursor:pointer;color:var(--mut2);background:transparent;border:1px solid transparent;white-space:nowrap;}
.hstp-tab.act{background:rgba(155,110,255,.15);color:var(--violet);border-color:rgba(155,110,255,.3);}
.hstp-body{flex:1;overflow-y:auto;padding:11px 13px;scrollbar-width:thin;scrollbar-color:var(--bord) transparent;}
.hstp-body::-webkit-scrollbar{width:3px;}
.hstp-body::-webkit-scrollbar-thumb{background:var(--bord2);border-radius:2px;}
#mapContainer{flex:1;position:relative;overflow:hidden;}
#cityMap{width:100%;height:100%;}
.map-top-bar{position:absolute;top:11px;left:50%;transform:translateX(-50%);z-index:1000;display:flex;gap:7px;align-items:center;}
.map-search-inp{background:rgba(8,6,10,.92);border:1px solid var(--bord2);color:var(--txt);border-radius:8px;padding:7px 13px;font-size:12px;font-family:inherit;width:270px;backdrop-filter:blur(12px);transition:border-color .15s,box-shadow .15s;}
.map-search-inp:focus{outline:none;border-color:var(--violet);box-shadow:0 0 0 3px rgba(155,110,255,.14);}
.map-search-inp::placeholder{color:var(--mut2);}
.map-legend-panel{position:absolute;bottom:28px;left:11px;z-index:1000;background:rgba(8,6,10,.9);border:1px solid var(--bord2);border-radius:9px;padding:9px 11px;backdrop-filter:blur(8px);max-width:170px;}
.map-legend-title{font-family:var(--mono);font-size:8px;letter-spacing:1.5px;color:var(--violet);text-transform:uppercase;margin-bottom:5px;}
.map-legend-item{display:flex;align-items:center;gap:6px;margin-bottom:2px;font-size:9.5px;color:var(--mut);}
.map-legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.map-data-src{position:absolute;bottom:8px;right:8px;z-index:1000;font-size:9px;color:rgba(255,255,255,.28);background:rgba(0,0,0,.35);padding:2px 6px;border-radius:4px;font-family:var(--mono);}
.surya-vision-panel{position:absolute;top:50px;right:11px;z-index:1000;background:rgba(8,6,10,.94);border:1px solid var(--bord2);border-radius:10px;padding:10px 12px;font-size:10.5px;min-width:200px;backdrop-filter:blur(8px);display:none;pointer-events:none;}
.vision-title{font-family:var(--mono);font-size:8px;letter-spacing:1.5px;color:var(--violet);margin-bottom:6px;text-transform:uppercase;}
.vision-row{display:flex;justify-content:space-between;margin-bottom:3px;border-bottom:1px solid rgba(255,255,255,.05);padding-bottom:3px;}
.vision-row:last-child{border:none;margin:0;padding:0;}
.vision-val{font-family:var(--mono);font-weight:700;}
@keyframes smpulse{0%{transform:translate(-50%,-50%) scale(.5);opacity:.55;}100%{transform:translate(-50%,-50%) scale(2.6);opacity:0;}}
@keyframes smpulse2{0%{transform:translate(-50%,-50%) scale(.5);opacity:.35;}100%{transform:translate(-50%,-50%) scale(2.1);opacity:0;}}
.surya-marker{position:relative;cursor:pointer;}
.sm-pulse{position:absolute;top:50%;left:50%;width:22px;height:22px;border-radius:50%;background:var(--mc,#FF4B2E);animation:smpulse 2.4s ease-out infinite;pointer-events:none;}
.sm-pulse2{position:absolute;top:50%;left:50%;width:22px;height:22px;border-radius:50%;background:var(--mc,#FF4B2E);animation:smpulse2 2.4s ease-out 1.2s infinite;pointer-events:none;}
.sm-dot{position:relative;z-index:1;width:22px;height:22px;border-radius:50%;background:var(--mc,#FF4B2E);border:2px solid rgba(255,255,255,.85);box-shadow:0 0 16px var(--mc,#FF4B2E),0 0 6px rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;}
.sm-rank{font-family:var(--mono);font-size:9px;font-weight:900;color:#fff;line-height:1;}
.map-zone-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:8px;margin-top:10px;}
.mzg-card{background:var(--card);border:1px solid var(--bord);border-left:3px solid var(--tc);border-radius:9px;padding:10px 12px;cursor:pointer;transition:all .12s;}
.mzg-card:hover{background:var(--card2);transform:translateY(-1px);}
.mzg-name{font-size:11.5px;font-weight:700;margin-bottom:2px;}
.mzg-meta{font-family:var(--mono);font-size:10px;color:var(--mut);}
@media(max-width:900px){.map-left-panel{width:200px;}.map-hstp.open{width:290px;}.hstp-inner{width:290px;}}
@media(max-width:640px){.map-mission-wrap{flex-direction:column;height:auto;min-height:auto;}.map-left-panel{width:100%;max-height:200px;flex-direction:row;overflow-x:auto;}.map-hstp.open{width:100%;}.hstp-inner{width:100%;}#mapContainer{height:400px;}}
.leaflet-tooltip-dark{background:rgba(8,6,14,.96)!important;border:1px solid var(--bord2)!important;color:var(--txt)!important;font-family:inherit;font-size:11px;box-shadow:0 2px 12px rgba(0,0,0,.7)!important;border-radius:6px!important;padding:5px 9px!important;}
.leaflet-tooltip-dark::before{border-top-color:var(--bord2)!important;}

.deepdive-layout{display:flex;gap:16px;align-items:flex-start;}
