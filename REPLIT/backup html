  const avgLST=r1(CURRENT_ZONES.reduce((s,z)=>s+z.lstPeak,0)/CURRENT_ZONES.length);
  updateScenarioDetail(id,avgLST,CURRENT_ZONES);
}
function updateScenarioDetail(id,avgLST,zones){
