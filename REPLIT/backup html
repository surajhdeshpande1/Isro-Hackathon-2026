}

function copilotSend(preset){
  const input=document.getElementById('copilotInput');
  const msgs=document.getElementById('copilotMsgs');
  if(!msgs) return;
  const q=preset||(input?input.value.trim():'');
  if(!q) return;
  if(input) input.value='';
  const userDiv=document.createElement('div');
  userDiv.className='msg msg-user';
  userDiv.innerHTML=`<div class="msg-avatar user">👤</div><div class="msg-bubble user">${esc(q)}</div>`;
  msgs.appendChild(userDiv);
  msgs.scrollTop=msgs.scrollHeight;
  const thinkDiv=document.createElement('div');
  thinkDiv.className='msg';
  thinkDiv.innerHTML=`<div class="msg-avatar surya">☉</div><div class="msg-bubble surya" style="color:var(--mut)">Processing through SURYA CORE engines…</div>`;
  msgs.appendChild(thinkDiv);
  msgs.scrollTop=msgs.scrollHeight;
  setTimeout(()=>{
    thinkDiv.querySelector('.msg-bubble').innerHTML=copilotAnswer(q);
    msgs.scrollTop=msgs.scrollHeight;
  },600+Math.random()*500);
}

