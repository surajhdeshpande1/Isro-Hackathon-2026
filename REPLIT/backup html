/* ---- Forecast ---- */
function renderForecast(forecast,zones,meta){
  const bauPts=forecast.map(p=>({x:p.yr,y:p.bauLST}));
  const withPts=forecast.map(p=>({x:p.yr,y:p.withLST}));
  const chart=svgLineChart([
    {points:bauPts,color:'#FF4B2E',fill:true},
    {points:withPts,color:'#2FD0C7',fill:true}
  ],{width:700,height:240,yFmt:v=>v.toFixed(1)+'°',xFmt:v=>`${v}`});
  const rows=forecast.map(p=>`<tr>
    <td>${p.yr}</td>
    <td class="bad">${p.bauLST}°C</td>
    <td class="${p.withLST<p.bauLST?'good':'bad'}">${p.withLST}°C</td>
    <td class="${p.dT<0?'good':'bad'}">${p.dT.toFixed(1)}°C</td>
    <td>${p.vegCov.toFixed(1)}%</td>
    <td class="${p.infraStress>70?'bad':p.infraStress>50?'warn':'good'}">${p.infraStress}/100</td>
    <td class="bad">₹${p.ecoLoss.toFixed(0)}L</td>
  </tr>`).join('');
  const last=forecast[forecast.length-1];
  const first=forecast[0];
  document.getElementById('panel-forecast').innerHTML=`
    <div class="sec-label">20-Year Land Surface Temperature Forecast</div>
    <div class="chart-card">
      ${chart}
      <div class="legend">
        <span><i style="background:#FF4B2E"></i> Business As Usual</span>
        <span><i style="background:#2FD0C7"></i> With Interventions</span>
      </div>
    </div>
    <div style="margin-top:14px">
      <div class="sec-label">Full Forecast Table — 2025 to 2050</div>
