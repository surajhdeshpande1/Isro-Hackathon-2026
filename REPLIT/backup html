function showVision(latlng,zones,center){
  const vp=document.getElementById('visionPanel');
  const vc=document.getElementById('visionContent');
  if(!vp||!vc) return;
  let nearest=zones[0],minD=999;
  zones.forEach(z=>{
    const d=Math.hypot(latlng.lat-(center[0]+z.latOff),latlng.lng-(center[1]+z.lngOff));
    if(d<minD){minD=d;nearest=z;}
  });
  const frac=clamp(1-minD*9,0,1);
  const temp=r1(nearest.lstPeak*frac+nearest.lstLow*(1-frac));
  const heatRisk=Math.round(nearest.uhsi*frac+30*(1-frac));
  const typ=TYPOLOGIES[nearest.typology];
  vp.style.display='block';
  vc.innerHTML=`
    <div class="vision-row"><span>Zone</span><span class="vision-val" style="font-size:9px;color:${typ.color}">${esc(nearest.name.substring(0,18))}</span></div>
    <div class="vision-row"><span>Temperature</span><span class="vision-val" style="color:var(--red)">${temp}°C</span></div>
    <div class="vision-row"><span>Heat Risk</span><span class="vision-val">${heatRisk}/100</span></div>
    <div class="vision-row"><span>NDVI</span><span class="vision-val" style="color:var(--green)">${r2(nearest.ndvi*(0.7+frac*0.3))}</span></div>
    <div class="vision-row"><span>Impervious</span><span class="vision-val">${Math.round(nearest.imperviousPct*frac+20*(1-frac))}%</span></div>
    <div class="vision-row"><span>Cooling Pot.</span><span class="vision-val" style="color:var(--teal)">${nearest.interventionScore}/100</span></div>
    <div class="vision-row"><span>Vulnerability</span><span class="vision-val" style="color:var(--orange)">${Math.round(nearest.vulnerability*frac+20*(1-frac))}/100</span></div>`;
}

function switchLayer(type){
  if(!cityMap) return;
  ['mlpOSM','mlpSat','mlpHybrid'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.remove('act');});
  const activeId=type==='osm'?'mlpOSM':type==='sat'?'mlpSat':'mlpHybrid';
  const activeEl=document.getElementById(activeId);if(activeEl)activeEl.classList.add('act');
  if(type==='osm'){
    if(!cityMap.hasLayer(osmLayer))osmLayer.addTo(cityMap);
    if(cityMap.hasLayer(satLayer))cityMap.removeLayer(satLayer);
    if(cityMap._hybridLabels&&cityMap.hasLayer(cityMap._hybridLabels))cityMap.removeLayer(cityMap._hybridLabels);
  } else if(type==='sat'){
    if(!cityMap.hasLayer(satLayer))satLayer.addTo(cityMap);
    if(cityMap.hasLayer(osmLayer))cityMap.removeLayer(osmLayer);
    if(cityMap._hybridLabels&&cityMap.hasLayer(cityMap._hybridLabels))cityMap.removeLayer(cityMap._hybridLabels);
  } else {
    if(!cityMap.hasLayer(satLayer))satLayer.addTo(cityMap);
    if(cityMap.hasLayer(osmLayer))cityMap.removeLayer(osmLayer);
    if(cityMap._hybridLabels&&!cityMap.hasLayer(cityMap._hybridLabels))cityMap._hybridLabels.addTo(cityMap);
  }
}

function toggleLayer(layerName,visible){
  mapLayers[layerName]=visible;
  if(!cityMap) return;
  const groups={heat:heatLayerGroup,hotspots:hotspotsLayerGroup,water:waterLayerGroup,parks:parksLayerGroup,buildings:buildingsLayerGroup,poi:poiLayerGroup};
  const lg=groups[layerName];
  if(!lg) return;
  if(visible){if(!cityMap.hasLayer(lg))lg.addTo(cityMap);}
  else{if(cityMap.hasLayer(lg))cityMap.removeLayer(lg);}
}

