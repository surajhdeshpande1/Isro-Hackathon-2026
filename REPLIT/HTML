/* Map search */
async function mapSearch(query){
  if(!query||!query.trim()||!cityMap)return;
  const inp=document.getElementById('mcSearchInp');
  if(inp){inp.style.borderColor='var(--amber)';inp.disabled=true;}
  try{
    const url=`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query+', India')}&format=json&limit=1`;
    const res=await fetch(url,{headers:{'User-Agent':'TAPAS-SURYA-DRISHTI/3.0'}});
    const d=await res.json();
    if(d&&d[0]){
      cityMap.flyTo([parseFloat(d[0].lat),parseFloat(d[0].lon)],16,{duration:1.5});
      L.popup({closeButton:true}).setLatLng([parseFloat(d[0].lat),parseFloat(d[0].lon)])
        .setContent(`<b>${esc(d[0].display_name.split(',')[0])}</b><br><span style="font-size:10px;color:#64748B">${esc(d[0].display_name.substring(0,70))}…</span>`)
        .openOn(cityMap);
    }
  }catch(e){}
  if(inp){inp.disabled=false;setTimeout(()=>{inp.style.borderColor='';},1500);}
}

