async function startScan(query){
  if(!query||!query.trim())return;
  const q=query.trim();
  document.getElementById('landing').style.display='none';
  const loader=document.getElementById('loader');
  loader.classList.add('show');
  document.getElementById('loaderCity').textContent=q;
  const steps=['SEARCHING CITY','DIGITAL TWIN GENERATION','SATELLITE ACQUISITION','HEAT INTELLIGENCE SCAN','HOTSPOT CLASSIFICATION','DNA PROFILING','SCENARIO GENERATION (A–J)','15-PHASE VERIFICATION','FINANCIAL INTELLIGENCE','MISSION READY'];
  const bar=document.getElementById('loaderBar');
  for(let i=0;i<10;i++){
    document.getElementById('loaderPhase').textContent=steps[i];
    const el=document.getElementById('ls'+i);
    if(el){el.classList.remove('done');el.classList.add('active');}
    if(i>0){const prev=document.getElementById('ls'+(i-1));if(prev){prev.classList.remove('active');prev.classList.add('done');}}
    bar.style.width=((i+1)*10)+'%';
    await new Promise(r=>setTimeout(r,280+Math.random()*180));
  }
  let resolved=resolveCity(q);
  if(!resolved){
    resolved={key:'custom',display:q,pop:2e6,area:200,baselineLST:31,climate:'Hot semi-arid',coords:null};
    const coords=await geocodeCity(q);
    if(coords)resolved.coords=coords;
    else resolved.coords=[20.5937,78.9629];
  }
  CURRENT_ZONES=computeZones(resolved);
  CURRENT_FIN=computeFinancials(CURRENT_ZONES,resolved);
  CURRENT_FORECAST=computeForecast(CURRENT_ZONES,resolved);
  CURRENT_RESOLVED=resolved;
  loader.classList.remove('show');
  launchApp(resolved,CURRENT_ZONES);
}

