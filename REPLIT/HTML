async function fetchOSMLayers(center){
  try{
    const r=.09,bbox=`${center[0]-r},${center[1]-r},${center[0]+r},${center[1]+r}`;
    const q=`[out:json][timeout:22];(way["natural"="water"](${bbox});way["leisure"="park"](${bbox});way["landuse"~"^(park|forest|grass|recreation_ground)$"](${bbox});way["natural"~"^(wood|grassland)$"](${bbox}););out geom 600;`;
    const res=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q)});
    if(!res.ok)return;
    const d=await res.json();
    (d.elements||[]).forEach(el=>{
      if(!el.geometry||el.geometry.length<3)return;
      const coords=el.geometry.map(p=>[p.lat,p.lon]);
      const isWater=el.tags&&el.tags.natural==='water';
      const isForest=el.tags&&(el.tags.landuse==='forest'||el.tags.natural==='wood');
      const sty=isWater
        ?{color:'rgba(13,148,136,.55)',fillColor:'rgba(13,148,136,.16)',weight:1,fillOpacity:1,interactive:false}
        :isForest
        ?{color:'rgba(5,150,105,.4)',fillColor:'rgba(5,150,105,.12)',weight:.8,fillOpacity:1,interactive:false}
        :{color:'rgba(22,163,74,.4)',fillColor:'rgba(22,163,74,.1)',weight:.8,fillOpacity:1,interactive:false};
      L.polygon(coords,sty).addTo(isWater?waterLG:parksLG);
    });
  }catch(e){}
  try{
    const rb=.07,bbox2=`${center[0]-rb},${center[1]-rb},${center[0]+rb},${center[1]+rb}`;
    const q2=`[out:json][timeout:16];(way["building"~"^(commercial|industrial|hospital|school|university|government|civic|office|retail|warehouse|manufacture)$"](${bbox2}););out geom 120;`;
    const res2=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q2)});
    if(!res2.ok)return;
    const d2=await res2.json();
    (d2.elements||[]).forEach(el=>{
      if(!el.geometry||el.geometry.length<3)return;
      const coords=el.geometry.map(p=>[p.lat,p.lon]);
      const bt=el.tags&&el.tags.building;
      const col=bt==='industrial'||bt==='warehouse'?'rgba(234,88,12,.4)':bt==='hospital'?'rgba(220,38,38,.4)':'rgba(124,58,237,.28)';
      L.polygon(coords,{color:col,fillColor:col,fillOpacity:.22,weight:.7,interactive:false}).addTo(buildingsLG);
    });
  }catch(e){}
  try{
    const rp=.08,bbox3=`${center[0]-rp},${center[1]-rp},${center[0]+rp},${center[1]+rp}`;
    const q3=`[out:json][timeout:14];(node["amenity"~"^(hospital|school|university|college|bus_station|railway_station|marketplace)$"](${bbox3}););out 60;`;
    const res3=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q3)});
    if(!res3.ok)return;
    const d3=await res3.json();
    (d3.elements||[]).forEach(el=>{
      if(!el.lat||!el.lon)return;
      const am=el.tags&&el.tags.amenity||'';
      const ico=am==='hospital'?'🏥':am.includes('school')||am.includes('university')||am.includes('college')?'🏫':am.includes('station')?'🚉':am==='marketplace'?'🛒':'📍';
      const nm=(el.tags&&el.tags.name)||am;
      L.marker([el.lat,el.lon],{icon:L.divIcon({className:'',html:`<div style="font-size:14px;filter:drop-shadow(0 1px 3px rgba(0,0,0,.4))">${ico}</div>`,iconSize:[16,16],iconAnchor:[8,8]}),zIndexOffset:-200})
        .bindTooltip(`<b>${esc(nm)}</b>`,{className:'warm-tt',direction:'top',offset:[0,-6]})
        .addTo(poiLG);
    });
  }catch(e){}
}

