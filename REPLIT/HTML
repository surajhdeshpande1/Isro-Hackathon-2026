   ============================================================ */
function resolveCity(query){
  const q=query.trim().toLowerCase();
  for(const k of CITY_KEYS){
    if(k===q||CITIES[k].display.toLowerCase()===q)return{key:k,...CITIES[k]};
  }
  for(const k of CITY_KEYS){
    if(k.includes(q)||CITIES[k].display.toLowerCase().includes(q))return{key:k,...CITIES[k]};
  }
  return null;
}
async function geocodeCity(name){
  try{
    const r=await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(name+', India')}&format=json&limit=1`,{headers:{'User-Agent':'TAPAS-SURYA-DRISHTI/3.0'}});
    const d=await r.json();
    if(d&&d[0])return[parseFloat(d[0].lat),parseFloat(d[0].lon)];
  }catch(e){}
  return null;
}

/* ============================================================
   ZONE GENERATION
   ============================================================ */
function computeZones(resolved){
  const rng=rngFor(resolved.display+'_zones_v2');
  const num=6;
  const zones=[];
  const typOrder=TYPO_ORDER.slice().sort(()=>rng()-.5);
  const nameFrags=['Central','North','South','East','West','Old','New','Upper','Lower','Industrial','Market','Lake','Rail','Highway','Tech'];
  for(let i=0;i<num;i++){
    const typ=typOrder[i]||TYPO_ORDER[i%6];
    const T=TYPOLOGIES[typ];
    const amp=T.ampRange[0]+(T.ampRange[1]-T.ampRange[0])*rng();
    const lstPeak=r1(resolved.baselineLST+amp*(0.8+rng()*.4));
    const lstLow=r1(resolved.baselineLST-1.5+rng()*1.5);
    const uhsi=Math.round(45+rng()*50);
    const sev=uhsi>=88?{label:'CRITICAL',color:'#DC2626'}:uhsi>=76?{label:'SEVERE',color:'#EA580C'}:uhsi>=64?{label:'HIGH',color:'#F59E0B'}:uhsi>=52?{label:'MODERATE',color:'#D97706'}:{label:'EMERGING',color:'#0D9488'};
    const areaKm2=r1(1.2+rng()*12);
    const pop=Math.round((80000+rng()*400000)*Math.max(.5,areaKm2/5));
    const ndvi=r2(.04+rng()*.28);
    const imperviousPct=Math.round(55+rng()*38);
    const n1=nameFrags[Math.floor(rng()*nameFrags.length)];
    const n2=nameFrags[Math.floor(rng()*nameFrags.length)];
    const name=`${n1} ${n2} Zone`;
    const dna={veg:Math.round(15+rng()*40),building:Math.round(10+rng()*30),road:Math.round(8+rng()*20),traffic:Math.round(5+rng()*20),industry:Math.round(3+rng()*25),water:Math.round(3+rng()*15)};
    const tot=Object.values(dna).reduce((a,b)=>a+b,0);
    Object.keys(dna).forEach(k=>dna[k]=Math.round(dna[k]/tot*100));
    zones.push({
      rank:i+1,name,typology:typ,lstPeak,lstLow,uhsi,sevInfo:sev,areaKm2,pop,ndvi,imperviousPct,
      dna,evidence:Math.round(70+rng()*28),confidence:Math.round(72+rng()*26),
      resilience:Math.round(20+rng()*55),vulnerability:Math.round(40+rng()*50),
      interventionScore:Math.round(50+rng()*45),
      latOff:(rng()-.5)*.045,lngOff:(rng()-.5)*.055,
      narrative:`SURYA CORE identified <b>${name}</b> as a ${T.short.toLowerCase()} heat island running <b>${lstPeak}°C</b> at peak — <b>${r1(lstPeak-resolved.baselineLST)}°C above</b> the rural baseline. ${T.mech(name)} Impervious surface coverage stands at ${imperviousPct}%, NDVI at ${ndvi} — well below the 0.35 healthy urban threshold.`,
    });
  }
  zones.sort((a,b)=>b.uhsi-a.uhsi);
  zones.forEach((z,i)=>z.rank=i+1);
  return zones;
}

function computeFinancials(zones,meta){
  const totalCapex=zones.reduce((s,z)=>s+Math.round(z.areaKm2*z.uhsi*22),0);
  const totalBen=Math.round(totalCapex*2.6);
  const avgROI=r1(zones.reduce((s,z)=>s+(14+z.interventionScore*.08),0)/zones.length);
  const avgPB=r1(zones.reduce((s,z)=>s+Math.max(4,8.5-z.resilience*.04),0)/zones.length);
  return{totalCapex,totalBen,avgROI,avgPB,npv20:Math.round(totalBen*1.8),irr:r1(avgROI+2.1),cbr:r1(totalBen/totalCapex)};
}

function computeForecast(zones,meta){
  const rng=rngFor(meta.display+'_fc');
  const base=meta.baselineLST;
  return [2026,2030,2035,2040,2045,2050].map(yr=>{
    const yrs=yr-2026;
    return{yr,
      bau:r1(base+yrs*.22+rng()*.15),
      mod:r1(base+yrs*.12-yrs*.04+rng()*.1),
      agg:r1(base-yrs*.06+rng()*.08),
      exposed:Math.round(zones.reduce((s,z)=>s+z.pop,0)*(1+yrs*.02)),
    };
  });
}

