/* Layer switching */
function switchLayer(type){
  if(!cityMap)return;
  ['mbl-street','mbl-sat','mbl-hybrid'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.remove('act');});
  const aid=type==='street'?'mbl-street':type==='sat'?'mbl-sat':'mbl-hybrid';
  const ael=document.getElementById(aid);if(ael)ael.classList.add('act');
  if(type==='street'){
    if(!cityMap.hasLayer(osmLayer))osmLayer.addTo(cityMap);
    if(cityMap.hasLayer(satLayer))cityMap.removeLayer(satLayer);
    if(cityMap._hybridLabels&&cityMap.hasLayer(cityMap._hybridLabels))cityMap.removeLayer(cityMap._hybridLabels);
  }else if(type==='sat'){
    if(!cityMap.hasLayer(satLayer))satLayer.addTo(cityMap);
    if(cityMap.hasLayer(osmLayer))cityMap.removeLayer(osmLayer);
    if(cityMap._hybridLabels&&cityMap.hasLayer(cityMap._hybridLabels))cityMap.removeLayer(cityMap._hybridLabels);
  }else{
    if(!cityMap.hasLayer(satLayer))satLayer.addTo(cityMap);
    if(cityMap.hasLayer(osmLayer))cityMap.removeLayer(osmLayer);
    if(cityMap._hybridLabels&&!cityMap.hasLayer(cityMap._hybridLabels))cityMap._hybridLabels.addTo(cityMap);
  }
}

function toggleLayer(name,vis){
  mapLayers[name]=vis;
  if(!cityMap)return;
  const groups={heat:heatLG,hotspots:hotspotLG,water:waterLG,parks:parksLG,buildings:buildingsLG,poi:poiLG};
  const lg=groups[name];
  if(!lg)return;
  if(vis){if(!cityMap.hasLayer(lg))lg.addTo(cityMap);}
  else{if(cityMap.hasLayer(lg))cityMap.removeLayer(lg);}
}

/* Vision panel */
function showVision(latlng,zones,center){
  const vp=document.getElementById('visionPanel'),vc=document.getElementById('visionContent');
  if(!vp||!vc)return;
  let nearest=zones[0],minD=999;
  zones.forEach(z=>{
    const d=Math.hypot(latlng.lat-(center[0]+z.latOff),latlng.lng-(center[1]+z.lngOff));
    if(d<minD){minD=d;nearest=z;}
  });
  const frac=clamp(1-minD*9,0,1);
  const temp=r1(nearest.lstPeak*frac+nearest.lstLow*(1-frac));
  vp.style.display='block';
  vc.innerHTML=`
    <div class="vision-row"><span>Zone</span><span class="vision-val" style="font-size:9px;color:${TYPOLOGIES[nearest.typology].color}">${esc(nearest.name.substring(0,20))}</span></div>
