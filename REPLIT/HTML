.lab-chip.act{background:rgba(245,158,11,.06);border-color:var(--amber);}
.lab-chip-name{font-size:11px;font-weight:600;color:var(--slate);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.lab-chip-uhsi{font-family:var(--mono);font-size:12px;font-weight:800;color:var(--amber);}
.lab-detail{flex:1;min-width:0;}
.lab-zone-head{background:var(--white);border:1px solid var(--border);border-top:3px solid var(--hc,var(--amber));border-radius:12px;padding:20px;margin-bottom:14px;box-shadow:var(--shadow);}
.lab-zone-title{font-family:var(--head);font-size:18px;font-weight:800;color:var(--slate);margin-bottom:4px;}
.lab-zone-type{font-size:11px;color:var(--mid);font-weight:500;margin-bottom:14px;}
.score-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:8px;margin-bottom:14px;}
.score-tile{background:var(--sand);border:1px solid var(--border);border-radius:8px;padding:10px 11px;text-align:center;}
.score-val{font-family:var(--mono);font-size:18px;font-weight:900;display:block;color:var(--slate);}
.score-lbl{font-size:9.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
.mech-box{background:rgba(245,158,11,.05);border:1px solid rgba(245,158,11,.18);border-radius:8px;padding:12px 14px;font-size:12.5px;color:var(--graphite);line-height:1.7;}
.dna-bars{margin-top:12px;}
.dna-row{display:flex;align-items:center;gap:10px;margin-bottom:7px;}
.dna-lbl{font-size:11px;color:var(--mid);width:130px;flex-shrink:0;}
.dna-track{flex:1;height:7px;background:var(--sand);border-radius:99px;overflow:hidden;}
.dna-fill{height:100%;border-radius:99px;}
.dna-pct{font-family:var(--mono);font-size:11px;font-weight:700;width:34px;text-align:right;flex-shrink:0;color:var(--slate);}

/* ── SCENARIOS ── */
.scen-wrap{flex:1;overflow-y:auto;padding:24px;}
.scen-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:12px;margin-bottom:24px;}
.scen-card{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:18px 20px;cursor:pointer;transition:all .16s;box-shadow:var(--shadow);}
.scen-card:hover{transform:translateY(-2px);box-shadow:var(--shadow2);}
.scen-card.sel{border-color:var(--amber);background:rgba(245,158,11,.04);}
.scen-letter{font-family:var(--mono);font-size:10px;letter-spacing:1.5px;color:var(--amber);font-weight:700;margin-bottom:6px;}
.scen-name{font-family:var(--head);font-size:14px;font-weight:800;color:var(--slate);margin-bottom:4px;}
.scen-desc{font-size:11.5px;color:var(--mid);margin-bottom:12px;line-height:1.6;}
.scen-dt{font-family:var(--head);font-size:22px;font-weight:900;color:var(--amber);margin-bottom:10px;}
.scen-pills{display:flex;gap:5px;flex-wrap:wrap;}
.scen-pill{font-size:10px;font-weight:600;padding:3px 8px;border-radius:99px;background:var(--sand);border:1px solid var(--border);color:var(--graphite);}
.scen-detail{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:22px;box-shadow:var(--shadow);}
.scen-detail-title{font-family:var(--head);font-size:16px;font-weight:800;margin-bottom:14px;color:var(--slate);}
.ver-phase{margin-bottom:16px;padding:14px 16px;background:var(--sand);border:1px solid var(--border);border-radius:9px;}
.ver-phase-title{font-size:12px;font-weight:700;color:var(--slate);margin-bottom:4px;display:flex;align-items:center;gap:7px;}
.ver-badge{font-size:9.5px;font-family:var(--mono);font-weight:700;padding:2px 7px;border-radius:99px;}
.ver-badge.pass{background:rgba(5,150,105,.1);color:var(--green);}
.ver-badge.warn{background:rgba(245,158,11,.1);color:var(--amber);}
.ver-badge.fail{background:rgba(220,38,38,.1);color:var(--crimson);}
.ver-phase-text{font-size:11.5px;color:var(--mid);line-height:1.6;}

/* ── FINANCIAL ── */
.fin-wrap{flex:1;overflow-y:auto;padding:24px;}
.fin-top{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px;}
.fin-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:18px 20px;box-shadow:var(--shadow);}
.fin-label{font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:6px;font-weight:600;}
.fin-value{font-family:var(--head);font-size:26px;font-weight:900;color:var(--slate);margin-bottom:3px;}
.fin-sub{font-size:11px;color:var(--muted);}
.fin-breakdown{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:var(--shadow);}
.fin-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);}
.fin-row:last-child{border:none;}
.fin-row-label{font-size:12.5px;color:var(--graphite);}
.fin-row-val{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--slate);}
.fin-row-val.pos{color:var(--green);}
.fin-assumptions{background:rgba(245,158,11,.05);border:1px solid rgba(245,158,11,.18);border-radius:10px;padding:14px 16px;font-size:12px;color:var(--graphite);line-height:1.7;}

/* ── ROADMAP ── */
.road-wrap{flex:1;overflow-y:auto;padding:24px;}
.road-timeline{display:flex;flex-direction:column;gap:0;}
.road-phase{display:flex;gap:16px;position:relative;}
.road-phase::before{content:'';position:absolute;left:22px;top:44px;bottom:-16px;width:1px;background:var(--border);}
.road-phase:last-child::before{display:none;}
.road-icon-wrap{flex-shrink:0;width:44px;display:flex;flex-direction:column;align-items:center;padding-top:4px;}
.road-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;border:2px solid var(--border);background:var(--white);}
.road-content{flex:1;padding-bottom:24px;}
.road-content-inner{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:16px 18px;box-shadow:var(--shadow);}
.road-window{font-family:var(--mono);font-size:10px;letter-spacing:1px;color:var(--amber);font-weight:700;margin-bottom:4px;}
.road-title{font-family:var(--head);font-size:15px;font-weight:800;color:var(--slate);margin-bottom:8px;}
.road-items{display:flex;flex-direction:column;gap:5px;margin-bottom:10px;}
.road-item{display:flex;align-items:flex-start;gap:7px;font-size:12px;color:var(--graphite);}
.road-item::before{content:'›';color:var(--amber);flex-shrink:0;margin-top:1px;}
.road-budget{display:inline-flex;align-items:center;gap:6px;background:var(--sand);border:1px solid var(--border);border-radius:7px;padding:5px 11px;font-size:11px;font-weight:600;color:var(--slate);}

/* ── FORECAST ── */
.fc-wrap{flex:1;overflow-y:auto;padding:24px;}
.fc-scenarios{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:20px;}
.fc-scen-card{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:18px;cursor:pointer;transition:all .14s;box-shadow:var(--shadow);}
.fc-scen-card.sel{border-color:var(--amber);background:rgba(245,158,11,.04);}
.fc-scen-name{font-family:var(--head);font-size:14px;font-weight:800;margin-bottom:4px;color:var(--slate);}
.fc-scen-desc{font-size:11.5px;color:var(--mid);margin-bottom:10px;}
.fc-scen-temp{font-family:var(--head);font-size:20px;font-weight:900;color:var(--amber);}
.fc-timeline{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:20px;box-shadow:var(--shadow);}
.fc-year-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.fc-year-row:last-child{border:none;}
.fc-year{font-family:var(--mono);font-size:12px;font-weight:700;width:44px;flex-shrink:0;color:var(--slate);}
.fc-temp-val{font-family:var(--head);font-size:15px;font-weight:800;width:52px;flex-shrink:0;}
.fc-bar-track{flex:1;height:8px;background:var(--sand);border-radius:99px;overflow:hidden;}
.fc-bar-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--gold),var(--orange));}
.fc-risk{font-family:var(--mono);font-size:10px;font-weight:700;width:60px;text-align:right;flex-shrink:0;}

/* ── WATCH ── */
.watch-wrap{flex:1;overflow-y:auto;padding:24px;}
.watch-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;}
.watch-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:16px 18px;box-shadow:var(--shadow);}
.watch-icon{font-size:24px;margin-bottom:10px;}
.watch-title{font-family:var(--head);font-size:14px;font-weight:800;color:var(--slate);margin-bottom:5px;}
.watch-val{font-family:var(--mono);font-size:11px;color:var(--amber);font-weight:700;margin-bottom:8px;}
.watch-desc{font-size:11.5px;color:var(--mid);line-height:1.6;}

/* ── COPILOT ── */
.cop-wrap{flex:1;display:flex;flex-direction:column;padding:20px;gap:14px;}
.cop-msgs{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:14px;}
.cop-msg{max-width:80%;display:flex;gap:9px;align-items:flex-start;}
.cop-msg.user{flex-direction:row-reverse;align-self:flex-end;}
.cop-avatar{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;}
.cop-avatar.ai{background:linear-gradient(135deg,var(--gold),var(--amber));}
.cop-avatar.user{background:var(--slate);}
.cop-bubble{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:11px 14px;font-size:12.5px;color:var(--slate);line-height:1.7;box-shadow:var(--shadow);}
.cop-bubble.user{background:var(--slate);color:#fff;border:none;}
.cop-input-wrap{display:flex;gap:9px;align-items:center;}
.cop-inp{flex:1;background:var(--white);border:1.5px solid var(--border);border-radius:10px;padding:12px 15px;font-family:var(--body);font-size:13px;color:var(--slate);outline:none;transition:border-color .14s;}
.cop-inp:focus{border-color:var(--amber);}
.cop-send{background:linear-gradient(135deg,var(--gold),var(--amber));border:none;color:#fff;border-radius:9px;padding:12px 18px;cursor:pointer;font-weight:700;font-size:13px;font-family:var(--body);}

/* ── METHODOLOGY ── */
.meth-wrap{flex:1;overflow-y:auto;padding:24px;}
.meth-section{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:14px;box-shadow:var(--shadow);}
.meth-title{font-family:var(--head);font-size:15px;font-weight:800;color:var(--slate);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.meth-items{display:flex;flex-wrap:wrap;gap:7px;}
.meth-badge{font-size:11px;font-weight:600;padding:5px 11px;border-radius:7px;background:var(--sand);border:1px solid var(--border);color:var(--graphite);}

/* ── ZONE SUMMARY CARDS ── */
.zone-summary{padding:16px 24px;background:var(--pearl);flex-shrink:0;border-top:1px solid var(--border);}
.zone-card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;}
.zs-card{background:var(--white);border:1px solid var(--border);border-left:3px solid var(--hc,var(--amber));border-radius:9px;padding:10px 12px;cursor:pointer;transition:all .12s;box-shadow:var(--shadow);}
.zs-card:hover{transform:translateY(-1px);box-shadow:var(--shadow2);}
.zs-name{font-size:11px;font-weight:700;color:var(--slate);margin-bottom:2px;}
.zs-meta{font-family:var(--mono);font-size:9.5px;color:var(--muted);}

/* Shared utils */
.tag{display:inline-block;font-family:var(--mono);font-size:9.5px;font-weight:700;padding:3px 8px;border-radius:5px;letter-spacing:.5px;}
.tag-amber{background:rgba(245,158,11,.1);color:var(--amber);}
.tag-red{background:rgba(220,38,38,.08);color:var(--crimson);}
.tag-green{background:rgba(5,150,105,.08);color:var(--green);}
.tag-blue{background:rgba(37,99,235,.08);color:var(--blue);}
.map-data-src{position:absolute;bottom:6px;right:8px;z-index:400;font-size:9px;color:var(--muted);font-family:var(--mono);}
</style>
</head>
