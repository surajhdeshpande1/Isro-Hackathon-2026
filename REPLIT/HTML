<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>TAPAS · SURYA DRISHTI v3.0 — Urban Climate Intelligence OS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root {
  --gold:    #F59E0B;
  --amber:   #D97706;
  --orange:  #EA580C;
  --crimson: #DC2626;
  --solar:   #FBBF24;
  --warm:    #FDE68A;
  --cream:   #FFFBF0;
  --pearl:   #FAF8F4;
  --sand:    #F5F0E8;
  --ivory:   #FEF9F0;
  --slate:   #334155;
  --graphite:#475569;
  --mid:     #64748B;
  --muted:   #94A3B8;
  --light:   #CBD5E1;
  --border:  #E2D9C8;
  --border2: #D4C9B0;
  --white:   #FFFEF9;
  --card:    #FFFFFF;
  --card2:   #FAF8F4;
  --teal:    #0D9488;
  --green:   #059669;
  --blue:    #2563EB;
  --violet:  #7C3AED;
  --mono:    'JetBrains Mono', monospace;
  --body:    'Inter', sans-serif;
  --head:    'Manrope', sans-serif;
  --shadow:  0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.06);
  --shadow2: 0 4px 24px rgba(0,0,0,.10), 0 1px 4px rgba(0,0,0,.06);
  --shadow3: 0 8px 48px rgba(0,0,0,.14);
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:var(--body);background:var(--pearl);color:var(--slate);-webkit-font-smoothing:antialiased;}

/* ── TOPBAR ── */
.topbar{position:fixed;top:0;left:0;right:0;height:52px;background:rgba(255,253,249,.96);border-bottom:1px solid var(--border);backdrop-filter:blur(16px);z-index:9000;display:flex;align-items:center;padding:0 24px;gap:20px;}
.logo{display:flex;align-items:center;gap:9px;text-decoration:none;}
.logo-sun{width:28px;height:28px;border-radius:50%;background:radial-gradient(circle at 40% 40%,#FDE68A,#F59E0B,#D97706);box-shadow:0 0 18px rgba(245,158,11,.45);flex-shrink:0;}
.logo-text{font-family:var(--head);font-size:15px;font-weight:800;color:var(--slate);letter-spacing:-.3px;}
.logo-sub{font-size:11px;font-weight:500;color:var(--muted);letter-spacing:.5px;}
.topbar-sep{width:1px;height:24px;background:var(--border);flex-shrink:0;}
.topbar-city{flex:1;display:flex;align-items:center;gap:8px;}
#topCityBadge{display:none;align-items:center;gap:7px;background:var(--sand);border:1px solid var(--border2);border-radius:8px;padding:5px 12px;font-size:12px;font-weight:600;color:var(--slate);}
.city-badge-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 6px rgba(5,150,105,.5);flex-shrink:0;}
.topbar-actions{display:flex;align-items:center;gap:8px;margin-left:auto;}
.top-btn{display:flex;align-items:center;gap:6px;padding:6px 13px;border-radius:7px;font-size:12px;font-weight:600;font-family:var(--body);cursor:pointer;border:none;transition:all .15s;}
.top-btn-ghost{background:transparent;color:var(--graphite);border:1px solid var(--border);}
.top-btn-ghost:hover{background:var(--sand);border-color:var(--border2);}
.top-btn-primary{background:linear-gradient(135deg,var(--gold),var(--amber));color:#fff;box-shadow:0 2px 8px rgba(245,158,11,.3);}
.top-btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(245,158,11,.35);}
.surya-status{display:flex;align-items:center;gap:6px;font-size:11px;font-family:var(--mono);color:var(--muted);}
.surya-status-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse-dot 2s ease-in-out infinite;}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:.4;}}

/* ── LANDING ── */
#landing{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--ivory);overflow:hidden;position:relative;padding:80px 20px 40px;}
.land-bg{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.land-circle{position:absolute;border-radius:50%;filter:blur(70px);opacity:.35;}
.lc1{width:700px;height:700px;background:radial-gradient(circle,#FDE68A,#F59E0B,transparent 70%);top:-200px;left:50%;transform:translateX(-50%);}
.lc2{width:400px;height:400px;background:radial-gradient(circle,#FED7AA,transparent 70%);bottom:0;right:-100px;}
.lc3{width:300px;height:300px;background:radial-gradient(circle,#E0F2FE,transparent 70%);bottom:100px;left:-50px;}
.land-content{position:relative;z-index:1;text-align:center;max-width:780px;}
.land-eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:2.5px;color:var(--amber);text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;justify-content:center;gap:8px;}
.land-eyebrow::before,.land-eyebrow::after{content:'';height:1px;width:40px;background:var(--amber);opacity:.5;}
.land-hero{font-family:var(--head);font-size:clamp(36px,6vw,72px);font-weight:800;line-height:1.05;letter-spacing:-2px;color:var(--slate);margin-bottom:18px;}
.land-hero span{background:linear-gradient(135deg,#F59E0B,#EA580C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.land-sub{font-size:16px;color:var(--mid);line-height:1.7;max-width:560px;margin:0 auto 40px;}
.land-search-wrap{background:var(--white);border:1.5px solid var(--border);border-radius:16px;display:flex;align-items:center;overflow:hidden;box-shadow:var(--shadow2);max-width:600px;margin:0 auto 28px;}
.land-search-icon{padding:0 16px;color:var(--muted);font-size:18px;flex-shrink:0;}
#landSearch{flex:1;border:none;background:transparent;font-family:var(--body);font-size:15px;padding:16px 0;color:var(--slate);outline:none;}
#landSearch::placeholder{color:var(--light);}
.land-scan-btn{margin:6px;background:linear-gradient(135deg,var(--gold),var(--amber));border:none;color:#fff;font-family:var(--body);font-size:14px;font-weight:700;padding:11px 24px;border-radius:10px;cursor:pointer;white-space:nowrap;transition:all .15s;}
.land-scan-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(245,158,11,.4);}
.land-chips{display:flex;flex-wrap:wrap;gap:7px;justify-content:center;margin-bottom:48px;}
.land-chip{font-size:12px;font-weight:600;padding:6px 14px;border-radius:99px;background:var(--white);border:1px solid var(--border);color:var(--graphite);cursor:pointer;transition:all .14s;}
.land-chip:hover{border-color:var(--amber);color:var(--amber);background:rgba(245,158,11,.06);}
.land-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;max-width:680px;margin:0 auto;}
.land-metric{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:16px 20px;text-align:left;}
.land-metric-v{font-family:var(--head);font-size:26px;font-weight:800;color:var(--slate);margin-bottom:3px;}
.land-metric-l{font-size:11px;color:var(--muted);font-weight:500;}
.land-metric-v span{color:var(--amber);}
@media(max-width:640px){.land-metrics{grid-template-columns:repeat(2,1fr);}.land-hero{letter-spacing:-1px;}}

/* ── LOADING ── */
#loader{display:none;position:fixed;inset:0;background:var(--ivory);z-index:8000;flex-direction:column;align-items:center;justify-content:center;}
#loader.show{display:flex;}
.loader-sun{width:72px;height:72px;border-radius:50%;background:radial-gradient(circle at 40% 40%,#FDE68A,#F59E0B,#D97706);box-shadow:0 0 40px rgba(245,158,11,.5);margin-bottom:28px;animation:sun-pulse 2s ease-in-out infinite;}
@keyframes sun-pulse{0%,100%{transform:scale(1);box-shadow:0 0 40px rgba(245,158,11,.5);}50%{transform:scale(1.06);box-shadow:0 0 60px rgba(245,158,11,.7);}}
.loader-city{font-family:var(--head);font-size:24px;font-weight:800;color:var(--slate);margin-bottom:8px;}
.loader-phase{font-family:var(--mono);font-size:11px;letter-spacing:1.5px;color:var(--amber);text-transform:uppercase;margin-bottom:32px;transition:all .4s;}
.loader-steps{display:flex;flex-direction:column;gap:6px;width:360px;}
.ls-item{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--muted);transition:all .3s;}
.ls-item.done{color:var(--green);}
.ls-item.active{color:var(--amber);font-weight:600;}
.ls-dot{width:18px;height:18px;border-radius:50%;border:1.5px solid var(--light);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;transition:all .3s;}
.ls-item.done .ls-dot{background:var(--green);border-color:var(--green);color:#fff;}
.ls-item.active .ls-dot{background:var(--amber);border-color:var(--amber);color:#fff;animation:pulse-dot 1s ease-in-out infinite;}
.loader-bar-wrap{width:360px;height:3px;background:var(--border);border-radius:99px;margin-top:24px;overflow:hidden;}
.loader-bar{height:100%;background:linear-gradient(90deg,var(--gold),var(--amber));border-radius:99px;width:0%;transition:width .5s ease;}

/* ── APP ── */
#app{display:none;flex-direction:column;height:100vh;overflow:hidden;}
#app.show{display:flex;}

/* ── RESULT NAV ── */
.app-nav{flex-shrink:0;height:44px;background:var(--white);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:2px;overflow-x:auto;scrollbar-width:none;margin-top:52px;}
.app-nav::-webkit-scrollbar{display:none;}
.nav-tab{display:flex;align-items:center;gap:6px;padding:6px 14px;border-radius:7px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .15s;border:none;background:none;font-family:var(--body);}
.nav-tab:hover{color:var(--graphite);background:var(--sand);}
.nav-tab.act{color:var(--amber);background:rgba(245,158,11,.08);box-shadow:inset 0 -2px 0 var(--amber);}

/* ── TAB PANELS ── */
.tab-pnl{display:none;flex:1;overflow:hidden;}
.tab-pnl.act{display:flex;flex-direction:column;}

/* ── MISSION CONTROL (MAP) ── */
#mc-wrap{display:flex;height:100%;position:relative;}
#mc-map-area{flex:1;position:relative;overflow:hidden;}
#cityMap{width:100%;height:100%;}

/* Map overlays */
.mc-search-bar{position:absolute;top:14px;left:50%;transform:translateX(-50%);z-index:1000;display:flex;gap:8px;align-items:center;}
.mc-search-inp{background:rgba(255,253,249,.96);border:1.5px solid var(--border2);color:var(--slate);border-radius:10px;padding:9px 16px;font-size:13px;font-family:var(--body);width:300px;backdrop-filter:blur(12px);transition:all .15s;outline:none;}
.mc-search-inp:focus{border-color:var(--amber);box-shadow:0 0 0 3px rgba(245,158,11,.12);}
.mc-search-inp::placeholder{color:var(--light);}
.mc-search-btn{background:linear-gradient(135deg,var(--gold),var(--amber));border:none;color:#fff;font-size:13px;font-weight:700;padding:9px 18px;border-radius:9px;cursor:pointer;font-family:var(--body);}

/* Left floating panel */
#mc-left{position:absolute;top:14px;left:14px;bottom:14px;width:236px;z-index:500;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.mc-card{background:rgba(255,253,249,.95);border:1px solid var(--border);border-radius:12px;backdrop-filter:blur(14px);box-shadow:var(--shadow);pointer-events:all;overflow:hidden;}
.mc-card-hdr{padding:10px 13px;border-bottom:1px solid rgba(226,217,200,.6);display:flex;align-items:center;justify-content:space-between;}
.mc-card-title{font-size:9.5px;font-family:var(--mono);letter-spacing:1.5px;text-transform:uppercase;color:var(--amber);font-weight:700;}
.mc-city-name{font-family:var(--head);font-size:14px;font-weight:800;color:var(--slate);padding:11px 13px 4px;}
.mc-city-tag{font-size:10px;color:var(--muted);padding:0 13px 10px;font-weight:500;}
.mc-stats{display:grid;grid-template-columns:1fr 1fr;gap:6px;padding:10px 12px;}
.mc-stat{background:var(--sand);border-radius:8px;padding:7px 9px;}
.mc-stat-v{font-family:var(--head);font-size:15px;font-weight:800;color:var(--amber);display:block;}
.mc-stat-l{font-size:9px;color:var(--muted);font-weight:500;}
.mc-layers{padding:8px 12px 10px;}
.mc-layer-row{display:flex;align-items:center;justify-content:space-between;padding:4px 0;border-bottom:1px solid rgba(226,217,200,.4);}
.mc-layer-row:last-child{border:none;}
.mc-layer-lbl{font-size:11px;color:var(--graphite);display:flex;align-items:center;gap:6px;font-weight:500;}
.tog{position:relative;width:32px;height:17px;flex-shrink:0;}
.tog input{opacity:0;width:0;height:0;position:absolute;}
.tog .t{position:absolute;inset:0;background:var(--light);border-radius:99px;cursor:pointer;transition:.2s;}
.tog .t::before{content:'';position:absolute;height:11px;width:11px;left:3px;top:3px;background:white;border-radius:50%;transition:.2s;box-shadow:0 1px 3px rgba(0,0,0,.15);}
.tog input:checked+.t{background:var(--amber);}
.tog input:checked+.t::before{transform:translateX(15px);}
.mc-base-btns{padding:8px 12px 10px;display:flex;flex-direction:column;gap:5px;}
.mc-base-btn{font-family:var(--body);font-size:11px;font-weight:600;padding:7px 10px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--graphite);cursor:pointer;text-align:left;transition:all .14s;display:flex;align-items:center;gap:7px;}
.mc-base-btn:hover{border-color:var(--border2);background:var(--sand);}
.mc-base-btn.act{background:rgba(245,158,11,.1);border-color:var(--amber);color:var(--amber);}
.mc-hotspots{padding:8px 12px 10px;display:flex;flex-direction:column;gap:4px;}
.mc-hs-item{display:flex;align-items:center;gap:7px;padding:5px 6px;border-radius:7px;cursor:pointer;transition:all .14s;}
.mc-hs-item:hover{background:var(--sand);}
.mc-hs-item.act{background:rgba(245,158,11,.1);}
.mc-hs-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.mc-hs-name{font-size:10px;font-weight:600;color:var(--slate);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;}
.mc-hs-temp{font-family:var(--mono);font-size:9.5px;color:var(--muted);}

/* Right slide panel */
#mc-dossier{position:absolute;top:0;bottom:0;right:0;width:0;overflow:hidden;transition:width .32s cubic-bezier(.4,0,.2,1);z-index:600;background:rgba(255,253,249,.97);border-left:1px solid transparent;display:flex;flex-direction:column;}
#mc-dossier.open{width:380px;border-left-color:var(--border);}
.dos-inner{width:380px;height:100%;display:flex;flex-direction:column;}
.dos-head{padding:16px 16px 12px;border-bottom:1px solid var(--border);flex-shrink:0;}
.dos-zone-name{font-family:var(--head);font-size:15px;font-weight:800;color:var(--slate);margin-bottom:4px;}
.dos-zone-meta{font-size:11px;color:var(--muted);font-weight:500;}
.dos-close{position:absolute;top:12px;right:14px;background:var(--sand);border:1px solid var(--border);border-radius:6px;width:26px;height:26px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--graphite);font-size:12px;}
.dos-close:hover{background:var(--border);color:var(--slate);}
.dos-tabs{display:flex;gap:2px;padding:8px 10px;border-bottom:1px solid var(--border);overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
.dos-tabs::-webkit-scrollbar{display:none;}
.dos-tab{font-size:10px;font-weight:700;font-family:var(--mono);padding:5px 9px;border-radius:5px;cursor:pointer;color:var(--muted);background:transparent;border:1px solid transparent;white-space:nowrap;transition:all .14s;}
.dos-tab.act{background:rgba(245,158,11,.1);color:var(--amber);border-color:rgba(245,158,11,.25);}
.dos-body{flex:1;overflow-y:auto;padding:14px 14px 20px;}
.dos-body::-webkit-scrollbar{width:3px;}
.dos-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* Legend */
.mc-legend{position:absolute;bottom:20px;left:14px;z-index:500;background:rgba(255,253,249,.94);border:1px solid var(--border);border-radius:10px;padding:10px 12px;backdrop-filter:blur(10px);box-shadow:var(--shadow);}
.mc-legend-title{font-family:var(--mono);font-size:8.5px;letter-spacing:1.5px;color:var(--amber);text-transform:uppercase;margin-bottom:7px;}
.mc-legend-item{display:flex;align-items:center;gap:7px;margin-bottom:3px;font-size:10px;color:var(--graphite);}
.mc-legend-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}

/* Vision panel */
#visionPanel{position:absolute;bottom:20px;right:14px;z-index:500;background:rgba(255,253,249,.96);border:1px solid var(--border2);border-radius:10px;padding:11px 13px;font-size:10.5px;min-width:190px;backdrop-filter:blur(10px);display:none;pointer-events:none;box-shadow:var(--shadow);}
.vision-title{font-family:var(--mono);font-size:8.5px;letter-spacing:1.5px;color:var(--amber);margin-bottom:7px;text-transform:uppercase;}
.vision-row{display:flex;justify-content:space-between;margin-bottom:4px;padding-bottom:4px;border-bottom:1px solid rgba(226,217,200,.5);}
.vision-row:last-child{border:none;margin:0;padding:0;}
.vision-val{font-family:var(--mono);font-weight:700;color:var(--slate);}

/* Pulsing markers */
@keyframes smpulse{0%{transform:translate(-50%,-50%) scale(.6);opacity:.6;}100%{transform:translate(-50%,-50%) scale(2.5);opacity:0;}}
.sm-pulse{position:absolute;top:50%;left:50%;width:20px;height:20px;border-radius:50%;background:var(--mc,#F59E0B);animation:smpulse 2.2s ease-out infinite;}
.sm-pulse2{position:absolute;top:50%;left:50%;width:20px;height:20px;border-radius:50%;background:var(--mc,#F59E0B);animation:smpulse 2.2s ease-out 1.1s infinite;}
.sm-dot{position:relative;z-index:1;width:20px;height:20px;border-radius:50%;background:var(--mc,#F59E0B);border:2px solid rgba(255,255,255,.9);box-shadow:0 2px 12px var(--mc,#F59E0B),0 1px 4px rgba(0,0,0,.15);display:flex;align-items:center;justify-content:center;}
.sm-rank{font-family:var(--mono);font-size:8.5px;font-weight:900;color:#fff;}
.surya-marker{position:relative;cursor:pointer;}

/* Leaflet tooltips — warm theme */
.leaflet-tooltip.warm-tt{background:rgba(255,253,249,.97);border:1px solid var(--border2);color:var(--slate);font-family:var(--body);font-size:11px;box-shadow:var(--shadow);border-radius:7px;padding:6px 10px;}
.leaflet-tooltip.warm-tt::before{border-top-color:var(--border2)!important;}

/* ── OVERVIEW PANEL ── */
.ov-wrap{flex:1;overflow-y:auto;padding:24px;background:var(--pearl);}
.ov-wrap::-webkit-scrollbar{width:4px;}
.ov-wrap::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.ov-hero{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px 32px;margin-bottom:20px;display:flex;align-items:flex-start;gap:24px;box-shadow:var(--shadow);}
.ov-hero-text{flex:1;}
.ov-hero-title{font-family:var(--head);font-size:22px;font-weight:800;color:var(--slate);margin-bottom:6px;}
.ov-hero-sub{font-size:13px;color:var(--mid);line-height:1.7;margin-bottom:16px;}
.ov-hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);border-radius:8px;padding:5px 12px;font-size:11px;font-weight:600;color:var(--amber);}
.ov-stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:20px;}
.ov-stat-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:18px 20px;box-shadow:var(--shadow);}
.ov-stat-v{font-family:var(--head);font-size:28px;font-weight:900;color:var(--slate);display:block;margin-bottom:3px;}
.ov-stat-l{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.5px;}
.ov-stat-trend{font-size:10px;font-weight:600;margin-top:5px;}
.ov-hotspots{margin-bottom:20px;}
.section-title{font-family:var(--head);font-size:16px;font-weight:800;color:var(--slate);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.section-title::after{content:'';flex:1;height:1px;background:var(--border);}
.hot-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;}
.hot-card{background:var(--white);border:1px solid var(--border);border-left:4px solid var(--hc,var(--amber));border-radius:10px;padding:14px 16px;cursor:pointer;transition:all .14s;box-shadow:var(--shadow);}
.hot-card:hover{transform:translateY(-2px);box-shadow:var(--shadow2);}
.hot-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px;}
.hot-name{font-size:13px;font-weight:700;color:var(--slate);}
.hot-rank{font-family:var(--mono);font-size:11px;font-weight:800;color:white;background:var(--hc,var(--amber));border-radius:5px;padding:2px 7px;}
.hot-meta{font-size:11px;color:var(--muted);margin-bottom:9px;}
.hot-bars{display:flex;flex-direction:column;gap:5px;}
.hot-bar-row{display:flex;align-items:center;gap:8px;font-size:10px;color:var(--mid);}
.hot-bar-lbl{width:90px;flex-shrink:0;}
.hot-bar-track{flex:1;height:4px;background:var(--sand);border-radius:99px;overflow:hidden;}
.hot-bar-fill{height:100%;border-radius:99px;}
.hot-bar-val{font-family:var(--mono);font-size:10px;font-weight:700;width:32px;text-align:right;flex-shrink:0;color:var(--slate);}
.ov-narrative{background:rgba(245,158,11,.05);border:1px solid rgba(245,158,11,.18);border-radius:12px;padding:18px 20px;font-size:13px;color:var(--graphite);line-height:1.75;}
.ov-narrative b{color:var(--amber);}

/* ── SURYA LAB ── */
.lab-wrap{flex:1;overflow-y:auto;padding:24px;}
.lab-zones{display:flex;gap:20px;align-items:flex-start;}
.lab-rail{width:240px;flex-shrink:0;display:flex;flex-direction:column;gap:6px;}
.lab-chip{display:flex;align-items:center;gap:8px;padding:9px 12px;background:var(--white);border:1px solid var(--border);border-left:3px solid var(--hc,var(--amber));border-radius:8px;cursor:pointer;transition:all .14s;font-family:var(--body);}
